  _V SUB_MULTI_TRACK
  printf '\n'

  printf '\n'
  echo "# ========================="
  echo "# External subtitle discovery"
  echo "# ========================="
  printf '\n'
  echo "# Discover external subtitle files alongside the source"
  echo "# (e.g. Movie.en.srt, Movie.en.forced.srt next to Movie.mkv)."
