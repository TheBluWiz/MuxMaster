  printf '#EXT_SUB_ENABLED=1\n'
  printf '\n'
  echo "# Override the directory searched for external subtitles"
  echo "# (default: same directory as the source file)"
  printf '#EXT_SUB_DIR=\n'
  printf '\n'

  printf '\n'
  echo "# ========================="
  echo "# Mux / output container"
  echo "# ========================="
  printf '\n'
  echo "# Output extension: mp4|m4v|mov|mkv"
  _V OUTPUT_EXT
  printf '\n'
  echo "# Keep chapter markers in output"
  _V KEEP_CHAPTERS
  printf '\n'
  echo "# Strip non-essential metadata from output"
  _V STRIP_METADATA
  printf '\n'
  echo "# Embed profile tagline in container comment metadata (on by default when a profile is active)"
  _V PROFILE_COMMENT
  printf '\n'
