      --no-keep-chapters)           _CC_OVERRIDES[KEEP_CHAPTERS]=0;                                                                     (( ++_cc_oi )) ;;
      --strip-metadata)             _CC_OVERRIDES[STRIP_METADATA]=1;                                                                    (( ++_cc_oi )) ;;
      --no-strip-metadata)          _CC_OVERRIDES[STRIP_METADATA]=0;                                                                    (( ++_cc_oi )) ;;
      --report-json)                _CC_OVERRIDES[REPORT_JSON]=1;                                                                       (( ++_cc_oi )) ;;
      --no-report-json)             _CC_OVERRIDES[REPORT_JSON]=0;                                                                       (( ++_cc_oi )) ;;
      --profile-comment)            _CC_OVERRIDES[PROFILE_COMMENT]=1;                                                                   (( ++_cc_oi )) ;;
      --no-profile-comment)         _CC_OVERRIDES[PROFILE_COMMENT]=0;                                                                   (( ++_cc_oi )) ;;
      # Logging
      --ffmpeg-loglevel)            _cc_val="${_cc_override_argv[$((_cc_oi+1))]}"; _CC_OVERRIDES[FFMPEG_LOGLEVEL]="$_cc_val";           (( _cc_oi += 2 )) ;;
      --ffprobe-loglevel)           _cc_val="${_cc_override_argv[$((_cc_oi+1))]}"; _CC_OVERRIDES[FFPROBE_LOGLEVEL]="$_cc_val";          (( _cc_oi += 2 )) ;;
      *)
        printf '❌ ERROR: Unknown config override: %s\n' "$_cc_flag" >&2
        printf '   Use --create-config without extra flags to generate a default template.\n' >&2
        exit 11
        ;;
    esac
  done

  # Normalize deprecated aliases
  if [[ "$profile" == "dv-archival" ]]; then
    warn "Profile 'dv-archival' is deprecated. Using 'archive' instead."
    profile="archive"
  elif [[ "$profile" == "streaming" ]]; then
    warn "Profile 'streaming' is deprecated. Use 'streaming-hevc' instead."
    profile="streaming-hevc"
  fi

  # Validate scope → target path
  local target_path
  case "$scope" in
    system)  target_path="/etc/.muxmrc" ;;
    user)    target_path="$HOME/.muxmrc" ;;
    project) target_path="$PWD/.muxmrc" ;;
    *)
      printf '❌ ERROR: Invalid scope: %s\n' "$scope" >&2
      printf '   Valid scopes: system, user, project\n' >&2
      printf '   system  → /etc/.muxmrc\n' >&2
      printf '   user    → ~/.muxmrc\n' >&2
      printf '   project → %s/.muxmrc\n' "$PWD" >&2
      exit 11
      ;;
  esac

  # Detect multi-profile (comma-separated) and validate accordingly
  local _cc_is_multi=0
  if [[ "$profile" == *,* ]]; then
    _cc_is_multi=1
    local _cc_mp _cc_mp_list=() _cc_norm_list=()
    IFS=',' read -ra _cc_mp_list <<< "$profile"
    for _cc_mp in "${_cc_mp_list[@]}"; do
      [[ -z "$_cc_mp" ]] && { printf '❌ ERROR: Empty profile name in list: %s\n' "$profile" >&2; exit 11; }
      # Normalize deprecated aliases within each entry of a multi-profile list.
      # The single-profile normalization above only fires when the whole string is an
      # alias; for comma-separated lists each element must be checked individually so
      # the config file is written with current canonical names, not deprecated ones.
      case "$_cc_mp" in
        dv-archival) warn "Profile 'dv-archival' is deprecated. Using 'archive' instead."; _cc_mp="archive" ;;
        streaming)   warn "Profile 'streaming' is deprecated. Use 'streaming-hevc' instead."; _cc_mp="streaming-hevc" ;;
      esac
      if ! _is_valid_profile "$_cc_mp"; then
        printf '❌ ERROR: Unknown profile: %s\n' "$_cc_mp" >&2
        printf '   Valid profiles: %s\n' "$(_valid_profiles_display)" >&2
        exit 11
      fi
      _cc_norm_list+=("$_cc_mp")
    done
    # Rebuild profile string from normalized entries
    local _cc_IFS_save="$IFS"; IFS=','; profile="${_cc_norm_list[*]}"; IFS="$_cc_IFS_save"
  else
    if ! _is_valid_profile "$profile"; then
      printf '❌ ERROR: Unknown profile: %s\n' "$profile" >&2
      printf '   Valid profiles: %s\n' "$(_valid_profiles_display)" >&2
      exit 11
    fi
  fi

  # Check for existing file (refuse unless --force-create-config)
  if [[ -f "$target_path" ]] && (( ! force )); then
    printf '❌ ERROR: Config file already exists: %s\n' "$target_path" >&2
    printf '   To overwrite, use --force-create-config instead of --create-config.\n' >&2
    printf '   Or remove the file manually:  rm %s\n' "$target_path" >&2
    exit 1
  fi

  # Check write permissions
  local target_dir
  target_dir="$(dirname "$target_path")"
  if [[ ! -w "$target_dir" ]]; then
    printf '❌ ERROR: No write permission for %s\n' "$target_dir" >&2
    if [[ "$scope" == "system" ]]; then
      printf '   Try: sudo muxm --create-config system %s\n' "$profile" >&2
    fi
    exit 1
  fi

  # Generate the config file
  if (( _cc_is_multi )); then
    _create_config_emit_multi "$profile" > "$target_path"
  else
    _create_config_emit "$profile" > "$target_path"
  fi

  printf '✅ Created %s config → %s\n' "$profile" "$target_path"
  if (( ${#_CC_OVERRIDES[@]} > 0 )); then
    printf 'ℹ️  Applied %d override(s) to generated config.\n' "${#_CC_OVERRIDES[@]}"
  fi
  printf '   Profile: %s\n' "$profile"
  printf '   Scope:   %s\n' "$scope"
  printf '\n'

  if (( _cc_is_multi )); then
    printf '   Multi-profile config — only PROFILE_NAME and explicit overrides written.\n'
    printf '   Each encode will run all listed profiles sequentially.\n'
    printf '   CLI flags always override config-file values.\n'
  else
    printf '   Profile-specific variables are uncommented and active.\n'
    printf '   All other variables are commented — uncomment to customize.\n'
    printf '   CLI flags always override config-file values.\n'
    printf '\n'

    # Report detected subtitle OCR tools
    local _det_ocr=""
    if command -v pgsrip >/dev/null 2>&1; then _det_ocr="pgsrip"; fi
    if command -v sub2srt >/dev/null 2>&1; then _det_ocr="${_det_ocr:+$_det_ocr, }sub2srt"; fi
    if [[ -n "$_det_ocr" ]]; then
      printf '   🔍 Detected OCR tools: %s\n' "$_det_ocr"
      printf '      SUB_ENABLE_OCR and SUB_OCR_TOOL set automatically.\n'
    else
      printf '   ⚠️  No subtitle OCR tools detected (pgsrip, sub2srt).\n'
      printf '      PGS/bitmap subtitles will be dropped unless you install one.\n'
      printf '      Run: muxm --install-dependencies\n'
    fi
  fi
  exit 0
}

# Pre-scan for --create-config / --force-create-config is below in Section 11,
# after profile functions are defined (they're needed by the config generator).


# ===== Section 11: Profiles & application =====================================================
# Two-pass CLI: first extract --profile, apply it, then let full CLI parse override.
#
# Precedence for PROFILE_NAME:
#   1. /etc/.muxmrc, ~/.muxmrc, ./.muxmrc  — may set PROFILE_NAME (lowest)
#   2. CLI --profile <n>                    — overrides config-file value (highest)
#
# Users can set a default profile in any .muxmrc file:
#   PROFILE_NAME="atv-directplay-hq"
# CLI --profile always overrides a config-file PROFILE_NAME.

# Track where the profile originated (for diagnostics / conflict warnings)
_PROFILE_SOURCE=""
if [[ -n "${PROFILE_NAME:-}" ]]; then
  _PROFILE_SOURCE="config-file"
fi

# Pre-scan: walk args looking only for --profile <n>
_prescan_args=("$@")
_filtered_args=()
_i=0
while (( _i < ${#_prescan_args[@]} )); do
  if [[ "${_prescan_args[$_i]}" == "--profile" ]]; then
    if (( _i + 1 < ${#_prescan_args[@]} )); then
      PROFILE_NAME="${_prescan_args[$((_i+1))]}"
      _PROFILE_SOURCE="cli"
      (( _i += 2 ))
    else
      die 11 "--profile requires a profile name ($(_valid_profiles_display))"
    fi
  else
    _filtered_args+=("${_prescan_args[$_i]}")
    # Use pre-increment (++_i) rather than post-increment (_i++) so the arithmetic
    # expression always evaluates to the new value (≥1), which is truthy.
    # Post-increment returns the *old* value, so when _i==0 the expression yields 0
    # (false) and set -e would silently exit the script before the main arg loop.
    (( ++_i ))
  fi
done
# Replace positional parameters with filtered args (--profile consumed)
set -- "${_filtered_args[@]}"
unset _prescan_args _filtered_args _i

# Multi-profile: detect comma-separated --profile and validate all names upfront.
# Single profile: behaviour is exactly as before (no multi-profile path activated).
if [[ "${PROFILE_NAME:-}" == *,* ]]; then
  # Reject malformed lists: leading comma, trailing comma, or consecutive commas
  if [[ "$PROFILE_NAME" == ,* || "$PROFILE_NAME" == *, || "$PROFILE_NAME" == *,,* ]]; then
    die 11 "--profile: empty profile name in list '$PROFILE_NAME'"
  fi
  IFS=',' read -ra _MULTI_PROFILES <<< "$PROFILE_NAME"
  for _mp in "${_MULTI_PROFILES[@]}"; do
    [[ -z "$_mp" ]] && die 11 "--profile: empty profile name in list '$PROFILE_NAME'"
    _is_valid_profile "$_mp" || die 11 "Unknown profile '${_mp}' in --profile list. Valid: $(_valid_profiles_display)"
  done
  _MULTI_PROFILE_MODE=1
  # Use first profile for single-pass config/conflict checks in the parent process
  PROFILE_NAME="${_MULTI_PROFILES[0]}"
fi
# Save filtered CLI args (--profile consumed) for multi-profile re-invocation
_ORIG_FILTERED_ARGS=("$@")

# ---- Profile application functions (pure assignment, no side effects) ----

apply_profile_archive() {
  # Goal: Preserve DV + HDR10 metadata, lossless audio, lossless remux only.
  DISABLE_DV=0
  ALLOW_DV_FALLBACK=1
  DV_CONVERT_TO_P81_IF_FAIL=1
  # Container: passthrough — keep source container.
  # Sources with unsupported output containers (avi, ts, etc.) fall back to mkv
  # via the passthrough resolution block in Section 15.
  OUTPUT_EXT=""
  # Video: copy, don't re-encode
  VIDEO_COPY_IF_COMPLIANT=1
  VIDEO_CODEC="libx265"
  # Audio: multi-track, copy all matching tracks from source.
  # No scoring, no transcoding, no stereo fallback.
  # Empty AUDIO_LANG_PREF = keep all languages (archival default).
  AUDIO_MULTI_TRACK=1
  AUDIO_KEEP_COMMENTARY=0
  AUDIO_LANG_PREF=""
  AUDIO_LOSSLESS_PASSTHROUGH=1
  ADD_STEREO_IF_MULTICH=0
  AUDIO_CODEC_PREFERENCE="truehd,dts,flac,eac3,ac3,aac,alac,other"
  # Subs: multi-track, keep all; no burn
  # Empty SUB_LANG_PREF = keep all languages (archival default).
  SUB_MULTI_TRACK=1
  SUB_LANG_PREF=""
  SUB_INCLUDE_FORCED=1
  SUB_INCLUDE_FULL=1
  SUB_INCLUDE_SDH=1
  SUB_MAX_TRACKS=99
  SUB_BURN_FORCED=0
  SUB_EXPORT_EXTERNAL=0
  # Chapters/metadata: keep
  KEEP_CHAPTERS=1
  STRIP_METADATA=0
  # Skip-if-ideal: on
  SKIP_IF_IDEAL=1
  # Reporting: JSON + SHA-256 checksum (archival integrity)
  REPORT_JSON=1
  CHECKSUM=1
}

# DEPRECATED: 'dv-archival' is a backwards-compatibility alias for 'archive'.
# Emits a deprecation notice and delegates to apply_profile_archive.
apply_profile_dv_archival() {
  warn "Profile 'dv-archival' is deprecated. Use '--profile archive' instead."
  apply_profile_archive
}

apply_profile_hdr10_hq() {
  # Goal: Max HDR10 quality, strip DV, preserve lossless audio + stereo fallback.
  DISABLE_DV=1
  ALLOW_DV_FALLBACK=0
  DV_CONVERT_TO_P81_IF_FAIL=0
  # Container: mkv
  OUTPUT_EXT="mkv"
  # Video: HEVC re-encode with high-quality HDR10 params
  VIDEO_CODEC="libx265"
  VIDEO_COPY_IF_COMPLIANT=0
  CRF_VALUE=17
  PRESET_VALUE="slower"
  X265_PARAMS_BASE='profile=main10:repeat-headers=1:hdr-opt=1:hdr10=1:hdr10-opt=1:colorprim=bt2020:transfer=smpte2084:colormatrix=bt2020nc:range=limited:aq-mode=3:aq-strength=1.3:psy-rd=2.0:psy-rdoq=1.0:rc-lookahead=60'
  HDR_TARGET_PIXFMT="yuv420p10le"
  FORCE_CHROMA_420=1
  # Audio: lossless passthrough + stereo fallback
  AUDIO_LOSSLESS_PASSTHROUGH=1
  ADD_STEREO_IF_MULTICH=1
  STEREO_BITRATE="256k"
  # Subs: keep all; no burn
  SUB_INCLUDE_FORCED=1
  SUB_INCLUDE_FULL=1
  SUB_INCLUDE_SDH=1
  SUB_BURN_FORCED=0
  # Chapters/metadata: keep
  KEEP_CHAPTERS=1
  STRIP_METADATA=0
}

apply_profile_atv_directplay_hq() {
  # Goal: Conform to Apple TV/Plex Direct Play constraints while keeping high quality.
  DISABLE_DV=0
  ALLOW_DV_FALLBACK=1
  DV_CONVERT_TO_P81_IF_FAIL=1
  # Container: passthrough — preserve source container.
  # mkv sources produce mkv output; mp4 sources produce mp4 output.
  # Apple TV Direct Play supports both containers for HEVC Main10 + DV P8.1.
  # When output is mkv, the post-resolution block (Section 15) enables native
  # ASS subtitle preservation and disables forced-sub burning. See Step 8.
  OUTPUT_EXT=""
  # Video: prefer copy if compliant; else HEVC Main10
  VIDEO_CODEC="libx265"
  VIDEO_COPY_IF_COMPLIANT=1
  MAX_COPY_BITRATE="50000k"
  CRF_VALUE=17
  PRESET_VALUE="slower"
  LEVEL_VALUE="5.1"
  CONSERVATIVE_VBV=1
  X265_PARAMS_BASE='profile=main10:repeat-headers=1:hdr-opt=1:hdr10=1:hdr10-opt=1:aq-mode=3:aq-strength=1.3:psy-rd=2.0:psy-rdoq=1.0:rc-lookahead=60'
  HDR_TARGET_PIXFMT="yuv420p10le"
  FORCE_CHROMA_420=1
  # Audio: E-AC-3 for surround (ATV can't Direct Play TrueHD), AAC stereo fallback
  AUDIO_LOSSLESS_PASSTHROUGH=0
  ADD_STEREO_IF_MULTICH=1
  STEREO_BITRATE="256k"
  EAC3_BITRATE_5_1="640k"
  EAC3_BITRATE_7_1="768k"
  # Subs: burn forced (or mov_text); keep others as mov_text
  SUB_INCLUDE_FORCED=1
  SUB_INCLUDE_FULL=1
  SUB_INCLUDE_SDH=1
  SUB_BURN_FORCED=1
  SUB_EXPORT_EXTERNAL=0
  # Chapters/metadata: keep
  KEEP_CHAPTERS=1
  STRIP_METADATA=0
  # Skip-if-ideal: on
  SKIP_IF_IDEAL=1
}

apply_profile_atv_directplay_animation() {
  # Goal: Animation-quality encode shaped for Apple TV / Plex Direct Play.
  # Combines atv-directplay-hq ATV constraints with animation's quality-first settings.
  DISABLE_DV=0
  ALLOW_DV_FALLBACK=1
  DV_CONVERT_TO_P81_IF_FAIL=1
  # Container: passthrough — preserve source container (same as atv-directplay-hq).
  # When output is MKV the post-resolution block (Section 15) disables forced-sub
  # burning and confirms ASS preservation. See Section 15.
  OUTPUT_EXT=""
  # Video: prefer copy if compliant; else HEVC Main10 with animation-tuned params
  VIDEO_CODEC="libx265"
  VIDEO_COPY_IF_COMPLIANT=1
  MAX_COPY_BITRATE="50000k"
  CRF_VALUE=16
  PRESET_VALUE="slower"
  LEVEL_VALUE="5.1"
  CONSERVATIVE_VBV=1
  # Animation-tuned params + HDR10 signalling required by ATV. Lower psy-rd/psy-rdoq,
  # adjusted deblock, and extra b-frames for banding-free flat-gradient animation.
  X265_PARAMS_BASE='profile=main10:repeat-headers=1:hdr-opt=1:hdr10=1:hdr10-opt=1:aq-mode=3:aq-strength=0.8:psy-rd=1.0:psy-rdoq=0.5:rc-lookahead=60:deblock=-1,-1:bframes=8'
  HDR_TARGET_PIXFMT="yuv420p10le"
  FORCE_CHROMA_420=1
  SDR_USE_10BIT_IF_SRC_10BIT=1
  SDR_FORCE_10BIT=1
  # Audio: E-AC-3 for surround (ATV cannot Direct Play TrueHD/DTS-HD MA), AAC stereo fallback.
  # Lossless tracks are transcoded rather than passed through.
  AUDIO_LOSSLESS_PASSTHROUGH=0
  ADD_STEREO_IF_MULTICH=1
  STEREO_BITRATE="256k"
  EAC3_BITRATE_5_1="640k"
  EAC3_BITRATE_7_1="768k"
  # Subs: multi-track; burn forced subs for MP4 Direct Play (overridden to soft for MKV
  # by the post-resolution block in Section 15). Preserve ASS/SSA natively.
  SUB_MULTI_TRACK=1
  SUB_INCLUDE_FORCED=1
  SUB_INCLUDE_FULL=1
  SUB_INCLUDE_SDH=1
  SUB_MAX_TRACKS=6
  SUB_BURN_FORCED=1
  SUB_EXPORT_EXTERNAL=0
  SUB_PRESERVE_TEXT_FORMAT=1
  # Chapters/metadata: keep
  KEEP_CHAPTERS=1
  STRIP_METADATA=0
  # Skip-if-ideal: on
  SKIP_IF_IDEAL=1
}

apply_profile_universal() {
  # Goal: Compatibility over fidelity. SDR H.264, AAC stereo, burn forced subs.
  DISABLE_DV=1
  ALLOW_DV_FALLBACK=0
  DV_CONVERT_TO_P81_IF_FAIL=0
  # Container: mp4
  OUTPUT_EXT="mp4"
  # Video: H.264 SDR, tone-map HDR if present
  VIDEO_CODEC="libx264"
  VIDEO_COPY_IF_COMPLIANT=0
  TONEMAP_HDR_TO_SDR=1
  CRF_VALUE=22
  PRESET_VALUE="slow"
  FORCE_CHROMA_420=1
