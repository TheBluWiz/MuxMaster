_install_man(){
  local mandir
  mandir="$(_man_target_dir)"
  local target="${mandir}/${CLI_NAME}.1"

  say "=== ${APP_NAME} v${VERSION} — Manual Page Installer ==="
  printf '\n'
  printf '  Target: %s\n' "$target"

  # Create directory if needed
  if [[ ! -d "$mandir" ]]; then
    printf '  📁 Creating %s ...\n' "$mandir"
    if [[ -w "$(dirname "$mandir")" ]]; then
      mkdir -p "$mandir"
    else
      sudo mkdir -p "$mandir"
    fi
  fi

  # Write the man page
  if [[ -w "$mandir" ]]; then
    _man_emit > "$target"
  else
    printf '  🔐 Requires elevated permissions.\n'
    _man_emit | sudo tee "$target" > /dev/null
  fi

  printf '  ✅ Installed %s\n' "$target"
  printf '\n'

  # Update man database if mandb/makewhatis available
  if command -v mandb >/dev/null 2>&1; then
    printf '  🔄 Updating man database ...\n'
    if [[ -w "$mandir" ]]; then
      mandb -q 2>/dev/null || true
    else
      sudo mandb -q 2>/dev/null || true
    fi
  fi

  printf '\n  View with: man %s\n' "$CLI_NAME"
  exit 0
}

_uninstall_man(){
  local mandir
  mandir="$(_man_target_dir)"
  local target="${mandir}/${CLI_NAME}.1"

  say "=== ${APP_NAME} v${VERSION} — Manual Page Uninstaller ==="
  printf '\n'

  if [[ ! -f "$target" ]]; then
    printf '  ⚠️  Man page not found at %s — nothing to remove.\n' "$target"
    exit 0
  fi

  printf '  Target: %s\n' "$target"
  if [[ -w "$mandir" ]]; then
    rm -f "$target"
  else
    printf '  🔐 Requires elevated permissions.\n'
    sudo rm -f "$target"
  fi

  printf '  ✅ Removed %s\n' "$target"
  exit 0
}

# Pre-scan for --install-man / --uninstall-man
for _arg in "$@"; do
  case "$_arg" in
    --install-man)   _install_man ;;
    --uninstall-man) _uninstall_man ;;
  esac
done
unset _arg

# ===== Section 9: Completion installer (--install-completions / --uninstall-completions) ======
# Embeds the full bash/zsh completion script and installs it to ~/.muxm/.
# Adds a `source` line to the user's shell RC file(s) (~/.bashrc, ~/.bash_profile, ~/.zshrc).

# <<< embedded completion script >>>
_completions_emit(){
  sed "s/__MUXM_PROFILES__/$VALID_PROFILES/g" <<'COMPLETIONS_EOF'
# =============================================================================
#  muxm — Bash/Zsh tab completion  (installed by muxm --install-completions)
# =============================================================================

_muxm_completions() {
    local cur prev
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    # ---- Flags that take a specific set of values ----
    case "$prev" in
        --profile)
            COMPREPLY=( $(compgen -W "__MUXM_PROFILES__" -- "$cur") )
            return ;;
        --video-codec)
            COMPREPLY=( $(compgen -W "libx265 libx264 libsvt-av1 libaom-av1" -- "$cur") )
            return ;;
        --output-ext)
            COMPREPLY=( $(compgen -W "mp4 mkv m4v mov" -- "$cur") )
            return ;;
        -p|--preset)
            COMPREPLY=( $(compgen -W "ultrafast superfast veryfast faster fast medium slow slower veryslow placebo" -- "$cur") )
            return ;;
        --ocr-tool)
            COMPREPLY=( $(compgen -W "pgsrip sub2srt" -- "$cur") )
            return ;;
        --ffmpeg-loglevel|--ffprobe-loglevel)
            COMPREPLY=( $(compgen -W "quiet panic fatal error warning info verbose debug trace" -- "$cur") )
            return ;;
        --create-config|--force-create-config)
            COMPREPLY=( $(compgen -W "system user project" -- "$cur") )
            return ;;
        --checksum-algo)
            COMPREPLY=( $(compgen -W "sha256 blake2b auto" -- "$cur") )
            return ;;

        # Flags that take a free-form value — offer no completion, fall through to files
        --crf|--stereo-bitrate|--threads|-l|--level|--x265-params|\
        --av1-params|--av1-maxrate|--av1-bufsize|\
        --audio-track|--audio-lang-pref|--audio-force-codec|\
        --max-copy-bitrate|--sub-lang-pref|--ocr-lang|--ext-subs-dir)
            COMPREPLY=()
            return ;;
    esac

    # ---- After --create-config <scope>, offer profile names ----
    if (( COMP_CWORD >= 3 )); then
        local pprev="${COMP_WORDS[COMP_CWORD-2]}"
        if [[ "$pprev" == "--create-config" || "$pprev" == "--force-create-config" ]]; then
            COMPREPLY=( $(compgen -W "__MUXM_PROFILES__" -- "$cur") )
            return
        fi
    fi

    # ---- If typing a flag, complete from all known flags ----
    if [[ "$cur" == -* ]]; then
        local flags="
            -h --help -V --version
            --profile --dry-run --print-effective-config
            --install-dependencies --install-man --uninstall-man
            --install-completions --uninstall-completions
            --setup
            --create-config --force-create-config

            --crf -p --preset --x265-params -l --level
            --av1-params --av1-maxrate --av1-bufsize
            --video-codec --tonemap --no-tonemap
            --sdr-force-10bit --no-sdr-force-10bit
            --conservative-vbv --no-conservative-vbv
            --dv --no-dv --allow-dv-fallback --no-allow-dv-fallback
            --dv-convert-p81 --no-dv-convert-p81
            --video-copy-if-compliant --no-video-copy-if-compliant
            --max-copy-bitrate

            --audio-track --audio-lang-pref
            --stereo-fallback --no-stereo-fallback --stereo-bitrate
            --audio-force-codec
            --audio-lossless-passthrough --no-audio-lossless-passthrough
            --audio-titles --no-audio-titles

            --sub-burn-forced --no-sub-burn-forced
            --sub-export-external --no-sub-export-external
            --sub-preserve-format --no-sub-preserve-format
            --sub-preserve-bitmap --no-sub-preserve-bitmap
            --sub-lang-pref --no-sub-sdh --no-subtitles
            --ocr-lang --no-ocr --ocr-tool
            --ext-subs --no-ext-subs --ext-subs-dir
            --sub-sole-ext-fallback --no-sub-sole-ext-fallback

            --skip-video --skip-audio --skip-subs

            --output-ext
            --keep-chapters --no-keep-chapters
            --strip-metadata --no-strip-metadata
            --profile-comment --no-profile-comment
            --skip-if-ideal --no-skip-if-ideal
            --report-json --no-report-json
            --checksum --no-checksum --checksum-algo
            --disk-check --no-disk-check
            --no-overwrite
            --replace-source --force-replace-source

            -k --keep-temp -K --keep-temp-always
            --ffmpeg-loglevel --ffprobe-loglevel --no-hide-banner
            --threads
        "
        COMPREPLY=( $(compgen -W "$flags" -- "$cur") )
        return
    fi

    # ---- Default: complete with media files ----
    # Uses typeset -l for case-insensitive extension matching (works in both
    # bash 4+ and zsh) and a while-read loop instead of mapfile (bash-only).
    # Avoids shopt/extglob which are unavailable in zsh even with bashcompinit.
    COMPREPLY=()
    local _f
    local _ext_lower
    typeset -l _ext_lower  # auto-lowercase on assignment (portable bash+zsh)
    while IFS= read -r _f; do
        _ext_lower="${_f##*.}"
        case "$_ext_lower" in
            mkv|mp4|m4v|mov|avi|ts|wmv|flv|webm) COMPREPLY+=("$_f") ;;
        esac
    done < <(compgen -f -- "$cur")
    # Also allow directories for navigation
    while IFS= read -r _f; do
        COMPREPLY+=("$_f")
    done < <(compgen -d -- "$cur")
}

# ---- Zsh compatibility ----
# If running in zsh, enable bash completion emulation BEFORE calling `complete`.
# Without this, the unconditional `complete` below would error in zsh.
if [[ -n "${ZSH_VERSION:-}" ]]; then
    autoload -Uz bashcompinit && bashcompinit
fi

complete -o filenames -o bashdefault -F _muxm_completions muxm
COMPLETIONS_EOF
}
# <<< end embedded completion script >>>

# Portable sed in-place: macOS sed requires '' after -i, GNU sed does not.
_sed_inplace(){
  if sed --version 2>/dev/null | grep -q GNU; then
    sed -i "$@"
  else
    sed -i '' "$@"
  fi
}

# shellcheck disable=SC2016  # $HOME must expand at shell-startup, not install-time
_completions_source_line='source "$HOME/.muxm/muxm-completion.bash"'
_completions_marker='# muxm tab completion'

_install_completions(){
  local comp_dir="$HOME/.muxm"
  local comp_file="$comp_dir/muxm-completion.bash"

  say "=== ${APP_NAME} v${VERSION} — Completion Installer ==="
  printf '\n'

  # Create directory (handle stale file from earlier installs)
  if [[ -e "$comp_dir" && ! -d "$comp_dir" ]]; then
    printf '  ⚠️  %s exists as a file — replacing with directory\n' "$comp_dir"
    rm -f "$comp_dir"
  fi
  if [[ ! -d "$comp_dir" ]]; then
    printf '  📁 Creating %s\n' "$comp_dir"
    mkdir -p "$comp_dir"
  fi

  # Write completion script
  _completions_emit > "$comp_file"
  chmod +x "$comp_file"
  printf '  ✅ Wrote %s\n' "$comp_file"
  printf '\n'

  # Detect and patch shell RC files
  local -a rc_files=()
  # Bash: prefer ~/.bash_profile on macOS (login shell), ~/.bashrc on Linux
  [[ -f "$HOME/.bash_profile" ]] && rc_files+=("$HOME/.bash_profile")
  [[ -f "$HOME/.bashrc" ]]       && rc_files+=("$HOME/.bashrc")
  [[ -f "$HOME/.zshrc" ]]        && rc_files+=("$HOME/.zshrc")

  if [[ ${#rc_files[@]} -eq 0 ]]; then
    printf '  ⚠️  No shell RC files found (~/.bashrc, ~/.bash_profile, ~/.zshrc).\n'
    printf '     Add this line manually to your shell config:\n\n'
    printf '       %s\n' "$_completions_marker"
    printf '       %s\n\n' "$_completions_source_line"
  else
    local patched=0
    for rc in "${rc_files[@]}"; do
      local rc_base="${rc##*/}"
      printf '  %-20s' "$rc_base"
      if grep -qF 'muxm-completion.bash' "$rc" 2>/dev/null; then
        printf '✅ already configured\n'
      else
        # Ensure file ends with a newline before appending
        [[ -s "$rc" ]] && [[ "$(tail -c 1 "$rc")" != "" ]] && printf '\n' >> "$rc"
        printf '\n%s\n%s\n' "$_completions_marker" "$_completions_source_line" >> "$rc"
        printf '✅ added source line\n'
        patched=$(( patched + 1 ))
      fi
    done

    printf '\n'
    if (( patched > 0 )); then
      printf '  Restart your shell or run:\n'
      printf '    source %s\n' "$comp_file"
    else
      printf '  All shell configs already have muxm completions.\n'
    fi
  fi

  exit 0
}

_uninstall_completions(){
  local comp_dir="$HOME/.muxm"
  local comp_file="$comp_dir/muxm-completion.bash"

  say "=== ${APP_NAME} v${VERSION} — Completion Uninstaller ==="
  printf '\n'

  # Remove completion file
  if [[ -f "$comp_file" ]]; then
    rm -f "$comp_file"
    printf '  ✅ Removed %s\n' "$comp_file"
  else
    printf '  ⚠️  Completion file not found at %s\n' "$comp_file"
  fi

  # Clean source lines from RC files
  local -a rc_files=("$HOME/.bash_profile" "$HOME/.bashrc" "$HOME/.zshrc")
  for rc in "${rc_files[@]}"; do
    [[ -f "$rc" ]] || continue
    local rc_base="${rc##*/}"
    if grep -qF 'muxm-completion.bash' "$rc" 2>/dev/null; then
      # Remove the marker comment and source line
      _sed_inplace '/# muxm tab completion/d' "$rc"
      _sed_inplace '/muxm-completion\.bash/d' "$rc"
      printf '  ✅ Cleaned %s\n' "$rc_base"
    fi
  done

  # Remove directory if empty
  if [[ -d "$comp_dir" ]] && [[ -z "$(ls -A "$comp_dir" 2>/dev/null)" ]]; then
    rmdir "$comp_dir"
    printf '  ✅ Removed empty %s\n' "$comp_dir"
  fi

  printf '\n'
  printf '  Restart your shell to complete removal.\n'
  exit 0
}

# Pre-scan for --install-completions / --uninstall-completions
for _arg in "$@"; do
  case "$_arg" in
    --install-completions)   _install_completions ;;
    --uninstall-completions) _uninstall_completions ;;
  esac
done
unset _arg

# ===== Section 9b: Full setup (--setup) =======================================================
# Combines --install-dependencies, --install-man, and --install-completions into a single
# first-time-setup command. Each installer runs in a subshell so its internal exit calls
# don't short-circuit the overall flow.

_setup_all(){
  say "=== ${APP_NAME} v${VERSION} — Full Setup ==="
  printf '\n'
  say "Running all installers: dependencies, manual page, tab completion."
  printf '\n'

  local -i failures=0

  # ---- 1. Dependencies ----
  say "━━━ Step 1/3: Dependencies ━━━"
  printf '\n'
  if ( _dep_install_dependencies ); then
    : # success
  else
    (( failures++ )) || true
  fi
  printf '\n'

  # ---- 2. Manual page ----
  say "━━━ Step 2/3: Manual Page ━━━"
  printf '\n'
  if ( _install_man ); then
    : # success
  else
    (( failures++ )) || true
  fi
  printf '\n'

  # ---- 3. Tab completion ----
  say "━━━ Step 3/3: Tab Completion ━━━"
  printf '\n'
  if ( _install_completions ); then
    : # success
  else
    (( failures++ )) || true
  fi
  printf '\n'

  # ---- Summary ----
  say "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  if (( failures == 0 )); then
    say "✅ Setup complete — ${APP_NAME} v${VERSION} is ready."
    printf '\n'
    printf '  Verify with:\n'
    printf '    man %s            # manual page\n' "$CLI_NAME"
    printf '    %s --version      # version check\n' "$CLI_NAME"
    printf '    %s <Tab><Tab>     # tab completion (open a new shell first)\n' "$CLI_NAME"
    exit 0
  else
    warn "Setup finished with $failures step(s) reporting errors. Check output above."
    exit 1
  fi
}

# Pre-scan for --setup
for _arg in "$@"; do
  if [[ "$_arg" == "--setup" ]]; then
    _setup_all
    # _setup_all always exits; this line is unreachable
  fi
done
unset _arg

# ===== Section 10: Config generator (--create-config / --force-create-config) =================
# Invoked via --create-config <scope> [profile]. Generates a .muxmrc file at the
# appropriate location with the full template and profile-specific variables
# uncommented. Halts all other operations.
#
# Scope → path:  system=/etc/.muxmrc  user=~/.muxmrc  project=$PWD/.muxmrc
# Profile:       defaults to atv-directplay-hq if omitted.
# --force-create-config: overwrite if file already exists.

# <<< embedded config template >>>
_create_config_emit() {
  local profile="$1"

  # Space-padded sets for O(1) whole-word membership tests:
  #   _active            — variables to emit uncommented (profile-owned + CLI overrides)
  #   _manually_adjusted — CLI-overridden variables whose value differs from what the
  #                        profile set; these get a trailing "# Manually adjusted" comment.
  local _active=" "
  local _manually_adjusted=" "

  # Snapshot all _V-tracked variables before applying the profile so we can
  # detect which ones the profile changes (those become "active" = uncommented).
  local _snap_vars=(
    VIDEO_CODEC CRF_VALUE PRESET_VALUE X265_PARAMS_BASE X264_PARAMS_BASE SVT_AV1_PARAMS_BASE
    AV1_MAXRATE AV1_BUFSIZE
    LEVEL_VALUE CONSERVATIVE_VBV
    LEVEL_VBV_4_1_MAXRATE LEVEL_VBV_4_1_BUFSIZE
    LEVEL_VBV_5_0_MAXRATE LEVEL_VBV_5_0_BUFSIZE
    LEVEL_VBV_5_1_MAXRATE LEVEL_VBV_5_1_BUFSIZE
    LEVEL_VBV_5_2_MAXRATE LEVEL_VBV_5_2_BUFSIZE
    VIDEO_COPY_IF_COMPLIANT MAX_COPY_BITRATE
    FORCE_CHROMA_420 SDR_USE_10BIT_IF_SRC_10BIT SDR_FORCE_10BIT HDR_TARGET_PIXFMT
    TONEMAP_HDR_TO_SDR
    THREADS
    DISABLE_DV ALLOW_DV_FALLBACK DV_CONVERT_TO_P81_IF_FAIL
    AUDIO_LANG_PREF AUDIO_CODEC_PREFERENCE
    AUDIO_MULTI_TRACK AUDIO_KEEP_COMMENTARY
    STEREO_BITRATE MAX_AUDIO_CHANNELS ADD_STEREO_IF_MULTICH
    EAC3_BITRATE_5_1 EAC3_BITRATE_7_1 AUDIO_FORCE_CODEC AUDIO_FORCE_BITRATE AUDIO_LOSSLESS_PASSTHROUGH
    SUB_LANG_PREF SUB_INCLUDE_FORCED SUB_INCLUDE_FULL SUB_INCLUDE_SDH SUB_MAX_TRACKS
    SUB_BURN_FORCED SUB_EXPORT_EXTERNAL SUB_PRESERVE_TEXT_FORMAT
    SUB_MULTI_TRACK
    OUTPUT_EXT KEEP_CHAPTERS STRIP_METADATA PROFILE_COMMENT INCLUDE_AUDIO_TITLES
    CHECKSUM CHECKSUM_ALGO SKIP_IF_IDEAL REPORT_JSON
    FFMPEG_LOGLEVEL
  )
  local _sv

  # Apply the profile to populate variable values
  PROFILE_NAME="$profile"
  "apply_profile_${profile//-/_}"

  # Diff: mark any variable the profile changed from the script's built-in defaults
  # as active (will be emitted uncommented).
  # We compare against _MUXM_PRE_CONFIG (captured before any .muxmrc was sourced)
  # rather than a runtime snapshot, so that config-file values that coincidentally
  # match the profile value don't suppress the uncommented output.
  for _sv in "${_snap_vars[@]}"; do
    if [[ "${!_sv}" != "${_MUXM_PRE_CONFIG[$_sv]}" ]]; then
      [[ "$_active" != *" ${_sv} "* ]] && _active+="${_sv} "
    fi
  done

  # Apply CLI overrides: update variable values and ensure they're active.
  # If the profile already set a variable AND the CLI value differs, mark as "manually adjusted".
  if (( ${#_CC_OVERRIDES[@]} > 0 )); then
    local _ovr_var _ovr_val
    for _ovr_var in "${!_CC_OVERRIDES[@]}"; do
      _ovr_val="${_CC_OVERRIDES[$_ovr_var]}"
      if [[ "$_active" == *" ${_ovr_var} "* && "${!_ovr_var}" != "$_ovr_val" ]]; then
        [[ "$_manually_adjusted" != *" ${_ovr_var} "* ]] && _manually_adjusted+="${_ovr_var} "
      fi
      printf -v "$_ovr_var" '%s' "$_ovr_val"
      [[ "$_active" != *" ${_ovr_var} "* ]] && _active+="${_ovr_var} "
    done
  fi

  # Helper: emit a variable — uncommented if it's in the _active set, commented otherwise.
  # Uses indirect expansion (${!var}) to read the variable's current value.
  # Membership test: _active is space-padded, so *" VARNAME "* matches whole names only.
  # Usage: _V VARNAME [quoted]
  # "quoted" wraps the value in double quotes (for strings with special chars).
  _V() {
    local var="$1" quote="${2:-}"
    local val="${!var}"
    local suffix=""
    [[ "$_manually_adjusted" == *" ${var} "* ]] && suffix=" # Manually adjusted"
    if [[ "$_active" == *" ${var} "* ]]; then
      if [[ "$quote" == "quoted" ]]; then
        printf '%s="%s"%s\n' "$var" "$val" "$suffix"
      else
        printf '%s=%s%s\n' "$var" "$val" "$suffix"
      fi
    else
      if [[ "$quote" == "quoted" ]]; then
        printf '#%s="%s"\n' "$var" "$val"
      else
        printf '#%s=%s\n' "$var" "$val"
      fi
    fi
  }

  cat <<'HEADER'
# ================================================================
#  MuxMaster .muxmrc — configuration file
#  Generated by: muxm --create-config
#  Precedence: Script defaults → /etc/.muxmrc → ~/.muxmrc → ./.muxmrc → --profile → CLI flags
#  Tip: Uncomment a line to override. Keep values shell-safe.
# ================================================================
HEADER
  printf '# Profile: %s\n' "$profile"
  printf '# Generated: %s\n' "$(date '+%Y-%m-%d %H:%M:%S')"
  printf '#\n'
  printf '# Variables set by this profile are uncommented below.\n'
  printf '# All other variables are commented with their defaults — uncomment to customize.\n'
  printf '\n'

  echo "# ========================="
  echo "# Profile (format presets)"
  echo "# ========================="
  printf '\n'
  echo "# Default profile to apply. CLI --profile overrides this value."
  echo "# Valid profiles: $(_valid_profiles_display)"
  echo "# Profiles set many variables at once; CLI flags still override individual values."
  printf 'PROFILE_NAME="%s"\n' "$profile"
  printf '\n'

  printf '\n'
  echo "# ========================="
  echo "# Video (x265/x264) fundamentals"
  echo "# ========================="
  printf '\n'
  echo "# Video encoder: libx265 (default, HEVC) or libx264 (H.264, universal compat)"
  _V VIDEO_CODEC
  printf '\n'
  echo "# CRF (Constant Rate Factor): 0–51 (lower = higher quality, larger files)"
  echo "#   14–18: visually transparent  |  19–22: good balance  |  23–28: smaller files"
  _V CRF_VALUE
  printf '\n'
  echo "# Preset: speed/efficiency trade-off (faster → bigger files, slower → smaller)"
  echo "# Options: ultrafast, superfast, veryfast, faster, fast, medium, slow, slower, veryslow, placebo"
  _V PRESET_VALUE quoted
  printf '\n'
  echo "# Base x265 params: advanced tuning as a single string"
  echo "# Keep values colon-separated. Override entirely if you know what you're doing."
  _V X265_PARAMS_BASE quoted
  printf '\n'
  echo "# Base x264 params: advanced tuning as a single string (used by youtube-upload profile)"
  echo "# Keep values colon-separated (e.g., profile=high:rc-lookahead=60:aq-mode=2:aq-strength=1.0)"
  _V X264_PARAMS_BASE quoted
  printf '\n'
  echo "# Base SVT-AV1 params: advanced AV1 parameter string (used with libsvt-av1 / libaom-av1)"
  echo "# Keep values colon-separated (e.g., film-grain=0:enable-overlays=1:scd=1)"
  _V SVT_AV1_PARAMS_BASE quoted
  printf '\n'
  echo "# AV1 maxrate / bufsize: optional VBV-style rate control for AV1 encodes"
  echo "#   Example: AV1_MAXRATE=20000k AV1_BUFSIZE=40000k"
  _V AV1_MAXRATE
  _V AV1_BUFSIZE
  printf '\n'
  echo "# Level/IDR constraint for compatibility (e.g., 5.1). Leave empty to let encoder decide."
  _V LEVEL_VALUE
  printf '\n'
  echo "# Conservative VBV guardrails (apply when LEVEL_VALUE is set)"
  echo "#   1 = apply cautious vbv-maxrate/bufsize  |  0 = don't apply additional limits"
  _V CONSERVATIVE_VBV
  printf '\n'
  echo "# VBV guardrails: per-level maxrate/bufsize caps (used when CONSERVATIVE_VBV=1)"
  echo "#   These enforce hardware-decode-safe bitrate ceilings per HEVC level."
  echo "#   Only active when LEVEL_VALUE is set AND CONSERVATIVE_VBV=1."
  _V LEVEL_VBV_4_1_MAXRATE
  _V LEVEL_VBV_4_1_BUFSIZE
  _V LEVEL_VBV_5_0_MAXRATE
  _V LEVEL_VBV_5_0_BUFSIZE
  _V LEVEL_VBV_5_1_MAXRATE
  _V LEVEL_VBV_5_1_BUFSIZE
  _V LEVEL_VBV_5_2_MAXRATE
  _V LEVEL_VBV_5_2_BUFSIZE
  printf '\n'
  echo "# Skip encode if source video already matches profile requirements"
  echo "#   1 = copy video stream if compliant (much faster)  |  0 = always re-encode"
  _V VIDEO_COPY_IF_COMPLIANT
  printf '\n'
