      --max-copy-bitrate)           _cc_val="${_cc_override_argv[$((_cc_oi+1))]}"; _CC_OVERRIDES[MAX_COPY_BITRATE]="$_cc_val";          (( _cc_oi += 2 )) ;;
      --video-copy-if-compliant)    _CC_OVERRIDES[VIDEO_COPY_IF_COMPLIANT]=1;                                                           (( ++_cc_oi )) ;;
