      --checksum-algo)              _CC_OVERRIDES[CHECKSUM_ALGO]="${_cc_override_argv[$((_cc_oi+1))]}"; _CC_OVERRIDES[CHECKSUM]=1;      (( _cc_oi += 2 )) ;;
