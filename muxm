}

print_version(){ echo "${APP_NAME} v${VERSION} (${CLI_NAME})"; }

is_valid_preset(){
  case "$1" in
    ultrafast|superfast|veryfast|faster|fast|medium|slow|slower|veryslow|placebo) return 0;;
    *) return 1;;
  esac
}

POSITIONALS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) print_usage; exit 0 ;;
    -V|--version) print_version; exit 0 ;;

    --print-effective-config) PRINT_EFFCONF=1; shift ;;

    -k|--keep-temp) KEEP_TEMP=1; shift ;;
    -K|--keep-temp-always) KEEP_TEMP_ALWAYS=1; shift ;;

    --dry-run) DRY_RUN=1; shift ;;
    --checksum) CHECKSUM=1; shift ;;
    --no-checksum) CHECKSUM=0; shift ;;
    --checksum-algo) CHECKSUM_ALGO="${2:-}"; CHECKSUM=1; shift 2 ;;
    --disk-check) DISK_CHECK=1; shift ;;
    --no-disk-check) DISK_CHECK=0; shift ;;

    --ffmpeg-loglevel)
      FFMPEG_LOGLEVEL="${2:-}"
      is_valid_loglevel "$FFMPEG_LOGLEVEL" || die 11 "Invalid --ffmpeg-loglevel: \"$FFMPEG_LOGLEVEL\". Valid values: quiet, panic, fatal, error, warning, info, verbose, debug, trace"
      shift 2 ;;
    --no-hide-banner) FFMPEG_HIDE_BANNER=0; shift ;;
    --no-overwrite) FFMPEG_OVERWRITE=0; shift ;;
    --ffprobe-loglevel)
      FFPROBE_LOGLEVEL="${2:-}"
      is_valid_loglevel "$FFPROBE_LOGLEVEL" || die 11 "Invalid --ffprobe-loglevel: \"$FFPROBE_LOGLEVEL\". Valid values: quiet, panic, fatal, error, warning, info, verbose, debug, trace"
      shift 2 ;;
    --threads) THREADS="${2:-}"; shift 2 ;;

    --crf) CRF_VALUE="${2:-}"; _CLI_CRF_EXPLICIT=1; shift 2 ;;
    -p|--preset)
      PRESET_VALUE="${2:-}"; _CLI_PRESET_EXPLICIT=1
      is_valid_preset "$PRESET_VALUE" || die 11 "Invalid preset: $PRESET_VALUE"
      shift 2
      ;;
    --x265-params) X265_PARAMS_BASE="${2:-}"; shift 2 ;;
    --x264-params) X264_PARAMS_BASE="${2:-}"; shift 2 ;;
    --av1-params) SVT_AV1_PARAMS_BASE="${2:-}"; shift 2 ;;
    --av1-maxrate) AV1_MAXRATE="${2:-}"; shift 2 ;;
    --av1-bufsize) AV1_BUFSIZE="${2:-}"; shift 2 ;;
    -l|--level) LEVEL_VALUE="${2:-}"; shift 2 ;;
    --conservative-vbv) CONSERVATIVE_VBV=1; shift ;;
    --no-conservative-vbv) CONSERVATIVE_VBV=0; shift ;;
