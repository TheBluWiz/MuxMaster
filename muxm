# ===== Section 1: Strict mode & bash version guard =============================================
set -eEuo pipefail
if shopt -q inherit_errexit 2>/dev/null; then shopt -s inherit_errexit; fi
[[ "${DEBUG:-0}" == "1" ]] && set -x
# Note: noclobber is deliberately omitted. The script intentionally overwrites
# intermediate temp files using > redirection throughout the pipeline stages.
# noclobber would break this pattern.
#
# Locale safety (audited 2026-02-27):
#   - _lower() uses LC_ALL=C for tr '[:upper:]' '[:lower:]'
#   - Hot paths use ${var,,} (Bash builtin, locale-independent for ASCII)
#   - All grep -i patterns are pure ASCII (DOVI, dolby, profile, RPU, etc.)
#   - All =~ [0-9] ranges are POSIX-safe regardless of locale
#   - The [a-zA-Z0-9] range in OCR tool sanitization is a security reject-list
#     (conservative direction under exotic locales)
#   - No sort, no locale-sensitive printf formatting
#   Validated by: LANG=C LC_ALL=C tests/test_muxm.sh --suite all

# ---- Bash version guard ----
# Namerefs (local -n), declare -i arrays, and other features require bash 4.3+.
# macOS ships bash 3.2; users must install a modern bash (e.g., via Homebrew).
if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 3) )); then
  printf "❌ %s requires bash 4.3+. Found: %s\n" "muxm" "$BASH_VERSION" >&2
  printf "   macOS: brew install bash (then ensure /opt/homebrew/bin/bash is in PATH)\n" >&2
  exit 1
fi

