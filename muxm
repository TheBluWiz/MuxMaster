# _create_config_emit_multi — emit a minimal config for a comma-separated multi-profile value.
# Outputs only the header, PROFILE_NAME (uncommented), and any CLI overrides.
_create_config_emit_multi() {
  local profile="$1"

  cat <<'HEADER'
# muxm project config — generated by --create-config
# Multi-profile: each encode runs both profiles sequentially.
# Only explicit overrides are listed; profiles handle all other settings.
# CLI flags always override these values.
HEADER
  printf '# Generated: %s\n' "$(date '+%Y-%m-%d %H:%M:%S')"
  printf '\n'
  printf 'PROFILE_NAME="%s"\n' "$profile"

  if (( ${#_CC_OVERRIDES[@]} > 0 )); then
    printf '\n'
    local _ovr_var _ovr_val
    for _ovr_var in "${!_CC_OVERRIDES[@]}"; do
      _ovr_val="${_CC_OVERRIDES[$_ovr_var]}"
      # Numeric values unquoted; everything else double-quoted
      if [[ "$_ovr_val" =~ ^[0-9]+$ ]]; then
        printf '%s=%s\n' "$_ovr_var" "$_ovr_val"
      else
        printf '%s="%s"\n' "$_ovr_var" "$_ovr_val"
      fi
    done
  fi
}

_create_config() {
  local scope="$1"
  local profile="${2:-atv-directplay-hq}"
  local force="${3:-0}"
  shift 3
  local -a _cc_override_argv=("$@")

  # Parse config override flags into global associative array _CC_OVERRIDES.
  declare -gA _CC_OVERRIDES=()
  local _cc_flag _cc_val _cc_oi=0
  while (( _cc_oi < ${#_cc_override_argv[@]} )); do
    _cc_flag="${_cc_override_argv[$_cc_oi]}"
    case "$_cc_flag" in
      --crf)                        _cc_val="${_cc_override_argv[$((_cc_oi+1))]}"; _CC_OVERRIDES[CRF_VALUE]="$_cc_val";                (( _cc_oi += 2 )) ;;
