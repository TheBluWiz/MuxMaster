# ===== Section 14: Tool validation ============================================================
need ffmpeg
need ffprobe
need jq
need bc
if (( ! DISABLE_DV )); then
  if command -v dovi_tool >/dev/null 2>&1; then
    _HAS_DOVI_TOOL=1
  else
    warn "dovi_tool not found — Dolby Vision handling will be disabled."
    DISABLE_DV=1
  fi
else
  # DV explicitly disabled, dovi_tool not needed
  :
fi

# mp4box (GPAC) is used to mux raw HEVC ES into MP4 with proper dvcC/dvvC box
# signaling. ffmpeg cannot synthesize dvcC from raw ES input — mp4box parses
# RPU NAL units natively and writes correct DV container metadata.
# Binary name varies by platform: MP4Box (macOS homebrew) vs mp4box (Linux).
if (( ! DISABLE_DV )); then
  if ! _detect_mp4box; then
    warn "mp4box (GPAC) not found — DV container signaling (dvcC box) may fail."
    warn "  Install: brew install gpac (macOS) or apt install gpac (Linux)"
  fi
fi

# Check AV1 encoder availability when libsvt-av1 or libaom-av1 is requested.
# Non-fatal probe: warn if not available now; die when actually selected at runtime.
if [[ "$VIDEO_CODEC" == "libsvt-av1" || "$VIDEO_CODEC" == "libaom-av1" ]]; then
  if [[ "$VIDEO_CODEC" == "libsvt-av1" ]] && ! ffmpeg -hide_banner -encoders 2>/dev/null | grep -q 'libsvtav1'; then
    die 10 "libsvtav1 encoder not available in this ffmpeg build. Install ffmpeg with SVT-AV1 support (e.g., brew install ffmpeg)."
  fi
  if [[ "$VIDEO_CODEC" == "libaom-av1" ]] && ! ffmpeg -hide_banner -encoders 2>/dev/null | grep -q 'libaom-av1'; then
    die 10 "libaom-av1 encoder not available in this ffmpeg build. Install ffmpeg with libaom support (e.g., brew tap homebrew-ffmpeg/ffmpeg && brew install homebrew-ffmpeg/ffmpeg/ffmpeg --with-libaom)."
  fi
fi

if (( SUB_ENABLE_OCR )); then
  # Security: reject OCR tool names containing shell metacharacters to prevent
  # injection via --ocr-tool or a malicious .muxmrc. Allows alphanumerics,
  # dots, hyphens, underscores, and forward slashes (for paths).
  if [[ "$SUB_OCR_TOOL" =~ [^a-zA-Z0-9_./-] ]]; then
    warn "SUB_OCR_TOOL '${SUB_OCR_TOOL}' contains disallowed characters — OCR disabled for safety."
    SUB_ENABLE_OCR=0
  elif ! command -v "$SUB_OCR_TOOL" >/dev/null 2>&1; then
    warn "SUB_ENABLE_OCR=1 but '${SUB_OCR_TOOL}' not found in PATH — PGS OCR will be skipped."
    SUB_ENABLE_OCR=0
  fi
fi

# ===== Section 15: Input validation & security checks =========================================
SRC="${POSITIONALS[0]:-}"
OUT="${POSITIONALS[1]:-}"
(( ${#POSITIONALS[@]} > 2 )) && die 11 "Too many arguments. $USAGE_SHORT"
[[ -z "$SRC" ]] && { print_usage; exit 0; }

# Validate output extension (security: prevent command injection)
case "$OUTPUT_EXT" in
  mp4|m4v|mov|mkv|"") ;;  # "" = container passthrough, resolved below once source is known
  *) die 11 "Invalid OUTPUT_EXT: must be mp4, m4v, mov, or mkv (got: $OUTPUT_EXT)" ;;
esac

# Resolve and validate source file
SRC_ABS="$(realpath_fallback "$SRC")"
[[ -f "$SRC_ABS" ]] || die 11 "Source file not found: $SRC_ABS"
[[ -s "$SRC_ABS" ]] || die 11 "Source file is empty: $SRC_ABS"
[[ -r "$SRC_ABS" ]] || die 11 "Source file not readable: $SRC_ABS"

# Validate filename doesn't contain control characters (security)
# This catches newlines, tabs, null bytes, and other chars that could cause
# field-splitting issues in the printf '%s\n' patterns used throughout.
if [[ "$SRC_ABS" =~ [[:cntrl:]] ]]; then
  die 11 "Source filename contains control characters - potential security risk"
fi

# ---- Multi-profile dispatch ------------------------------------------------------------------
# Must run after SRC_ABS is validated so we have a clean absolute source path,
# but before WORKDIR/TMP_OUT creation (those belong to single-profile children only).
# Each child sub-invocation runs independently with its own workdir and pipeline.
if (( _MULTI_PROFILE_MODE )); then
  _run_multi_profiles
  # on_exit EXIT trap fires after this exit; WORKDIR/TMP_OUT are empty → no-op cleanup.
  exit $?
fi
# ---- End multi-profile dispatch --------------------------------------------------------------

# ---- Infer output container from explicit output filename -----------------------------------
# If the user provided an explicit output filename with a recognized extension, infer
# OUTPUT_EXT from it (as if --output-ext was passed). This prevents a mismatch where
# passthrough would derive the container from the source, but the output file has a
# different extension (e.g., muxm --profile archive movie.mkv output.mp4).
# Only applies in single-profile mode; --output-ext flag wins if already set.
if [[ -n "${OUT:-}" ]] && (( ! _OUTPUT_EXT_EXPLICIT )); then
  _out_inferred_ext="$(_lower "${OUT##*.}")"
  case "$_out_inferred_ext" in
    mp4|m4v|mov|mkv)
      OUTPUT_EXT="$_out_inferred_ext"
      _OUTPUT_EXT_EXPLICIT=1
      log "[output] Inferred output container .$_out_inferred_ext from explicit output filename"
      ;;
  esac
  unset _out_inferred_ext
fi
# ---- End output filename inference ----------------------------------------------------------

# ---- Container passthrough resolution -------------------------------------------------------
# If OUTPUT_EXT is empty (set by a profile or left at default), derive the container from the
# source file extension. This implements "passthrough" mode: mkv→mkv, mp4→mp4, etc.
# --output-ext on the CLI always wins (_OUTPUT_EXT_EXPLICIT=1 skips this block).
if [[ -z "$OUTPUT_EXT" ]] && (( ! _OUTPUT_EXT_EXPLICIT )); then
  _src_passthrough_ext="$(_lower "${SRC_ABS##*.}")"
  case "$_src_passthrough_ext" in
    mp4|m4v|mov|mkv)
      OUTPUT_EXT="$_src_passthrough_ext"
      log "[container-passthrough] Source .$_src_passthrough_ext → output .$OUTPUT_EXT"
      ;;
    *)
      OUTPUT_EXT="mkv"
      note "[container-passthrough] Source container .$_src_passthrough_ext is not supported for output — defaulting to .mkv"
      ;;
  esac
  unset _src_passthrough_ext
fi
# ---- End container passthrough resolution ---------------------------------------------------

# ---- atv-directplay-hq / atv-directplay-animation: MKV-output subtitle adjustment ----------
# When either ATV profile produces MKV output (via passthrough or explicit --output-ext mkv),
# switch from burned forced subs (MP4-required) to soft subtitles with native ASS preservation.
# MP4 output path is unchanged: SUB_BURN_FORCED=1, SUB_PRESERVE_TEXT_FORMAT=0 (hq) or =1 (animation).
if [[ "${PROFILE_NAME:-}" == "atv-directplay-hq" || "${PROFILE_NAME:-}" == "atv-directplay-animation" ]] \
    && [[ "$OUTPUT_EXT" == "mkv" ]]; then
  if (( ! _CLI_SUB_BURN_FORCED )); then
    SUB_BURN_FORCED=0
    log "[${PROFILE_NAME}] MKV output: disabling forced-sub burning (soft subs preferred)."
  fi
  SUB_PRESERVE_TEXT_FORMAT=1
  log "[${PROFILE_NAME}] MKV output: enabling native ASS/SSA format preservation."
  SUB_PRESERVE_BITMAP=1
  log "[${PROFILE_NAME}] MKV output: enabling PGS bitmap preservation (stream-copy)."
fi
# ---- End ATV MKV subtitle adjustment -------------------------------------------------------

# Determine output path
if [[ -z "${OUT:-}" ]]; then
  base="${SRC_ABS%.*}"
  OUT="${base}.${OUTPUT_EXT}"
fi

# Resolve output directory and validate
OUT_DIR="$(dirname -- "$OUT")"
OUT_DIR="$(if cd -- "$OUT_DIR" 2>/dev/null; then pwd; else echo "$OUT_DIR"; fi)"
[[ -d "$OUT_DIR" ]] || die 11 "Output directory does not exist: $OUT_DIR"
[[ -w "$OUT_DIR" ]] || die 11 "Output directory not writable: $OUT_DIR"

OUT_BASENAME="$(basename -- "$OUT")"
OUT_ABS="${OUT_DIR}/${OUT_BASENAME}"
OUT="$OUT_ABS"

# Validate output doesn't contain control characters (security)
if [[ "$OUT_ABS" =~ [[:cntrl:]] ]]; then
  die 11 "Output filename contains control characters - potential security risk"
fi

# Prevent overwriting source file (security/safety)
# --replace-source / --force-replace-source: allow source replacement
# Otherwise: auto-version the output filename to avoid collision
declare -i _REPLACING_SOURCE=0
if [[ "$SRC_ABS" -ef "$OUT_ABS" ]]; then
  if (( FORCE_REPLACE_SOURCE )); then
    _REPLACING_SOURCE=1
    note "Source will be replaced (--force-replace-source): $SRC_ABS"
  elif (( REPLACE_SOURCE )); then
    printf '⚠️  Are you sure you want the original file replaced? (y/n) '
    read -r _confirm
    if [[ "$_confirm" == [Yy]* ]]; then
      _REPLACING_SOURCE=1
      note "Source will be replaced (confirmed): $SRC_ABS"
    else
      die 11 "Aborted — source replacement declined by user."
    fi
  else
    # Auto-version: filename(1).ext, filename(2).ext, ...
    _ver_base="${OUT_ABS%.*}"
    _ver_ext="${OUT_ABS##*.}"
    _ver=1
    OUT_ABS="${_ver_base}(${_ver}).${_ver_ext}"
    while [[ -e "$OUT_ABS" ]]; do
      (( _ver++ ))
      OUT_ABS="${_ver_base}(${_ver}).${_ver_ext}"
    done
    OUT_BASENAME="$(basename -- "$OUT_ABS")"
    OUT="$OUT_ABS"
    note "Source collision — output renamed to: $OUT_BASENAME"
  fi
fi

# --no-overwrite: refuse if final output already exists
if (( ! FFMPEG_OVERWRITE )) && [[ -f "$OUT_ABS" ]]; then
  die 11 "Output file already exists (--no-overwrite): $OUT_ABS"
fi

# Security: Use unpredictable temp file name.
# NOTE: mktemp creates the file, then we delete it and re-add the extension.
# There is a theoretical TOCTOU window between rm and ffmpeg's eventual open.
# This is acceptable because: (a) the window is microseconds, (b) exploitation
# requires local write access to OUT_DIR, (c) mktemp --suffix is not portable.
TMP_OUT="$(mktemp "$OUT_DIR/.muxm.output.XXXXXXXX")" || die 11 "Cannot create temp output file"
rm -f "$TMP_OUT"  # Remove the file, we just wanted the name
TMP_OUT="${TMP_OUT}.${OUTPUT_EXT}"

# Determine mux format
MUX_FORMAT="mp4"
case "$OUTPUT_EXT" in
  mp4|m4v) MUX_FORMAT="mp4" ;;
  mov)     MUX_FORMAT="mov" ;;
  mkv)     MUX_FORMAT="matroska" ;;
esac

# ===== Section 16: Build ffmpeg/ffprobe flags =================================================
# Assemble the base flag arrays used for every ffmpeg and ffprobe invocation.
# These arrays are prepended to command-specific flags throughout the pipeline,
# ensuring consistent loglevel, banner suppression, overwrite policy, and probe
# settings (analyzeduration/probesize) across all subprocess calls.
FFMPEG_FLAGS=()
FFPROBE_FLAGS=()

(( FFMPEG_HIDE_BANNER )) && FFMPEG_FLAGS+=(-hide_banner)
FFMPEG_FLAGS+=(-loglevel "$FFMPEG_LOGLEVEL")
(( FFMPEG_OVERWRITE )) && FFMPEG_FLAGS+=(-y)

FFPROBE_FLAGS=(-v "$FFPROBE_LOGLEVEL")

PROBE_OPTS=(-analyzeduration 100M -probesize 100M)
FFMPEG_FLAGS+=("${PROBE_OPTS[@]}")
FFPROBE_FLAGS+=("${PROBE_OPTS[@]}")

# ===== Section 17: Workdir & logging ==========================================================
WORKDIR="$(
  mktemp -d "${OUT_DIR}/.muxm.tmp.XXXXXXXX"
)" || die 11 "Cannot create working directory under: $OUT_DIR"
LOGFILE="$WORKDIR/muxm.$(date +%Y%m%d-%H%M%S).log"

# ---- Begin logging to file ----
# Redirect stdout and stderr through tee to capture all output in the log file
# while still displaying it on the terminal.
#
# FD 3 is preserved as a "raw terminal" descriptor BEFORE the redirect. This
# allows spinner/progress-bar code to write \r-based updates directly to the
# terminal without polluting the log file with ANSI cursor movements.
#
# Lifecycle: FD 3 is opened here and closed in on_exit() (Section 18) during
# cleanup, completing the descriptor lifecycle.
#
# After this section:
#   stdout/stderr → tee → log file + terminal
#   FD 3          → raw terminal (bypasses tee)
if [[ "${DEBUG:-0}" != "1" ]]; then
  : > "$LOGFILE" 2>/dev/null || true
  # Preserve a raw terminal FD for spinner / progress-bar output.
  # After the exec redirect, stdout and stderr both go through tee → log + terminal.
  # FD 3 bypasses tee so \r-based progress UI doesn't pollute the log file.
  exec 3>&2
  TERM_FD=3
  exec > >(tee -a "$LOGFILE") 2>&1
  note "Logging to $(realpath_fallback "$LOGFILE")"
fi

# ===== Section 18: Traps ======================================================================
trap 'on_error $LINENO "$BASH_COMMAND" "$?"' ERR
trap 'FAILED=1; EXIT_CODE=130; FAIL_MSG="Interrupted by user (SIGINT)"; _term_print "\n"; exit 130' INT
trap 'FAILED=1; EXIT_CODE=143; FAIL_MSG="Terminated (SIGTERM)"; exit 143' TERM

_print_completed_steps(){
  [[ ${#COMPLETED_STEPS[@]} -gt 0 ]] || return 0
  echo "---- Completed steps ----"
  for s in "${COMPLETED_STEPS[@]}"; do echo "  • $s"; done
}

# _cleanup_workdir — Remove WORKDIR after a run, with safety guard.
# Args: $1 = 1 to also honour KEEP_TEMP (failure path), 0 for success path.
# Globals read: WORKDIR, DEBUG, KEEP_TEMP, KEEP_TEMP_ALWAYS
_cleanup_workdir() {
  local keep_on_failure="${1:-0}"
  if [[ -n "$WORKDIR" && -d "$WORKDIR" && "${DEBUG:-0}" != "1" && $KEEP_TEMP_ALWAYS -eq 0 ]]; then
    if (( keep_on_failure && KEEP_TEMP )); then
      note "Keeping failure artifacts at: $WORKDIR"
      return
    fi
    if (( ! keep_on_failure )); then
      (( KEEP_TEMP )) && note "--keep-temp preserves workdir on failure only; use -K/--keep-temp-always to keep on success."
    fi
    # Safety: only remove if path matches expected .muxm.tmp. pattern
    if [[ "$WORKDIR" == *"/.muxm.tmp."* ]]; then
      rm -rf "$WORKDIR"
    else
      warn "Refusing to remove unexpected workdir path: $WORKDIR"
    fi
  else
    if (( keep_on_failure )); then
      note "Keeping failure artifacts at: $WORKDIR"
    else
      note "Keeping workdir: $WORKDIR"
    fi
  fi
}

# on_exit — EXIT trap handler. Performs all end-of-run cleanup and reporting.
#
# Success path: atomically moves temp output to final path, writes checksum,
#   prints completed steps, cleans up workdir (unless --keep-temp-always).
# Failure path: prints failure message + completed steps, cleans up temp output,
#   preserves workdir for debugging (if --keep-temp or --keep-temp-always).
# Dry-run path: removes temp placeholder, reports completion.
#
# Globals read: FAILED, DRY_RUN, TMP_OUT, OUT, CHECKSUM, WORKDIR, DEBUG,
#               KEEP_TEMP, KEEP_TEMP_ALWAYS, EXIT_CODE, FAIL_MSG, TERM_FD
on_exit() {
  # Clean up subtitle burn-in temp file (lives inside WORKDIR; explicit removal before workdir cleanup)
  [[ -n "${_BURN_SRT_FILTER:-}" && -f "$_BURN_SRT_FILTER" ]] && rm -f "$_BURN_SRT_FILTER"

  local have_result=0

  if (( DRY_RUN )); then
    have_result=1
  elif [[ -n "${TMP_OUT:-}" && -s "$TMP_OUT" ]]; then
    have_result=1
  elif [[ -n "${OUT:-}" && -s "$OUT" ]]; then
    have_result=1
  fi

  # Close the raw-terminal FD now that spinner output is complete (Section 17)
  [[ -n "${TERM_FD:-}" ]] && exec 3>&- 2>/dev/null || true

  if (( FAILED == 0 && have_result == 1 )); then
    if (( DRY_RUN )); then
      [[ -f "$TMP_OUT" ]] && rm -f "$TMP_OUT"
      note "DRY-RUN complete — no real files were created."
    else
      [[ -f "$TMP_OUT" ]] && mv -f "$TMP_OUT" "$OUT"
      # macOS/APFS sets the UF_HIDDEN (user hidden) flag on dot-prefixed files
      # at the filesystem level. Our temp file (.muxm.output.XXXXXXXX) inherits
      # this flag, and `mv` preserves it even after renaming to a non-dot name.
      # This causes Finder to treat the final output as hidden. Clear it here.
      # No-op on Linux (chflags doesn't exist) and harmless if already clear.
      chflags nohidden "$OUT" 2>/dev/null || true
      (( _REPLACING_SOURCE )) && note "Original source file has been replaced."
      (( CHECKSUM )) && write_checksum "$OUT"
      note "Build SUCCEEDED."
    fi

    _print_completed_steps
    _cleanup_workdir 0
    exit 0
  else
    [[ -z "$FAIL_MSG" ]] && FAIL_MSG="No output produced (likely earlier parse/runtime error)."
    printf "❌ Build FAILED. %s\n" "$FAIL_MSG"

    _print_completed_steps
    echo "See log: $LOGFILE"

    # Clean up temp output file on failure
    [[ -f "$TMP_OUT" ]] && rm -f "$TMP_OUT"

    _cleanup_workdir 1
    exit "${EXIT_CODE:-1}"
  fi
}
trap 'on_exit' EXIT

# ===== Section 19: Disk space preflight =======================================================
# Estimates required disk space before starting an encode and aborts early if
# the destination volume is likely too small. Estimation uses CRF-to-ratio
# lookup tables (_crf_ratio) and preset multipliers (_preset_multiplier) to
# derive an expected output bitrate from the source, with a 25% safety margin.
# Both the output volume and the temp workdir volume are checked (they may differ
# when WORKDIR is on a separate filesystem). Disable with DISK_CHECK=0.

# _crf_ratio CODEC CRF — echo output/source bitrate ratio ×1000
# Used by disk_free_warn to estimate encoded video size from source bitrate.
_crf_ratio() {
  local codec="$1"
  local -i crf="${2:-18}"
  case "$codec" in
    libx265)
      case "$crf" in
        14) echo 720 ;; 15) echo 600 ;; 16) echo 480 ;; 17) echo 400 ;;
        18) echo 330 ;; 19) echo 270 ;; 20) echo 220 ;; 21) echo 180 ;;
        22) echo 160 ;; 23) echo 130 ;; 24) echo 100 ;; 25) echo 85  ;;
        26) echo 72  ;; 27) echo 58  ;; 28) echo 50  ;;
        *) (( crf < 14 )) && echo 850 || echo 35 ;;
      esac ;;
    libx264)
      case "$crf" in
        14) echo 1100 ;; 15) echo 920 ;; 16) echo 780 ;; 17) echo 650 ;;
        18) echo 550  ;; 19) echo 460 ;; 20) echo 390 ;; 21) echo 330 ;;
        22) echo 270  ;; 23) echo 230 ;; 24) echo 200 ;; 25) echo 160 ;;
        26) echo 140  ;; 27) echo 110 ;; 28) echo 100 ;;
        *) (( crf < 14 )) && echo 1300 || echo 70 ;;
      esac ;;
    libsvt-av1|libaom-av1)
      case "$crf" in
        20)echo 250;;22)echo 200;;24)echo 170;;26)echo 140;;28)echo 120;;30)echo 100;;
        32)echo 85;;34)echo 70;;36)echo 58;;38)echo 48;;40)echo 38;;
        *)(( crf<20 ))&&echo 320||echo 28;;
      esac ;;
    *) echo 330 ;;  # fallback: x265 CRF 18 equivalent
  esac
}

# _preset_multiplier PRESET — echo encode-size multiplier ×1000 relative to medium
# Faster presets typically produce larger files at the same CRF.
_preset_multiplier() {
  case "${1:-medium}" in
    ultrafast) echo 2000 ;;
    superfast) echo 1400 ;;
    veryfast)  echo 1000 ;;
    faster)    echo 1050 ;;
    fast)      echo 1050 ;;
    medium)    echo 1000 ;;
    slow)      echo 1000 ;;
    slower)    echo 1000 ;;
    veryslow)  echo 950  ;;
    *)         echo 1000 ;;
  esac
}

# _av1_preset_multiplier PRESET — AV1 uses numeric presets (0=slowest/best, 13=fastest/worst)
# Lower numeric preset = more compression = smaller file at same CRF.
_av1_preset_multiplier() {
  case "${1:-6}" in
    0|1)       echo 900  ;;
    2|3|4)     echo 950  ;;
    5|6|7)     echo 1000 ;;
    8|9|10)    echo 1050 ;;
    11|12|13)  echo 1200 ;;
    *)         echo 1000 ;;
  esac
}

# disk_free_warn — smart disk space preflight
# Estimates output size from source bitrate + CRF/preset tables, then warns
# if estimated required space exceeds available space on the output (or temp) volume.
# Must be called AFTER cache_stream_metadata() so METADATA_CACHE is populated.
# Set DISK_CHECK=0 (--no-disk-check) to skip entirely.
disk_free_warn() {
  (( DISK_CHECK )) || return 0

  # ---- Duration (integer seconds, via three-tier cached lookup) ----
  local -i dur
  dur="$(_get_source_duration_secs)"
  (( dur <= 0 )) && dur=1

  # ---- Video estimate ----
  local -i est_video_bytes=0
  local vbr_raw
  vbr_raw="$(_jq_cache -r \
    '[.streams[] | select(.codec_type=="video")] | .[0].bit_rate // empty' | head -n1 || true)"
  local -i vbr=0
  if [[ "$vbr_raw" =~ ^[0-9]+$ ]]; then
    vbr="$vbr_raw"
  else
    # Fall back to container bit_rate (includes audio — still a useful upper bound)
    local fbr_raw
    fbr_raw="$(_jq_cache -r '.format.bit_rate // empty' | head -n1 || true)"
    [[ "$fbr_raw" =~ ^[0-9]+$ ]] && vbr="$fbr_raw"
  fi

  if (( vbr > 0 )); then
    if (( VIDEO_COPY_IF_COMPLIANT )); then
      # Copy mode: output ≈ source size (no CRF reduction)
      est_video_bytes=$(( (vbr / 8) * dur ))
    else
      local -i ratio preset_mult
      ratio="$(_crf_ratio "$VIDEO_CODEC" "$CRF_VALUE")"
      case "$VIDEO_CODEC" in
        libsvt-av1|libaom-av1) preset_mult="$(_av1_preset_multiplier "$PRESET_VALUE")" ;;
        *)                     preset_mult="$(_preset_multiplier "$PRESET_VALUE")" ;;
      esac
      # All multiplications before any division to avoid integer truncation (SC2017); safe for practical bitrates
      est_video_bytes=$(( vbr * dur * ratio * preset_mult / 8000000 ))
    fi
  fi

  # ---- Audio estimate ----
  # Multi-track mode: estimate all streams; single-track mode: first stream only (approximation).
  local -i est_audio_bytes=0
  local -i n_audio
  n_audio="$(_audio_stream_count)"
  if (( n_audio > 0 )); then
    local -i max_tracks=$n_audio
    (( AUDIO_MULTI_TRACK )) || max_tracks=1
    local -i i
    for (( i=0; i<max_tracks; i++ )); do
      local a_info a_codec a_channels _a_lang a_bitrate _a_title
      a_info="$(_audio_stream_info "$i")"
      IFS=$'\t' read -r a_codec a_channels _a_lang a_bitrate _a_title <<< "$a_info"

      local -i ch=0
      [[ "$a_channels" =~ ^[0-9]+$ ]] && ch="$a_channels"

      # Passthrough if codec is already a compatible format and no forced transcode
      local -i is_passthrough=0
      if [[ -z "${AUDIO_FORCE_CODEC:-}" ]]; then
        case "${a_codec:-}" in
          eac3|ac3|aac|dts|truehd|mlp|flac) is_passthrough=1 ;;
        esac
      fi

      if (( is_passthrough )); then
        if [[ "$a_bitrate" =~ ^[0-9]+$ ]] && (( a_bitrate > 0 )); then
          est_audio_bytes=$(( est_audio_bytes + (a_bitrate / 8) * dur ))
        elif (( ch > 0 )); then
          # Estimate from channel count: ~96 kbps per channel
          est_audio_bytes=$(( est_audio_bytes + ch * 96000 * dur / 8 ))
        fi
      else
        # Transcoding to EAC-3: 64 kbps per channel (conservative)
        local -i ach=$(( ch > 0 ? ch : 6 ))
        est_audio_bytes=$(( est_audio_bytes + ach * 64000 * dur / 8 ))
      fi
    done
  fi

  # ---- Total with 25% safety margin and 5 MB subtitle overhead ----
  local -i sub_overhead=$(( 5 * 1024 * 1024 ))
  local -i est_total=$(( (est_video_bytes + est_audio_bytes + sub_overhead) * 125 / 100 ))

  # Floor: always require at least DISK_FREE_WARN_GB to be free
  local -i floor_bytes=$(( DISK_FREE_WARN_GB * 1024 * 1024 * 1024 ))
  local -i required=$(( est_total > floor_bytes ? est_total : floor_bytes ))

  # Format estimate as X.X GB for display
  local est_gb
  est_gb="$(printf '%.1f' "$(echo "scale=2; $required / 1073741824" | bc 2>/dev/null)" 2>/dev/null)" || \
    est_gb="$(( required / 1024 / 1024 / 1024 ))"

  log "Disk preflight: video_bytes=${est_video_bytes} audio_bytes=${est_audio_bytes}" \
      "est_total=${est_total} required=${required} (~${est_gb}GB)"

  # ---- Check output volume ----
  local avail_kb out_dev
  avail_kb="$(df -Pk "$OUT_DIR" 2>/dev/null | awk 'NR==2{print $4}')"
  out_dev="$(df -Pk "$OUT_DIR" 2>/dev/null | awk 'NR==2{print $1}')"
  if [[ -n "$avail_kb" ]] && (( avail_kb * 1024 < required )); then
    local avail_gb
    avail_gb="$(printf '%.1f' "$(echo "scale=2; $avail_kb / 1048576" | bc 2>/dev/null)" 2>/dev/null)" || \
      avail_gb="$(( avail_kb / 1024 / 1024 ))"
    warn "Estimated output ~${est_gb}GB but only ${avail_gb}GB free on output volume ($OUT_DIR)."
    warn "Use --no-disk-check to suppress this warning."
  fi

  # ---- Check temp volume (only when on a different device than output) ----
  [[ -n "${WORKDIR:-}" && -d "${WORKDIR:-}" ]] || return 0
  local work_dev
  work_dev="$(df -Pk "$WORKDIR" 2>/dev/null | awk 'NR==2{print $1}')"
  [[ -n "${out_dev:-}" && -n "$work_dev" && "$out_dev" != "$work_dev" ]] || return 0
  local work_avail_kb
  work_avail_kb="$(df -Pk "$WORKDIR" 2>/dev/null | awk 'NR==2{print $4}')"
  [[ -n "$work_avail_kb" ]] && (( work_avail_kb * 1024 < required )) || return 0
  local tmp_avail_gb
  tmp_avail_gb="$(printf '%.1f' "$(echo "scale=2; $work_avail_kb / 1048576" | bc 2>/dev/null)" 2>/dev/null)" || \
    tmp_avail_gb="$(( work_avail_kb / 1024 / 1024 ))"
  warn "Estimated output ~${est_gb}GB but only ${tmp_avail_gb}GB free on temp volume ($WORKDIR)."
  warn "Use --no-disk-check to suppress this warning."
}

# ===== Section 20: Metadata caching & ffprobe helpers =========================================
# Cache all stream metadata in one call for performance
cache_stream_metadata() {
  log "→ Caching stream metadata..."
  local _probe_err_file="$WORKDIR/probe_meta.err"
  METADATA_CACHE="$(ffprobe "${FFPROBE_FLAGS[@]}" -show_format -show_streams -of json "$SRC_ABS" 2>"$_probe_err_file")" || {
    local _probe_err
    _probe_err="$(head -5 "$_probe_err_file" 2>/dev/null)"
    die 12 "ffprobe failed to read source file: ${_probe_err:-file may be corrupt or inaccessible}. Try: ffprobe -v error \"$SRC_ABS\""
  }
  # Validate JSON integrity before downstream helpers rely on it
  _jq_cache empty || {
    die 12 "ffprobe returned invalid JSON — file may be corrupt or ffprobe version incompatible. Try: ffprobe -v error -show_format -of json \"$SRC_ABS\""
  }
  if [[ "${DEBUG:-0}" == "1" ]]; then
    log "[cache_stream_metadata] JSON size: ${#METADATA_CACHE} bytes"
    log "[cache_stream_metadata] streams: $(_jq_cache -r '[.streams[].codec_type] | join(", ")' 2>/dev/null)"
  fi
}

# ===== Section 21: Report helpers & skip-if-ideal =============================================

# Add an entry to the JSON report accumulator.
# Escapes backslash, double-quote, and ASCII control characters to produce valid JSON.
report_add() {
  # Escape in order: backslash first (must be first), then the other JSON special chars.
  # Control characters (newline, tab, carriage-return) would break the JSON line structure
  # if left bare, so they are replaced with their two-character escape sequences.
  local key="${1//\\/\\\\}"; key="${key//\"/\\\"}"; key="${key//$'\n'/\\n}"; key="${key//$'\r'/\\r}"; key="${key//$'\t'/\\t}"
  local val="${2//\\/\\\\}"; val="${val//\"/\\\"}"; val="${val//$'\n'/\\n}"; val="${val//$'\r'/\\r}"; val="${val//$'\t'/\\t}"
  REPORT_ENTRIES+=("\"${key}\": \"${val}\"")
}

# Write JSON report alongside output
write_json_report() {
  (( REPORT_JSON )) || return 0
  local report_path="${OUT%."${OUTPUT_EXT}"}.report.json"
  {
    printf '{\n'
    printf '  "tool": "%s",\n' "$APP_NAME v$VERSION"
    printf '  "profile": "%s",\n' "${PROFILE_NAME:-<none>}"
    printf '  "source": "%s",\n' "$SRC_ABS"
    printf '  "output": "%s",\n' "$OUT"
    if (( ${#REPORT_ENTRIES[@]} > 0 )); then
      printf '  "timestamp": "%s",\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
      local i last=$(( ${#REPORT_ENTRIES[@]} - 1 ))
      for (( i=0; i<${#REPORT_ENTRIES[@]}; i++ )); do
        if (( i < last )); then
          printf '  %s,\n' "${REPORT_ENTRIES[$i]}"
        else
          printf '  %s\n' "${REPORT_ENTRIES[$i]}"
        fi
      done
    else
      printf '  "timestamp": "%s"\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    fi
    printf '}\n'
  } > "$report_path" 2>/dev/null || warn "Failed to write JSON report to $report_path"
  note "JSON report written → $report_path"
}

# Check if source already matches profile requirements (skip-if-ideal)
# Delegates video-stream compliance to _video_is_copy_compliant (DRY), then
# adds container and audio checks that only the skip-if-ideal path needs.
check_skip_if_ideal() {
  (( SKIP_IF_IDEAL )) || return 1  # return 1 = don't skip

  local ideal=1 reason=""

  # ---- Video compliance (reuse the copy-compliant check) ----
  # _video_is_copy_compliant checks: codec, pixel format, tone-map, DV profile, bitrate.
  # On rejection it sets _COPY_REJECT_REASON with a specific diagnostic.
  # VIDEO_COPY_IF_COMPLIANT=0 means the profile requires re-encoding; skip-if-ideal cannot apply.
  if (( ! VIDEO_COPY_IF_COMPLIANT )); then
    ideal=0
    reason="VIDEO_COPY_IF_COMPLIANT=0 (profile requires re-encode)"
  elif ! _video_is_copy_compliant; then
    ideal=0
    reason="${_COPY_REJECT_REASON:-video stream not copy-compliant}"
  fi

  # ---- Container check (skip-if-ideal only) ----
  if (( ideal )); then
    local src_ext
    src_ext="$(_lower "${SRC_ABS##*.}")"
    case "$OUTPUT_EXT" in
      mp4|m4v)
        if [[ "$src_ext" != "mp4" && "$src_ext" != "m4v" ]]; then
          ideal=0; reason="container is .$src_ext (need .mp4/.m4v)"
        fi
        ;;
      mkv)
        if [[ "$src_ext" != "mkv" ]]; then
          ideal=0; reason="container is .$src_ext (need .mkv)"
        fi
        ;;
    esac
  fi

  # ---- Audio compliance (skip-if-ideal only) ----
  if (( ideal )) && (( AUDIO_MULTI_TRACK )); then
    # Multi-track: source is ideal only if every audio track survives the filter.
    # If any track would be dropped (commentary, wrong language), we need to remux.
    _check_filter_ideality "audio" "_build_audio_keep_list" "_audio_stream_count" ideal reason
  elif (( ideal )) && (( ! AUDIO_LOSSLESS_PASSTHROUGH )); then
    local n_audio a_codec
    n_audio="$(_audio_stream_count)"
    if (( n_audio > 0 )); then
      a_codec="$(_audio_codec 0)"
      if [[ -n "${AUDIO_FORCE_CODEC:-}" && "$a_codec" != "$AUDIO_FORCE_CODEC" ]]; then
        ideal=0; reason="audio codec is $a_codec (need $AUDIO_FORCE_CODEC)"
      elif ! audio_is_direct_play_copyable "$a_codec"; then
        ideal=0; reason="audio codec $a_codec not Direct Play compatible"
      fi
    fi
  fi

  # ---- Stereo fallback check (skip-if-ideal only) ----
  # If ADD_STEREO_IF_MULTICH is set and the primary audio track is surround,
  # the source is not ideal because a stereo downmix track would need to be added.
  if (( ideal )) && (( ADD_STEREO_IF_MULTICH )); then
    local _sii_ch
    _sii_ch="$(_audio_channels 0)"
    if [[ -n "$_sii_ch" ]] && (( _sii_ch > 2 )); then
      ideal=0; reason="stereo fallback needed (${_sii_ch}ch audio, ADD_STEREO_IF_MULTICH=1)"
    fi
  fi

  # ---- Subtitle compliance (skip-if-ideal only) ----
  if (( ideal )) && (( SUB_MULTI_TRACK )); then
    # Multi-track: source is ideal only if every subtitle track survives the filter.
    # If any track would be dropped (wrong language, excluded type, cap), we need to remux.
    _check_filter_ideality "subtitle" "_build_subtitle_keep_list" "_sub_count" ideal reason
  fi

  # ---- External subtitle check ----
  # If sidecar subtitle files were discovered, they must be muxed in — the source
  # cannot be considered ideal because a straight copy would silently omit them.
  if (( ideal )) && (( ${#EXT_SUB_PATHS[@]} > 0 )); then
    ideal=0; reason="${#EXT_SUB_PATHS[@]} external subtitle(s) need to be muxed in"
  fi

  # ---- CLI quality override checks ----
  # If the user explicitly requested a different CRF or preset on the CLI, the source
  # cannot be considered ideal — skip-if-ideal must not suppress a quality override.
  if (( ideal )) && (( _CLI_CRF_EXPLICIT )); then
    ideal=0; reason="CRF explicitly set on CLI (--crf ${CRF_VALUE})"
  fi
  if (( ideal )) && (( _CLI_PRESET_EXPLICIT )); then
    ideal=0; reason="preset explicitly set on CLI (--preset ${PRESET_VALUE})"
  fi

  if (( ideal )); then
    # ---- Build validated stream keep-lists for the remux ----
    # Multi-track profiles reuse their existing filter functions (which already
    # validated all streams above — ideal=1 means nothing was dropped).
    # Single-track profiles keep all streams that are container-compatible:
    # a safety gate that prevents incompatible codecs from reaching the mux
    # without changing track-selection behavior.
    SII_AUDIO_INDICES=()
    SII_SUB_INDICES=()

    if (( AUDIO_MULTI_TRACK )); then
      local _sii_alist
      _sii_alist="$(_build_audio_keep_list)"
      # shellcheck disable=SC2206  # intentional word-splitting of index list
      SII_AUDIO_INDICES=( $_sii_alist )
    else
      local _sii_a_n _sii_a_i _sii_a_codec
      _sii_a_n="$(_audio_stream_count)"
      for (( _sii_a_i=0; _sii_a_i<_sii_a_n; _sii_a_i++ )); do
        _sii_a_codec="$(_audio_codec "$_sii_a_i")"
        if _sii_audio_is_container_safe "$_sii_a_codec"; then
          SII_AUDIO_INDICES+=("$_sii_a_i")
        else
          log "  [skip-if-ideal] Excluding audio #$_sii_a_i ($_sii_a_codec) — incompatible with $OUTPUT_EXT container"
        fi
      done
    fi

    if (( SUB_MULTI_TRACK )); then
      local _sii_slist
      _sii_slist="$(_build_subtitle_keep_list)"
      # shellcheck disable=SC2206  # intentional word-splitting of index list
      SII_SUB_INDICES=( $_sii_slist )
    else
      local _sii_s_n _sii_s_i _sii_s_codec _sii_s_info
      _sii_s_n="$(_sub_count)"
      for (( _sii_s_i=0; _sii_s_i<_sii_s_n; _sii_s_i++ )); do
        _sii_s_info="$(_sub_stream_info "$_sii_s_i")"
        IFS=$'\t' read -r _sii_s_codec _ _ _ <<< "$_sii_s_info"
        _sii_s_codec="${_sii_s_codec,,}"
        if [[ "$MUX_FORMAT" == "matroska" ]] || _is_text_sub_codec "$_sii_s_codec"; then
          SII_SUB_INDICES+=("$_sii_s_i")
        else
          log "  [skip-if-ideal] Excluding subtitle #$_sii_s_i ($_sii_s_codec) — incompatible with $OUTPUT_EXT container"
        fi
      done
    fi

    note "✅ Source already matches profile '${PROFILE_NAME:-}' requirements — skipping processing."
    report_add "skip_if_ideal" "true"
    report_add "skip_reason" "source already compliant"
    return 0  # 0 = skip
  else
    note "Source does not match ideal: $reason"
    report_add "skip_if_ideal" "false"
    report_add "skip_reason" "$reason"
    return 1  # 1 = don't skip
  fi
}

# Query a field from the first video stream in the metadata cache.
# Falls back to ffprobe if cache is empty (called before cache_stream_metadata).
# Args: $1 — field name (e.g., codec_name, pix_fmt, color_primaries)
#        $2 — (optional) source file path, only used in pre-cache fallback
# Globals: METADATA_CACHE (read), FFPROBE_FLAGS (read)
_probe_field(){
  local field="$1"
  if [[ -n "${METADATA_CACHE:-}" ]]; then
    _jq_cache -r \
      "[.streams[] | select(.codec_type==\"video\")] | .[0].$field // empty" | head -n1 || true
  else
    # Pre-cache fallback (should only occur if called before cache_stream_metadata)
    ffprobe "${FFPROBE_FLAGS[@]}" -show_entries "stream=$field" \
            -of default=nk=1:nw=1 "${2:-}" 2>/dev/null | head -n1 || true
  fi
}

# Check if METADATA_CACHE contains at least one stream of the given type.
# Args: $1 — stream type (e.g., "audio", "video", "subtitle")
# Globals: METADATA_CACHE (read)
_has_stream(){
  _jq_cache -e "[.streams[] | select(.codec_type==\"$1\")] | length > 0" >/dev/null
}

# ===== Section 22: Color space & pixel format decision ========================================
declare -i IS_DV=0
PROFILE_DESC="SDR"
TARGET_PIXFMT="yuv420p"
COLOR_ARGS=()

# decide_color_and_pixfmt — Analyze source color metadata and set output targets.
#
# Reads color_primaries, color_transfer, color_space, and pix_fmt from the
# source video stream and determines the output color profile and pixel format.
#
# Decision tree:
#   TONEMAP_HDR_TO_SDR + HDR source → SDR-TONEMAP (force bt709, yuv420p)
#   arib-std-b67/HLG transfer        → HLG (bt2020, HDR_TARGET_PIXFMT)
#   bt2020/smpte2084                  → HDR10 (bt2020, HDR_TARGET_PIXFMT)
#   everything else                   → SDR (bt709, 10-bit if source is 10-bit)
#
# Sets globals: PROFILE_DESC, TARGET_PIXFMT, COLOR_ARGS[]
# Reads globals: METADATA_CACHE, TONEMAP_HDR_TO_SDR, HDR_TARGET_PIXFMT,
#                FORCE_CHROMA_420, SDR_USE_10BIT_IF_SRC_10BIT, SDR_FORCE_10BIT
decide_color_and_pixfmt() {
  local pix prim trc cspace
  pix="$(_probe_field pix_fmt)"
  prim="$(_probe_field color_primaries)"
  trc="$(_probe_field color_transfer)"
  cspace="$(_probe_field color_space)"

  prim="$(_lower "$prim")"
  trc="$(_lower "$trc")"
  cspace="$(_lower "$cspace")"
  pix="$(_lower "$pix")"

  local is_10bit=0 chroma="420"
  [[ "$pix" =~ p10 ]] && is_10bit=1
  [[ "$pix" =~ 422 ]] && chroma="422"
  [[ "$pix" =~ 444 ]] && chroma="444"

  if (( FORCE_CHROMA_420 )) && [[ "$chroma" != "420" ]]; then
    warn "Source chroma is 4:${chroma}; downsampling to 4:2:0 for Apple TV Direct Play."
    chroma="420"
  fi

  # Color Space Decision Tree:
  # ┌─ TONEMAP_HDR_TO_SDR=1 + HDR source → SDR-TONEMAP (force bt709)
  # ├─ HLG (arib-std-b67)                → HLG profile, bt2020
  # ├─ HDR10 (bt2020/smpte2084)          → HDR10 profile, bt2020
  # └─ SDR (everything else)             → SDR, 10-bit if source is 10-bit
  
  local tgt_pix="yuv420p" profile="SDR"

  if (( TONEMAP_HDR_TO_SDR )) && [[ "$prim" == "bt2020" || "$cspace" == "bt2020nc" || "$trc" == "smpte2084" || "$trc" == "arib-std-b67" || "$trc" == "hlg" ]]; then
    # Source is HDR but we want SDR output (tone-mapping)
    profile="SDR-TONEMAP"
    tgt_pix="yuv420p"
    COLOR_ARGS=(-color_primaries bt709 -color_trc bt709 -colorspace bt709)
    note "HDR source detected — will tone-map to SDR (profile: universal)"
  elif [[ "$trc" == "arib-std-b67" || "$trc" == "hlg" ]]; then
    profile="HLG"
    tgt_pix="$HDR_TARGET_PIXFMT"
    COLOR_ARGS=(-color_primaries bt2020 -color_trc arib-std-b67 -colorspace bt2020nc)
  elif [[ "$prim" == "bt2020" || "$cspace" == "bt2020nc" || "$trc" == "smpte2084" ]]; then
    profile="HDR10"
    tgt_pix="$HDR_TARGET_PIXFMT"
    COLOR_ARGS=(-color_primaries bt2020 -color_trc smpte2084 -colorspace bt2020nc)
  else
    profile="SDR"
    if (( SDR_FORCE_10BIT )); then
      tgt_pix="yuv420p10le"
    elif (( SDR_USE_10BIT_IF_SRC_10BIT )) && (( is_10bit )); then
      tgt_pix="yuv420p10le"
    else
      tgt_pix="yuv420p"
    fi
    [[ -z "$prim" ]] && prim="bt709"
    [[ -z "$trc" ]] && trc="bt709"
    [[ -z "$cspace" ]] && cspace="bt709"
    COLOR_ARGS=(-color_primaries "$prim" -color_trc "$trc" -colorspace "$cspace")
  fi
  PROFILE_DESC="$profile"
  TARGET_PIXFMT="$tgt_pix"
  
  note "Color profile: $PROFILE_DESC, Target pixel format: $TARGET_PIXFMT"
}

# ===== Section 23: x265 params & Level/VBV guardrails ========================================
# Build the final X265_PARAMS string from X265_PARAMS_BASE.
# Adds or strips HDR-specific x265 parameters based on the detected color profile:
#   - Non-HDR10: removes :hdr-opt=1
#   - HDR10: appends hdr10=1, colorprim, transfer, colormatrix, range
# Sets: X265_PARAMS (global)
# Reads: X265_PARAMS_BASE, PROFILE_DESC
build_x265_params() {
  X265_PARAMS="$X265_PARAMS_BASE"

  # Remove hdr-opt if not HDR10
  if [[ "$PROFILE_DESC" != "HDR10" ]]; then
    X265_PARAMS="${X265_PARAMS/:hdr-opt=1/}"
  fi

  # Add HDR10-specific params if HDR10
  if [[ "$PROFILE_DESC" == "HDR10" ]]; then
    # Strip any instances already present in X265_PARAMS_BASE (some profiles
    # bake these in) to avoid duplicate keys that confuse x265.
    X265_PARAMS="$(printf '%s' "$X265_PARAMS" | sed \
      's/:hdr10=[^:]*//g; s/^hdr10=[^:]*://
       s/:hdr10-opt=[^:]*//g; s/^hdr10-opt=[^:]*://
       s/:colorprim=[^:]*//g; s/^colorprim=[^:]*://
       s/:transfer=[^:]*//g; s/^transfer=[^:]*://
       s/:colormatrix=[^:]*//g; s/^colormatrix=[^:]*://
       s/:range=[^:]*//g; s/^range=[^:]*://')"
    X265_PARAMS="${X265_PARAMS}:hdr10=1:hdr10-opt=1:colorprim=bt2020:transfer=smpte2084:colormatrix=bt2020nc:range=limited"
  fi
}

build_av1_params() {
  SVT_AV1_PARAMS="$SVT_AV1_PARAMS_BASE"
}

# Apply level-based VBV constraints
# VBV (Video Buffering Verifier) ensures bitrate stays within device capabilities
apply_level_vbv() {
  # AV1 encoders use different level/VBV mechanisms — skip x265-specific params
  case "$VIDEO_CODEC" in
    libsvt-av1|libaom-av1) return 0 ;;
  esac
  local lvl="$1" maxrate="" bufsize=""
  if (( CONSERVATIVE_VBV )); then
    case "$lvl" in
      4.1) maxrate="$LEVEL_VBV_4_1_MAXRATE"; bufsize="$LEVEL_VBV_4_1_BUFSIZE" ;;
      5.0) maxrate="$LEVEL_VBV_5_0_MAXRATE"; bufsize="$LEVEL_VBV_5_0_BUFSIZE" ;;
      5.1) maxrate="$LEVEL_VBV_5_1_MAXRATE"; bufsize="$LEVEL_VBV_5_1_BUFSIZE" ;;
      5.2) maxrate="$LEVEL_VBV_5_2_MAXRATE"; bufsize="$LEVEL_VBV_5_2_BUFSIZE" ;;
    esac
  fi
  if [[ -n "$maxrate" ]]; then
    X265_PARAMS="${X265_PARAMS}:level-idc=${lvl}:vbv-maxrate=${maxrate}:vbv-bufsize=${bufsize}"
    note "Applying VBV guardrails for level ${lvl} → maxrate=${maxrate}, bufsize=${bufsize}"
  else
    [[ -n "$lvl" ]] && X265_PARAMS="${X265_PARAMS}:level-idc=${lvl}"
  fi
}

# ===== Section 24: Dolby Vision detection =====================================================
# detect_dv — Check if source contains Dolby Vision metadata.
#
# Two-pass detection:
#   1. Stream-level probe: checks codec tags, side data, and FourCC codes
#      (dvhe, dvh1, com.dolby.vision) in the first video stream.
#   2. Frame-level probe: reads the first 5 frames looking for DOVI/dolby
#      metadata in frame side data (catches cases where container metadata
#      is missing but RPU NAL units are present).
#
# Returns: 0 if DV detected, 1 if not detected, 2 if detection was skipped (DISABLE_DV=1).
# Globals: DISABLE_DV (read), FFPROBE_FLAGS (read), SRC_ABS (read)
detect_dv() {
  (( DISABLE_DV )) && return 2
  
  local probe_output
  probe_output="$(ffprobe "${FFPROBE_FLAGS[@]}" -show_streams -select_streams v:0 "$SRC_ABS" 2>&1)" || {
    warn "ffprobe failed during DV detection - assuming no DV present"
    return 1
  }
  
  if printf '%s\n' "$probe_output" | grep -m1 -qiE 'dolby_vision|dv_profile|dovi|dvhe|dvh1|com\.dolby\.vision'; then
    return 0
  fi
  
  # Check first few frames for DV metadata
  probe_output="$(ffprobe "${FFPROBE_FLAGS[@]}" -show_frames -read_intervals %+#5 -select_streams v:0 "$SRC_ABS" 2>&1)" || {
    warn "Frame analysis failed during DV detection - assuming no DV"
    return 1
  }
  
  printf '%s\n' "$probe_output" | grep -m1 -qiE 'DOVI|dolby' && return 0
  return 1
}

# _source_has_dv_metadata — Lightweight check for DV presence using the metadata cache.
#
# Unlike detect_dv, this does NOT honour DISABLE_DV and never probes frames.
# It only checks the already-populated METADATA_CACHE for a DOVI configuration
# record. Intended for informational messages when DV detection was skipped.
#
# Returns: 0 if DOVI configuration record found in cache, 1 otherwise.
# Globals: METADATA_CACHE (read)
_source_has_dv_metadata() {
  [[ -n "${METADATA_CACHE:-}" ]] || return 1
  _jq_cache -e '
    [.streams[] | select(.codec_type=="video")] | .[0].side_data_list[]? |
    select(.side_data_type == "DOVI configuration record")' >/dev/null 2>&1
}

# Populate DV source metadata from ffprobe side data and container records.
# Sets: DV_SRC_PROFILE, DV_SRC_COMPAT_ID, DV_SRC_BL_PRESENT, DV_SRC_EL_PRESENT
# Must be called after detect_dv returns true and METADATA_CACHE is populated.
# Globals: METADATA_CACHE (read), DV_SRC_* (write), FFPROBE_FLAGS (read), SRC_ABS (read)
detect_dv_info() {
  # Try JSON metadata cache first (structured side_data_list)
  if [[ -n "${METADATA_CACHE:-}" ]]; then
    local side_data
    side_data="$(_jq_cache -r '
      [.streams[] | select(.codec_type=="video")] | .[0].side_data_list[]? |
      select(.side_data_type == "DOVI configuration record")')" || true

    if [[ -n "$side_data" ]]; then
      { read -r DV_SRC_PROFILE
        read -r DV_SRC_COMPAT_ID
        read -r DV_SRC_BL_PRESENT
        read -r DV_SRC_EL_PRESENT
      } < <(printf '%s\n' "$side_data" | jq -r '
          .dv_profile // "",
          .dv_bl_signal_compatibility_id // "",
          .bl_present_flag // "",
          .el_present_flag // ""
        ' 2>/dev/null) || true
    fi
  fi

  # Fallback: parse text ffprobe output if JSON didn't produce results
  if [[ -z "${DV_SRC_PROFILE:-}" ]]; then
    local probe_out
    probe_out="$(ffprobe "${FFPROBE_FLAGS[@]}" -show_streams -select_streams v:0 "$SRC_ABS" 2>&1)" || return 1

    DV_SRC_PROFILE="$(printf '%s\n' "$probe_out" | grep -oiE 'profile: [0-9]+' | grep -oE '[0-9]+' | head -1)" || true
    DV_SRC_COMPAT_ID="$(printf '%s\n' "$probe_out" | grep -oiE 'compatibility id: [0-9]+' | grep -oE '[0-9]+' | head -1)" || true
    DV_SRC_BL_PRESENT="$(printf '%s\n' "$probe_out" | grep -oiE 'bl.flag: [0-9]+' | grep -oE '[0-9]+' | head -1)" || true
    DV_SRC_EL_PRESENT="$(printf '%s\n' "$probe_out" | grep -oiE 'el.flag: [0-9]+' | grep -oE '[0-9]+' | head -1)" || true
  fi

  note "DV source info: profile=${DV_SRC_PROFILE:-?}, compat_id=${DV_SRC_COMPAT_ID:-?}, bl=${DV_SRC_BL_PRESENT:-?}, el=${DV_SRC_EL_PRESENT:-?}"
  report_add "dv_src_profile" "${DV_SRC_PROFILE:-unknown}"
  report_add "dv_src_compat_id" "${DV_SRC_COMPAT_ID:-unknown}"
  report_add "dv_src_el_present" "${DV_SRC_EL_PRESENT:-unknown}"
}

# Validate RPU integrity via dovi_tool info.
# Args: $1 — path to RPU file
# Returns: 0 if valid, 1 if invalid or dovi_tool unavailable.
# Side effect: logs RPU frame count and detected profile.
# Globals: WORKDIR (read)
_validate_dv_rpu() {
  local rpu_path="$1" rpu_info=""
  [[ -s "$rpu_path" ]] || { warn "RPU file is empty: $rpu_path"; return 1; }

  if ! (( _HAS_DOVI_TOOL )); then
    warn "dovi_tool not available — cannot validate RPU integrity."
    return 0  # Non-fatal; proceed optimistically
  fi

  rpu_info="$(dovi_tool info -i "$rpu_path" --summary 2>"$WORKDIR/rpu_validate.err")" || {
    warn "dovi_tool info failed on RPU — RPU may be corrupt. See: $WORKDIR/rpu_validate.err"
    return 1
  }

  # Extract profile from RPU info
  local rpu_profile
  rpu_profile="$(printf '%s\n' "$rpu_info" | grep -oiE 'profile [0-9]+' | grep -oE '[0-9]+' | head -1)" || true
  if [[ -n "$rpu_profile" ]]; then
    note "RPU validated: DV Profile $rpu_profile"
    report_add "dv_rpu_profile" "$rpu_profile"
  fi

  return 0
}

# Count video frames in an HEVC elementary stream or container.
# Args: $1 — file path
# Returns: frame count on stdout (0 if counting fails)
# Globals: FFPROBE_FLAGS (read)
_count_video_frames() {
  local file="$1" count
  count="$(ffprobe "${FFPROBE_FLAGS[@]}" -count_packets -select_streams v:0 \
           -show_entries stream=nb_read_packets -of csv=p=0 "$file" 2>/dev/null)" || true
  [[ "$count" =~ ^[0-9]+$ ]] && echo "$count" || echo "0"
}

# Verify DOVI configuration record (dvcC/dvvC box) is present in muxed output.
# For MP4/MOV containers, the dvcC box is required for players to activate DV rendering.
# If missing, attempts a fallback remux. If still missing, warns clearly.
# Args: none (operates on TMP_OUT)
# Globals: OUTPUT_HAS_DV, DRY_RUN, MUX_FORMAT, TMP_OUT, FFPROBE_FLAGS, WORKDIR,
#          V_MIXED, VIDEO_COPY_FROM_SOURCE
verify_dv_container_record() {
  (( OUTPUT_HAS_DV )) || return 0
  (( DRY_RUN )) && return 0

  # MKV uses different DV signaling (codec private data, not MP4 boxes)
  [[ "$MUX_FORMAT" == "matroska" ]] && {
    note "MKV container — DV signaling uses codec private data (no dvcC box needed)."
    report_add "dv_container_record" "n/a (matroska)"
    return 0
  }

  local out_probe
  if ! out_probe="$(ffprobe "${FFPROBE_FLAGS[@]}" -show_streams -show_entries \
               stream_side_data -select_streams v:0 "$TMP_OUT" 2>&1)"; then
    warn "ffprobe could not probe output container — cannot verify DV configuration record."
    warn "  Output may still be valid. Re-check with: ffprobe -show_streams \"$TMP_OUT\""
    report_add "dv_container_record" "unknown (ffprobe failed to probe output)"
    return 0
  fi

  if printf '%s\n' "$out_probe" | grep -qiE "$DV_CONTAINER_PATTERN"; then
    note "✅ DOVI configuration record confirmed in output container."
    report_add "dv_container_record" "present"
    return 0
  fi

  warn "DOVI configuration record (dvcC/dvvC box) NOT found in output container."
  warn "  RPU NAL units are present in the bitstream but the container lacks DV signaling."
  warn "  Impact: Some players (Apple TV, iPhone, iPad) may not activate DV rendering"
  warn "  and will fall back to HDR10/HLG base layer instead."

  # Attempt fallback: mux the raw HEVC ES into a DV-signaled MP4 with mp4box,
  # then merge that video with audio/subs from the original mux.
  if (( ! VIDEO_COPY_FROM_SOURCE )); then
    note "→ Attempting DV container signaling fallback…"
    local dv_video_mp4="$WORKDIR/dv_video_only.mp4"
    local fallback_ok=0

    # mp4box fallback: natively parses RPU NALs and writes dvcC box.
    if (( ! fallback_ok )) && [[ -n "${MP4BOX_CMD:-}" && -n "${V_MIXED:-}" && -s "$V_MIXED" ]]; then
      local dvp_hint=""
      if [[ -n "${DV_SRC_PROFILE:-}" && -n "${DV_SRC_COMPAT_ID:-}" ]]; then
        dvp_hint=":dvp=${DV_SRC_PROFILE}.${DV_SRC_COMPAT_ID}"
      fi

      "$MP4BOX_CMD" -add "${V_MIXED}${dvp_hint}" \
           -new "$dv_video_mp4" >"$WORKDIR/dovi_mux_mp4box.log" 2>&1 &
      local mp4box_fb_pid=$!
      spinner "$mp4box_fb_pid" "DV fallback: muxing with mp4box"
      if wait "$mp4box_fb_pid" 2>/dev/null && [[ -s "$dv_video_mp4" ]]; then
        local mux_probe
        mux_probe="$(ffprobe "${FFPROBE_FLAGS[@]}" -show_streams -show_entries \
                     stream_side_data -select_streams v:0 "$dv_video_mp4" 2>&1)" || true

        if printf '%s\n' "$mux_probe" | grep -qiE "$DV_CONTAINER_PATTERN"; then
          fallback_ok=1
        else
          warn "mp4box fallback muxed OK but dvcC not detected. See: $WORKDIR/dovi_mux_mp4box.log"
        fi
      else
        warn "mp4box fallback mux failed. See: $WORKDIR/dovi_mux_mp4box.log"
      fi
    fi

    # If mp4box produced a dvcC-bearing video MP4, remux it with audio/subs from original output.
    if (( fallback_ok )); then
      local dv_final="$WORKDIR/dv_final_remux.${OUTPUT_EXT}"
      local -a remux_cmd=("${FFMPEG_FLAGS[@]}")
      remux_cmd+=(-i "$dv_video_mp4")  # Video with dvcC from mp4box
      remux_cmd+=(-i "$TMP_OUT")       # Audio/subs from original mux
      remux_cmd+=(-map 0:v:0)          # Video from mp4box mux
      remux_cmd+=(-map 1:a? -map 1:s?) # Audio + subs from original mux
      remux_cmd+=(-c copy)
      remux_cmd+=(-strict unofficial -tag:v dvh1)
      remux_cmd+=(-movflags +faststart)
      remux_cmd+=(-f "$MUX_FORMAT" "$dv_final")

      ffmpeg "${remux_cmd[@]}" 2>"$WORKDIR/dv_remux.err" &
      local remux_fb_pid=$!
      spinner "$remux_fb_pid" "DV fallback: remuxing with dvcC"
      if wait "$remux_fb_pid" 2>/dev/null && [[ -s "$dv_final" ]]; then
        local final_probe
        final_probe="$(ffprobe "${FFPROBE_FLAGS[@]}" -show_streams -show_entries \
                       stream_side_data -select_streams v:0 "$dv_final" 2>&1)" || true

        if printf '%s\n' "$final_probe" | grep -qiE "$DV_CONTAINER_PATTERN"; then
          mv -f "$dv_final" "$TMP_OUT"
          note "✅ DV container fallback succeeded (mp4box) — DOVI configuration record added."
          report_add "dv_container_record" "added via mp4box fallback"
          return 0
        fi
      fi
      warn "DV container fallback remux failed. See: $WORKDIR/dv_remux.err"
    fi
  fi

  report_add "dv_container_record" "missing — players may fall back to HDR10/HLG"
  return 0  # Non-fatal; output is still usable, just without DV activation on some players
}

# Check if source has valid HDR10 static metadata (MaxCLL, mastering display).
# Warns if metadata is absent, which causes dim/washed-out playback when DV is stripped.
# Globals: METADATA_CACHE (read), FFPROBE_FLAGS (read), SRC_ABS (read)
_check_hdr10_static_metadata() {
  local has_mastering=0 has_cll=0 side_data

  # Check JSON metadata cache for mastering display and content light level
  if [[ -n "${METADATA_CACHE:-}" ]]; then
    side_data="$(_jq_cache -r '
      [.streams[] | select(.codec_type=="video")] | .[0].side_data_list[]?.side_data_type // empty')" || true

    printf '%s\n' "$side_data" | grep -qiE 'mastering.display' && has_mastering=1
    printf '%s\n' "$side_data" | grep -qiE 'content.light.level' && has_cll=1
  fi

  # Fallback: text probe
  if (( ! has_mastering && ! has_cll )); then
    local probe_out
    probe_out="$(ffprobe "${FFPROBE_FLAGS[@]}" -show_frames -read_intervals %+#1 \
                 -select_streams v:0 "$SRC_ABS" 2>&1)" || true
    printf '%s\n' "$probe_out" | grep -qiE 'mastering.display|mastering_display' && has_mastering=1
    printf '%s\n' "$probe_out" | grep -qiE 'max_content|max_average|content.light' && has_cll=1
  fi

  if (( ! has_mastering && ! has_cll )); then
    warn "Source has DV but NO HDR10 static metadata (mastering display, MaxCLL/MaxFALL)."
    warn "  Stripping DV will produce an HDR10 stream with missing brightness metadata."
    warn "  Impact: Playback may appear dim or washed-out on HDR10-only displays."
    warn "  Consider using archive profile to preserve DV, or adding HDR10 metadata manually."
    report_add "hdr10_static_metadata" "missing (mastering=$has_mastering, cll=$has_cll)"
  elif (( ! has_mastering )); then
    warn "Source has MaxCLL/MaxFALL but no mastering display metadata. HDR10 output may have suboptimal tone-mapping on some displays."
    report_add "hdr10_static_metadata" "partial (mastering=0, cll=1)"
  elif (( ! has_cll )); then
    note "Source has mastering display metadata but no MaxCLL/MaxFALL. Most players handle this gracefully."
    report_add "hdr10_static_metadata" "partial (mastering=1, cll=0)"
  else
    report_add "hdr10_static_metadata" "present"
  fi
}

# ===== Section 25: Temp paths =================================================================
V_SRC_ES="$WORKDIR/video_src.es"
RPU_P7="$WORKDIR/rpu_p7.bin"
RPU_FINAL="$WORKDIR/rpu_final.bin"

# Initial values — run_video_pipeline() reassigns V_BASE and V_MIXED at runtime
# based on whether DV injection is needed:
#   DV path:     .hevc raw ES (dovi_tool requires raw elementary streams)
#   Non-DV path: .mkv container (preserves timestamps for matroska final mux)
#
# NOTE: On non-DV paths and DV fallback paths, V_MIXED is reassigned to alias
# V_BASE (or V_INJECTED) rather than copying the file.  This avoids multi-GB
# file copies for no functional gain.  Downstream consumers (mux_final, DV
# container verification, pre-wrap) only read V_MIXED — they never write to it.
# Consequence for --keep-temp-always: the workdir will contain only video_base
# (not a separate video_mixed) on non-DV runs.
V_BASE="$WORKDIR/video_base.hevc"
V_MIXED="$WORKDIR/video_mixed.hevc"

# Intermediate file for P7/P5→P8 conversion: inject raw RPU here first, then
# dovi_tool convert produces the final V_MIXED from this file.
V_INJECTED="$WORKDIR/video_injected.hevc"

# Pre-wrapped DV MP4: V_MIXED wrapped into MP4 with proper dvcC/dvvC box via dovi_tool.
# When available, mux_final uses this instead of the raw V_MIXED ES so that ffmpeg
# copies the dvcC box through to the final output container.
V_DV_MP4=""

# When copy-compliant, we map video directly from source in final mux to preserve
# container-level metadata (DOVI configuration record, displaymatrix, etc.) that
# would be stripped by extracting to raw HEVC elementary stream.
declare -i VIDEO_COPY_FROM_SOURCE=0

# Diagnostic: set by _video_is_copy_compliant on rejection, read by check_skip_if_ideal.
_COPY_REJECT_REASON=""

# Runtime AV1 params string (built by build_av1_params from SVT_AV1_PARAMS_BASE)
SVT_AV1_PARAMS=""

A_PRIMARY=""
AAC_STEREO=""
declare -i HAS_AUDIO=0

# Multi-track audio: when AUDIO_MULTI_TRACK=1, audio streams are mapped
# directly from source in mux_final (no intermediate extraction).
# AUDIO_COPY_FROM_SOURCE is the runtime flag set by run_audio_pipeline_multi.
declare -i AUDIO_COPY_FROM_SOURCE=0
declare -a AUDIO_MT_INDICES=()    # 0-based audio-relative indices to keep
declare -a AUDIO_MT_CODECS=()     # codec per kept track (e.g., truehd, ac3)
declare -a AUDIO_MT_CHANNELS=()   # channel count per kept track
declare -a AUDIO_MT_LANGS=()      # language tag per kept track
declare -a AUDIO_MT_TITLES=()     # title tag per kept track (empty if unset)

# Multi-track subtitles: when SUB_MULTI_TRACK=1, subtitle streams are mapped
# directly from source in mux_final (no extraction, OCR, or conversion).
# SUB_COPY_FROM_SOURCE is the runtime flag set by run_subtitle_pipeline_multi.
declare -i SUB_COPY_FROM_SOURCE=0
declare -a SUB_MT_INDICES=()      # 0-based embedded subtitle index per kept track (-1 for external)
declare -a SUB_MT_SOURCES=()      # unified source per kept track ("embedded:N" or "ext:/path")
declare -a SUB_MT_CODECS=()       # codec per kept track (e.g., subrip, hdmv_pgs_subtitle)
declare -a SUB_MT_LANGS=()        # language tag per kept track
declare -a SUB_MT_TITLES=()       # title tag per kept track (empty if unset)
declare -a SUB_MT_TYPES=()        # "forced" | "full" | "sdh" per kept track

# External subtitle discovery (populated by discover_external_subtitles)
declare -a EXT_SUB_PATHS=()       # absolute paths to discovered external subtitle files
declare -a EXT_SUB_LANGS=()       # language codes parsed from filename segments
declare -a EXT_SUB_TYPES=()       # "forced", "sdh", or "full" parsed from filename segments
declare -a EXT_SUB_CODECS=()      # codec name derived from file extension

# Unified subtitle source list — embedded + external (populated by merge_subtitle_sources).
# Each entry is "embedded:N" (N = 0-based stream index in source) or "ext:/abs/path".
# All subtitle filtering and selection functions iterate this list instead of raw stream counts.
declare -a ALL_SUB_SOURCES=()     # source descriptor per entry
declare -a ALL_SUB_LANGS=()       # language per entry
declare -a ALL_SUB_TYPES=()       # "forced" | "full" | "sdh" per entry
declare -a ALL_SUB_CODECS=()      # codec name per entry
declare -a ALL_SUB_TITLES=()      # title tag per entry (empty for external files)

# ===== Section 26: Video pipeline =============================================================

# Check if source video can be stream-copied (no re-encode) for the target profile.
# Tests: codec match (hevc/h264), pixel format (10-bit for HDR), tone-map requirement,
#        DV profile compatibility (atv-directplay-hq requires P8 for copy),
#        bitrate ceiling (MAX_COPY_BITRATE).
# Returns: 0 if copy-compliant, 1 if re-encode required.
# Sets: _COPY_REJECT_REASON (diagnostic string when returning 1)
# Globals: VIDEO_CODEC, TARGET_PIXFMT, TONEMAP_HDR_TO_SDR, PROFILE_DESC,
#          IS_DV, DISABLE_DV, PROFILE_NAME, DV_SRC_PROFILE,
#          MAX_COPY_BITRATE (read)
_video_is_copy_compliant() {
  _COPY_REJECT_REASON=""
  local src_codec src_pix
  src_codec="$(_lower "$(_probe_field codec_name)")"
  src_pix="$(_lower "$(_probe_field pix_fmt)")"

  # CLI overrides: explicit --crf or --preset forces a re-encode regardless of compliance
  if (( _CLI_CRF_EXPLICIT )); then
    _COPY_REJECT_REASON="CRF explicitly set on CLI (--crf ${CRF_VALUE})"
    return 1
  fi
  if (( _CLI_PRESET_EXPLICIT )); then
    _COPY_REJECT_REASON="preset explicitly set on CLI (--preset ${PRESET_VALUE})"
    return 1
  fi

  # Check codec match
  if [[ "$VIDEO_CODEC" == "libx265" && "$src_codec" != "hevc" ]]; then
    _COPY_REJECT_REASON="video codec is $src_codec (need hevc)"
    return 1
  fi
  if [[ "$VIDEO_CODEC" == "libx264" && "$src_codec" != "h264" ]]; then
    _COPY_REJECT_REASON="video codec is $src_codec (need h264)"
    return 1
  fi
  if [[ "$VIDEO_CODEC" == "libsvt-av1" || "$VIDEO_CODEC" == "libaom-av1" ]]; then
    if [[ "$src_codec" != "av1" ]]; then
      _COPY_REJECT_REASON="video codec is $src_codec (need av1)"
      return 1
    fi
  fi

  # Check pixel format (10-bit for HDR)
  if [[ "$TARGET_PIXFMT" == "yuv420p10le" && "$src_pix" != *"p10"* ]]; then
    _COPY_REJECT_REASON="pixel format is $src_pix (need 10-bit for $TARGET_PIXFMT)"
    return 1
  fi

  # If tone-mapping is requested, can't copy — check actual source color metadata
  # (PROFILE_DESC is not yet set when check_skip_if_ideal runs, so probe directly)
  if (( TONEMAP_HDR_TO_SDR )); then
    local _sii_prim _sii_trc
    _sii_prim="$(_lower "$(_probe_field color_primaries)")"
    _sii_trc="$(_lower "$(_probe_field color_transfer)")"
    if [[ "$_sii_prim" == "bt2020" || "$_sii_trc" == "smpte2084" || "$_sii_trc" == "arib-std-b67" ]]; then
      _COPY_REJECT_REASON="tone-mapping required (HDR source cannot be copied)"
      return 1
    fi
  fi

  # Check DV profile compatibility when DV handling is active.
  # For atv-directplay-hq, only Profile 8 is acceptable for copy; other
  # profiles (e.g., P7) require RPU conversion and cannot be stream-copied.
  if (( IS_DV && ! DISABLE_DV )) && [[ "${PROFILE_NAME:-}" == "atv-directplay-hq" ]] \
     && [[ "${DV_SRC_PROFILE:-}" != "8" ]]; then
    _COPY_REJECT_REASON="DV profile ${DV_SRC_PROFILE:-?} requires conversion (need P8 for copy)"
    return 1
  fi

  # Bitrate ceiling: reject copy if source exceeds MAX_COPY_BITRATE.
  # Prevents copying high-bitrate remuxes that would stutter on constrained
  # hardware (e.g., Apple TV 4K with 80+ Mbps Blu-ray remuxes).
  if [[ -n "${MAX_COPY_BITRATE:-}" ]]; then
    local src_br_bps max_br_kbps max_br_bps
    src_br_bps="$(_probe_field bit_rate)"

    # Fallback: compute average bitrate from file size / duration
    if [[ -z "$src_br_bps" || "$src_br_bps" == "N/A" || "$src_br_bps" == "0" ]]; then
      local _dur _fsz
      _dur="$(_get_source_duration_secs)"
      _dur="${_dur%.*}"  # truncate to integer
      if [[ -n "$_dur" ]] && (( _dur > 0 )); then
        # Cross-platform stat: macOS uses -f%z, Linux uses -c%s
        _fsz="$(stat -f%z "$SRC_ABS" 2>/dev/null || stat -c%s "$SRC_ABS" 2>/dev/null || echo 0)"
        if (( _fsz > 0 )); then
          src_br_bps=$(( _fsz * 8 / _dur ))
        fi
      fi
    fi

    if [[ -n "$src_br_bps" && "$src_br_bps" =~ ^[0-9]+$ ]] && (( src_br_bps > 0 )); then
      # MAX_COPY_BITRATE is specified as e.g. "80000k" — strip the trailing 'k'
      # suffix to get a plain integer, then convert kbps → bps for comparison.
      max_br_kbps="${MAX_COPY_BITRATE%k}"
      # Guard: validate numeric before arithmetic to prevent bash error on bad config
      if [[ ! "$max_br_kbps" =~ ^[0-9]+$ ]]; then
        warn "MAX_COPY_BITRATE='${MAX_COPY_BITRATE}' is not a valid rate (expected e.g. '80000k') — skipping bitrate ceiling check."
      else
        max_br_bps=$(( max_br_kbps * 1000 ))
        if (( src_br_bps > max_br_bps )); then
          _COPY_REJECT_REASON="bitrate ~$(( src_br_bps / 1000 ))kbps exceeds MAX_COPY_BITRATE=${MAX_COPY_BITRATE}"
          return 1
        fi
      fi
    fi
  fi

  return 0
}

# run_video_pipeline — Encode or copy the video stream, with DV handling.
#
# High-level flow:
#   1. Check copy-if-compliant → skip encode if source matches target profile
#   2. Determine intermediate format (raw ES for DV injection, MKV otherwise)
#   3. Demux raw HEVC ES from source (for DV RPU extraction, if applicable)
#   4. Encode video with filters (tone-map, forced sub burn-in)
#   5. Extract DV RPU from source (piped method → file fallback)
#   6. Convert RPU profile if needed (P7/P5 → P8.1)
#   7. Inject RPU into encoded video via dovi_tool
#   8. Pre-wrap DV video into MP4 with dvcC box (mp4box → ffmpeg fallback)
#
# Sets: V_BASE, V_MIXED, V_DV_MP4, VIDEO_COPY_FROM_SOURCE, OUTPUT_HAS_DV
# Dies on: encode failure, DV failure with fallback disabled
run_video_pipeline() {
  # Check copy-if-compliant first
  if (( VIDEO_COPY_IF_COMPLIANT )); then
    if ! _video_is_copy_compliant; then
      note "Source video not compliant for copy — will re-encode."
      report_add "video_action" "re-encode (not compliant)"
    else
      note "→ Source video is compliant for target profile — will copy directly from source during mux."
      report_add "video_action" "copy (compliant)"

      # Flag for mux_final to map video directly from source file.
      # This preserves container-level metadata (DOVI configuration record,
      # displaymatrix, etc.) that would be lost by extracting to raw HEVC ES.
      VIDEO_COPY_FROM_SOURCE=1

      if (( IS_DV && ! DISABLE_DV )); then
        # Validate DV integrity in source before committing to copy path.
        # A corrupt RPU would pass through silently without this check.
        if (( _HAS_DOVI_TOOL )); then
          note "→ Validating DV RPU integrity in source (copy path)…"
          # Quick RPU extraction to validate (piped, no temp file needed)
          local rpu_check="$WORKDIR/rpu_copy_check.bin"
          (
            set +eE  # Prevent ERR trap in subshell
            ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:v:0 -c copy \
                 -bsf:v hevc_mp4toannexb -f hevc - 2>/dev/null \
               | dovi_tool extract-rpu - -o "$rpu_check" >/dev/null 2>&1
          ) &
          local rpu_val_pid=$!
          spinner "$rpu_val_pid" "Validating DV RPU integrity"
          if wait "$rpu_val_pid" 2>/dev/null && [[ -s "$rpu_check" ]]; then
            if _validate_dv_rpu "$rpu_check"; then
              note "DV RPU integrity verified for copy path."
              report_add "dv_copy_rpu_check" "passed"
            else
              warn "DV RPU validation failed on source — RPU may be corrupt."
              warn "  Copy will proceed (source data is unchanged), but DV playback may be affected."
              report_add "dv_copy_rpu_check" "failed (proceeding with copy)"
            fi
            rm -f "$rpu_check" 2>/dev/null || true
          else
            note "Could not extract RPU for validation (non-fatal). Proceeding with copy."
            report_add "dv_copy_rpu_check" "extraction failed (proceeding)"
          fi
        fi

        OUTPUT_HAS_DV=1
        note "DV metadata will be preserved via direct source copy."
        mark_done "DV preserved (direct source copy)"
      fi

      mark_done "Video stream copy (compliant — direct source)"
      return 0
    fi
  fi

  # Determine intermediate format: raw ES is needed only when DV RPU injection
  # is possible (HEVC codec + DV source + DV enabled). Otherwise, use a container
  # (matroska) to preserve timestamps that the Matroska final muxer requires.
  # Raw ES files lack packet pts/dts, which the mp4 muxer can reconstruct from
  # HEVC VUI/SPS parameters but the matroska muxer cannot — causing mux failures
  # for any MKV output path.
  local -i v_needs_raw_es=0
  if [[ "$VIDEO_CODEC" == "libx265" ]] && (( IS_DV && ! DISABLE_DV )); then
    v_needs_raw_es=1
  fi

  if (( v_needs_raw_es )); then
    V_BASE="$WORKDIR/video_base.hevc"
    V_MIXED="$WORKDIR/video_mixed.hevc"
  else
    V_BASE="$WORKDIR/video_base.mkv"
    V_MIXED="$WORKDIR/video_mixed.mkv"
  fi

  # Demux raw HEVC ES for DV RPU extraction (only when DV injection is possible).
  # Skipped for non-HEVC sources and when DV is disabled — the ES is only consumed
  # by dovi_tool extract-rpu later in the pipeline.
  if (( v_needs_raw_es )); then
    log "→ Preparing raw video elementary stream…"

    if (( DRY_RUN )); then
      : > "$V_SRC_ES" 2>/dev/null || true
      mark_done "Demux raw ES → video_src.es (dry-run)"
    else
      # Extract HEVC elementary stream for DV RPU extraction.
      # -bsf:v hevc_mp4toannexb ensures proper conversion from hvc1/hev1
      # length-prefixed NAL units to Annex B start codes, which preserves
      # DV RPU NAL units that dovi_tool requires for extraction.
      ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:v:0 -c copy -bsf:v hevc_mp4toannexb -f hevc "$V_SRC_ES" 2>"$WORKDIR/demux.err" &
      local demux_pid=$!
      spinner "$demux_pid" "Demuxing video elementary stream"
      if ! wait "$demux_pid" 2>/dev/null; then
        local codec
        codec="$(_probe_field codec_name)"
        warn "Could not demux raw HEVC ES (source codec: ${codec:-unknown})."
        warn "  DV RPU extraction requires an HEVC source stream. Use --no-dv to skip DV processing."
        warn "  See: $WORKDIR/demux.err for details."
        : > "$V_SRC_ES" 2>/dev/null || true
      fi
      mark_done "Demux raw ES → video_src.es"
    fi
  else
    note "Skipping ES demux (DV injection not applicable for this encode)."
  fi

  # Build encode command based on VIDEO_CODEC and PROFILE_DESC
  local -a vf_filters=()
  local -a encode_args=()
  local thread_args=()
  [[ -n "${THREADS:-}" ]] && thread_args=(-threads "$THREADS")

  # Tone-mapping filter (universal profile: HDR→SDR)
  if [[ "$PROFILE_DESC" == "SDR-TONEMAP" ]]; then
    vf_filters+=("$TONEMAP_FILTER")
    note "→ Tone-mapping HDR→SDR via: ${TONEMAP_FILTER}"
    report_add "tonemap" "enabled (hable)"
  fi

  # Forced subtitle burn-in filter (added here if SUB_BURN_FORCED and we have a forced SRT)
  # Note: SRT_FORCED_BURN_PATH is set by subtitle plan if burn is requested.
  if (( SUB_BURN_FORCED )) && [[ -n "${SRT_FORCED_BURN_PATH:-}" && -s "${SRT_FORCED_BURN_PATH:-}" ]]; then
    # Stage the forced SRT at a clean temp path for the ffmpeg subtitles filter.
    # The subtitles filter requires the explicit 'filename=' key — positional
    # argument form (subtitles=/path) fails on many ffmpeg builds with
    # "No option name near '/path'".  Single quotes are ffmpeg filter-level
    # escaping, protecting the path from the filter graph parser (colons,
    # commas, etc. are syntactic in that context).
    # Security: Use WORKDIR (mktemp -d, unpredictable name, 0700 on Linux) so
    # the path is not guessable by a local attacker — eliminates the TOCTOU
    # race that a predictable /tmp/muxm-burn-$$.srt name would expose.
    _BURN_SRT_FILTER="$WORKDIR/burn.srt"
    cp -f "$SRT_FORCED_BURN_PATH" "$_BURN_SRT_FILTER"
    vf_filters+=("subtitles=filename='${_BURN_SRT_FILTER}'")
    note "→ Burning forced subtitles into video stream"
    report_add "sub_burn_forced" "true"
  elif (( SUB_BURN_FORCED )); then
    warn "SUB_BURN_FORCED requested but no forced subtitle was prepared — encoding without burn-in."
    report_add "sub_burn_forced" "skipped (no forced subtitle available)"
  fi

  # Build -vf string
  local vf_str=""
  if [[ ${#vf_filters[@]} -gt 0 ]]; then
    # shellcheck disable=SC2030  # Subshell-scoped IFS change is intentional
    vf_str="$(IFS=','; echo "${vf_filters[*]}")"
  fi

  if [[ "$VIDEO_CODEC" == "libsvt-av1" || "$VIDEO_CODEC" == "libaom-av1" ]]; then
    # AV1 encode (SVT-AV1 or libaom-av1)
    # ffmpeg's encoder name is "libsvtav1" (no dash); "libsvt-av1" is muxm's user-facing alias.
    local _ffmpeg_vcodec="$VIDEO_CODEC"
    [[ "$_ffmpeg_vcodec" == "libsvt-av1" ]] && _ffmpeg_vcodec="libsvtav1"
    local av1_preset="${PRESET_VALUE:-6}"
    log "→ Encoding video (AV1, ${TARGET_PIXFMT}, preset ${av1_preset}, CRF ${CRF_VALUE}) → $V_BASE"
    encode_args=(
      -c:v "$_ffmpeg_vcodec"
      -crf "$CRF_VALUE"
      -pix_fmt "$TARGET_PIXFMT"
      "${COLOR_ARGS[@]}"
    )
    if [[ "$VIDEO_CODEC" == "libsvt-av1" ]]; then
      encode_args+=( -preset "$av1_preset" )
    else
      encode_args+=( -cpu-used "$av1_preset" )
    fi
    # SVT_AV1_PARAMS_BASE is shared between libsvt-av1 and libaom-av1; flag name differs per encoder
    if [[ -n "${SVT_AV1_PARAMS:-}" ]]; then
      if [[ "$VIDEO_CODEC" == "libsvt-av1" ]]; then
        encode_args+=( -svtav1-params "$SVT_AV1_PARAMS" )
      else
        encode_args+=( -aom-params "$SVT_AV1_PARAMS" )
      fi
    fi
    [[ -n "$AV1_MAXRATE" ]] && encode_args+=( -maxrate "$AV1_MAXRATE" )
    [[ -n "$AV1_BUFSIZE" ]] && encode_args+=( -bufsize "$AV1_BUFSIZE" )
    report_add "video_codec" "av1"
  elif [[ "$VIDEO_CODEC" == "libx264" ]]; then
    # H.264 encode (universal / youtube-upload profile)
    log "→ Encoding video (H.264/SDR, preset ${PRESET_VALUE}, CRF ${CRF_VALUE}) → $V_BASE"
    encode_args=(
      -c:v libx264
      -preset "$PRESET_VALUE"
      -crf "$CRF_VALUE"
      -pix_fmt yuv420p
      "${COLOR_ARGS[@]}"
    )
    [[ -n "$X264_PARAMS_BASE" ]] && encode_args+=( -x264-params "$X264_PARAMS_BASE" )
    report_add "video_codec" "h264"
  else
    # HEVC encode (default, hdr10-hq, atv-directplay-hq)
    log "→ Encoding video (${PROFILE_DESC}, ${TARGET_PIXFMT}, preset ${PRESET_VALUE}, CRF ${CRF_VALUE}) → $V_BASE"
    encode_args=(
      -c:v libx265
      -preset "$PRESET_VALUE"
      -crf "$CRF_VALUE"
      -pix_fmt "$TARGET_PIXFMT"
      "${COLOR_ARGS[@]}"
      -x265-params "$X265_PARAMS"
    )
    report_add "video_codec" "hevc"
  fi

  if (( DRY_RUN )); then
    : > "$V_BASE" 2>/dev/null || true
    mark_done "Encode base video (dry-run)"
  else
    local -a ff_cmd=("${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:v:0)
    [[ -n "$vf_str" ]] && ff_cmd+=(-vf "$vf_str")
    if (( v_needs_raw_es )); then
      ff_cmd+=("${encode_args[@]}" "${thread_args[@]}" -an -sn -dn -f hevc "$V_BASE")
    else
      ff_cmd+=("${encode_args[@]}" "${thread_args[@]}" -an -sn -dn -f matroska "$V_BASE")
    fi

    local total_secs
    total_secs="$(_get_source_duration_secs)"
    log "ffmpeg encode command: ffmpeg ${ff_cmd[*]}"
    if ! _ffmpeg_run_with_ui ff_cmd "Encoding video" "$WORKDIR/encode.err" "$total_secs"; then
      _check_disk_full "$WORKDIR/encode.err"
      die 40 "Base video encode failed. See: $WORKDIR/encode.err"
    fi

    # Validate encoded output
    _validate_media_file "$V_BASE" "Base video encode"

    mark_done "Encode base video"
  fi

  log "→ Finalizing video stream (DV inject if available) → $V_MIXED"

  if (( DRY_RUN )); then
    : > "$V_MIXED" 2>/dev/null || true
    mark_done "Use base video (dry-run)"
    return 0
  fi

  # Default: no DV, or DV disabled, or non-HEVC codec (no DV possible) → use base
  if (( IS_DV == 0 || DISABLE_DV == 1 )) || [[ "$VIDEO_CODEC" == "libx264" || "$VIDEO_CODEC" == "libsvt-av1" || "$VIDEO_CODEC" == "libaom-av1" ]]; then
    V_MIXED="$V_BASE"
    mark_done "Use base video (non-DV)"
    return 0
  fi

  # Try extracting RPU from the source.
  #
  # Primary method: pipe ffmpeg → dovi_tool via stdin.
  # This matches the dovi_tool README's recommended workflow and avoids
  # subtle issues with file-based extraction (EOS/EOB NAL handling,
  # buffer flushing differences) that cause failures on some sources
  # — particularly iPhone P8.4 HLG MOV files.
  #
  # Fallback: extract from the previously demuxed ES file on disk.

  local rpu_extracted=0

  # Primary: piped extraction (ffmpeg → dovi_tool stdin)
  if (( ! DRY_RUN )); then
    log "→ Extracting DV RPU via piped stdin…"
    (
      set +eE  # Prevent ERR trap from firing inside this subshell
      ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:v:0 -c copy \
           -bsf:v hevc_mp4toannexb -f hevc - 2>"$WORKDIR/rpu_pipe_demux.err" \
         | dovi_tool extract-rpu - -o "$RPU_P7" >"$WORKDIR/rpu_pipe.log" 2>&1
    ) &
    local rpu_pipe_pid=$!
    spinner "$rpu_pipe_pid" "Extracting DV RPU (piped)"
    if wait "$rpu_pipe_pid" 2>/dev/null; then
      if [[ -s "$RPU_P7" ]]; then
        rpu_extracted=1
        log "DV RPU extracted successfully (piped method)."
      else
        warn "Piped RPU extraction produced empty file — trying file-based fallback."
      fi
    else
      warn "Piped RPU extraction failed — trying file-based fallback."
      log "See: $WORKDIR/rpu_pipe_demux.err and $WORKDIR/rpu_pipe.log"
    fi
  fi

  # Fallback: file-based extraction from demuxed ES
  if (( ! rpu_extracted && ! DRY_RUN )); then
    if [[ -s "$V_SRC_ES" ]]; then
      log "→ Extracting DV RPU from demuxed ES file (fallback)…"
      dovi_tool extract-rpu -i "$V_SRC_ES" -o "$RPU_P7" >"$WORKDIR/rpu_file.log" 2>&1 &
      local rpu_file_pid=$!
      spinner "$rpu_file_pid" "Extracting DV RPU (file fallback)"
      if wait "$rpu_file_pid" 2>/dev/null; then
        if [[ -s "$RPU_P7" ]]; then
          rpu_extracted=1
          log "DV RPU extracted successfully (file-based fallback)."
        fi
      else
        warn "File-based RPU extraction also failed."
        log "See: $WORKDIR/rpu_file.log"
      fi
    else
      warn "No demuxed ES file available for fallback RPU extraction."
    fi
  fi

  if (( ! rpu_extracted && ! DRY_RUN )); then
    warn "All DV RPU extraction methods failed; using base video."
    if (( ALLOW_DV_FALLBACK )); then
      V_MIXED="$V_BASE"
      mark_done "Use base video (DV extract failed)"
      return 0
    fi
    die 40 "Dolby Vision RPU extraction failed and fallback is disabled"
  fi

  # ---- DV RPU profile analysis (conversion deferred until after injection) ----
  # Decision tree for RPU handling based on source DV profile:
  #
  # ┌─ Source is P8 (any compat_id) → RPU passes through unchanged
  # │   P8.1 (compat_id=1, PQ), P8.2 (compat_id=2, SDR), P8.4 (compat_id=4, HLG)
  # │   are all single-layer and compatible with re-encoded base layer.
  # ├─ Source is P7 (dual-layer) → inject raw RPU, then convert HEVC to P8
  # │   ├─ EL present → warn about enhancement layer data loss (irreversible)
  # │   ├─ HLG source (compat_id=4) → warn about PQ compat_id mismatch
  # │   └─ After injection: dovi_tool convert -d → P8.1 (best-effort)
  # ├─ Source is P5 (IPT) → inject raw RPU, then convert HEVC to P8.1
  # └─ Unknown profile → attempt passthrough with warning

  # Start with extracted RPU; used directly for injection in all cases
  cp -f "$RPU_P7" "$RPU_FINAL" 2>/dev/null \
    || warn "Failed to copy extracted RPU to staging path — DV injection will likely fail."

  # Flag: set to 1 when the injected HEVC needs P7/P5→P8 conversion via
  # dovi_tool convert after RPU injection.
  local -i dv_needs_convert=0

  if [[ "${DV_SRC_PROFILE:-}" == "8" ]]; then
    # Source is already Profile 8 — RPU is single-layer compatible, no conversion needed.
    # Preserves original compat_id (1=PQ, 2=SDR, 4=HLG) and all RPU metadata.
    note "Source DV is Profile 8 (compat_id=${DV_SRC_COMPAT_ID:-?}) — RPU passes through unchanged."
    report_add "dv_rpu_action" "passthrough (already P8, compat_id=${DV_SRC_COMPAT_ID:-?})"

  elif [[ "${DV_SRC_PROFILE:-}" == "7" || "${DV_SRC_PROFILE:-}" == "5" ]]; then
    # Source is dual-layer (P7) or IPT (P5) — needs conversion to single-layer P8.
    # Conversion happens AFTER RPU injection: dovi_tool convert now operates on
    # HEVC elementary streams (not standalone RPU files).
    if (( DV_CONVERT_TO_P81_IF_FAIL )); then
      note "Source DV is Profile ${DV_SRC_PROFILE} — will convert to Profile 8 after injection…"
      dv_needs_convert=1

      # Warn about enhancement layer data loss for P7
      if [[ "${DV_SRC_EL_PRESENT:-}" == "1" ]]; then
        warn "DV Profile ${DV_SRC_PROFILE} has an enhancement layer (EL) that carries additional"
        warn "  highlight/shadow detail. The EL will be discarded during P7→P8 conversion."
        warn "  This is a lossy operation — DV image quality may be slightly reduced."
        report_add "dv_el_loss" "true (P${DV_SRC_PROFILE} EL discarded)"
      fi

      # Warn about HLG compat_id mismatch: dovi_tool convert produces P8.1 (PQ, compat_id=1)
      # but HLG sources use compat_id=4. Players may misinterpret the fallback layer.
      if [[ "${DV_SRC_COMPAT_ID:-}" == "4" ]]; then
        warn "Source is HLG Dolby Vision (compat_id=4) but dovi_tool convert targets P8.1 (PQ, compat_id=1)."
        warn "  The DV RPU will be converted, but the compatibility ID will change from HLG to PQ."
        warn "  Impact: Non-DV players may interpret the base layer as PQ instead of HLG."
        report_add "dv_compat_id_mismatch" "source=4(HLG) → output=1(PQ)"
      fi
    else
      warn "Source DV is Profile ${DV_SRC_PROFILE} (dual-layer) but conversion is disabled"
      warn "  (DV_CONVERT_TO_P81_IF_FAIL=0). Using raw RPU — DV playback will likely fail."
      report_add "dv_rpu_action" "passthrough (P${DV_SRC_PROFILE}, conversion disabled)"
    fi

  else
    # Unknown or unrecognized DV profile — attempt passthrough
    if [[ -n "${DV_SRC_PROFILE:-}" ]]; then
      warn "Unrecognized DV profile: ${DV_SRC_PROFILE}. Attempting RPU passthrough."
      warn "  DV playback behavior is unpredictable for this profile."
    else
      warn "Could not determine source DV profile. Attempting RPU passthrough."
    fi
    report_add "dv_rpu_action" "passthrough (unknown profile ${DV_SRC_PROFILE:-?})"
  fi

  # Validate RPU integrity before injection
  if ! _validate_dv_rpu "$RPU_FINAL"; then
    warn "RPU validation failed — RPU may be corrupt or incompatible."
    if (( ALLOW_DV_FALLBACK )); then
      warn "Falling back to base video without DV."
      V_MIXED="$V_BASE"
      mark_done "Use base video (RPU validation failed)"
      return 0
    fi
    die 40 "DV RPU validation failed and fallback is disabled"
  fi

  # Inject RPU into encoded video.
  # When P7/P5→P8 conversion is needed, inject into an intermediate file first;
  # dovi_tool convert will then produce the final V_MIXED from that file.
  local inject_target="$V_MIXED"
  if (( dv_needs_convert )); then
    inject_target="$V_INJECTED"
  fi

  dovi_tool inject-rpu -i "$V_BASE" --rpu-in "$RPU_FINAL" -o "$inject_target" >"$WORKDIR/rpu_inject.log" 2>&1 &
  local inject_pid=$!
  spinner "$inject_pid" "Injecting DV RPU into video"
  if ! wait "$inject_pid" 2>/dev/null; then
    warn "DV RPU injection failed. See: $WORKDIR/rpu_inject.log"
    if (( ALLOW_DV_FALLBACK )); then
      warn "Falling back to base video without DV."
      V_MIXED="$V_BASE"
      mark_done "Use base video (DV inject failed)"
      return 0
    fi
    die 41 "Dolby Vision RPU injection failed and fallback is disabled"
  fi

  # Validate DV-injected output exists and is non-empty
  if [[ ! -s "$inject_target" ]]; then
    warn "DV injection produced empty file."
    if (( ALLOW_DV_FALLBACK )); then
      warn "Falling back to base video without DV."
      V_MIXED="$V_BASE"
      mark_done "Use base video (DV inject empty)"
      return 0
    fi
    die 41 "DV injection produced empty output and fallback is disabled"
  fi

  # ---- Post-injection DV profile conversion (P7/P5 → P8) ----
  # dovi_tool convert now operates on HEVC elementary streams (not standalone
  # RPU files). The -d flag discards the enhancement layer, producing a valid
  # single-layer Profile 8 output from the dual-layer P7/P5 input.
  if (( dv_needs_convert )); then
    dovi_tool convert -i "$V_INJECTED" -o "$V_MIXED" -d >"$WORKDIR/rpu_convert.log" 2>&1 &
    local conv_pid=$!
    spinner "$conv_pid" "Converting DV RPU (P${DV_SRC_PROFILE} → P8.1)"
    if wait "$conv_pid" 2>/dev/null && [[ -s "$V_MIXED" ]]; then
      note "DV profile converted (P${DV_SRC_PROFILE} → P8.1)"
      report_add "dv_rpu_action" "converted P${DV_SRC_PROFILE} → P8.1"
    else
      warn "dovi_tool convert failed (P${DV_SRC_PROFILE} → P8.1). See: $WORKDIR/rpu_convert.log"
      warn "  Using unconverted P${DV_SRC_PROFILE} HEVC — this is technically invalid for"
      warn "  single-layer output. DV playback may be unpredictable or fail."
      warn "  Reason: Profile ${DV_SRC_PROFILE} RPU references a dual-layer structure that"
      warn "  doesn't exist in the re-encoded single-layer output."
      report_add "dv_rpu_action" "convert failed — using raw P${DV_SRC_PROFILE} RPU (may be invalid)"
      # Fall back to the unconverted injected file
      V_MIXED="$V_INJECTED"
    fi
  fi

  # Verify RPU frame count matches encoded video frame count.
  # Mismatched counts cause DV flicker, color shifts, or player crashes
  # on frames where the RPU and video desync.
  local v_frames rpu_frames
  v_frames="$(_count_video_frames "$V_MIXED")"
  # RPU frame count from dovi_tool info (if available)
  if (( _HAS_DOVI_TOOL )); then
    rpu_frames="$(dovi_tool info -i "$RPU_FINAL" --summary 2>/dev/null \
                  | grep -oiE '[0-9]+ RPU' | grep -oE '[0-9]+' | head -1)" || true
    # Fallback: try parsing "Parsed X RPU" format
    if [[ -z "$rpu_frames" ]]; then
      rpu_frames="$(dovi_tool info -i "$RPU_FINAL" --summary 2>/dev/null \
                    | grep -oiE 'parsed [0-9]+' | grep -oE '[0-9]+' | head -1)" || true
    fi
  fi

  if [[ -n "$rpu_frames" && "$rpu_frames" =~ ^[0-9]+$ && -n "$v_frames" && "$v_frames" =~ ^[0-9]+$ ]]; then
    if (( v_frames > 0 && rpu_frames > 0 )); then
      local frame_diff=$(( v_frames - rpu_frames ))
      # Allow ±2 frame tolerance (encoder may add/drop frames at boundaries)
      if (( frame_diff > 2 || frame_diff < -2 )); then
        warn "RPU frame count mismatch: video has $v_frames frames but RPU has $rpu_frames frames."
        warn "  Difference: ${frame_diff} frames. DV may flicker or desync on mismatched frames."
        warn "  This can occur when the re-encode changes frame count (e.g., framerate conversion)."
        report_add "dv_frame_count_match" "MISMATCH (video=$v_frames, rpu=$rpu_frames, diff=$frame_diff)"
      else
        note "RPU frame count verified: video=$v_frames, rpu=$rpu_frames (within tolerance)."
        report_add "dv_frame_count_match" "ok (video=$v_frames, rpu=$rpu_frames)"
      fi
    fi
  else
    note "Could not verify RPU/video frame count alignment (counting unavailable)."
    report_add "dv_frame_count_match" "unverified"
  fi

  # Pre-wrap the DV-injected HEVC ES into an MP4 with proper dvcC/dvvC signaling.
  #
  # Why: When mux_final feeds a raw HEVC ES to ffmpeg, ffmpeg cannot synthesize
  # a dvcC configuration record from RPU NAL units in a raw elementary stream.
  # The raw HEVC demuxer does not parse RPU NALs (type 62) to construct DOVI
  # side data — so even with -strict unofficial -tag:v dvh1, no dvcC box is
  # written. The dvcC box must already exist in an input container for ffmpeg
  # to copy it through to the output.
  #
  # Strategy: Use mp4box (GPAC) to mux the raw ES into a video-only MP4.
  # mp4box natively parses RPU NAL units and writes the correct dvcC/dvvC box.
  # The dvp= hint tells mp4box the exact DV profile and cross-compatibility ID.
  # ffmpeg-based approaches are kept as fallbacks for environments without mp4box.
  if [[ "$MUX_FORMAT" != "matroska" ]]; then
    local dv_prewrap="$WORKDIR/video_dv_prewrap.mp4"
    note "→ Pre-wrapping DV video into MP4 with dvcC signaling…"

    local prewrap_ok=0

    # Method 1: mp4box (GPAC) — natively understands DV RPU NALs.
    # Constructs the dvcC box from RPU data; dvp=PROFILE.COMPAT_ID ensures
    # correct signaling even if auto-detection is ambiguous.
    if (( ! prewrap_ok )) && [[ -n "${MP4BOX_CMD:-}" ]]; then
      local dvp_hint=""
      if [[ -n "${DV_SRC_PROFILE:-}" && -n "${DV_SRC_COMPAT_ID:-}" ]]; then
        dvp_hint=":dvp=${DV_SRC_PROFILE}.${DV_SRC_COMPAT_ID}"
      fi

      "$MP4BOX_CMD" -add "${V_MIXED}${dvp_hint}" \
           -new "$dv_prewrap" >"$WORKDIR/dv_prewrap_mp4box.log" 2>&1 &
      local pw_mp4box_pid=$!
      spinner "$pw_mp4box_pid" "Pre-wrapping DV video (mp4box)"
      if wait "$pw_mp4box_pid" 2>/dev/null && [[ -s "$dv_prewrap" ]]; then
        local pw_probe
        pw_probe="$(ffprobe "${FFPROBE_FLAGS[@]}" -show_streams -show_entries \
                     stream_side_data -select_streams v:0 "$dv_prewrap" 2>&1)" || true

        if printf '%s\n' "$pw_probe" | grep -qiE "$DV_CONTAINER_PATTERN"; then
          V_DV_MP4="$dv_prewrap"
          prewrap_ok=1
          note "✅ DV pre-wrap succeeded (mp4box) — dvcC box present."
          report_add "dv_prewrap" "success (mp4box)"
        else
          warn "mp4box muxed OK but dvcC not detected by ffprobe. See: $WORKDIR/dv_prewrap_mp4box.log"
        fi
      else
        warn "mp4box pre-wrap failed. See: $WORKDIR/dv_prewrap_mp4box.log"
      fi
    fi

    # Method 2 (ffmpeg fallback): Direct mux with -strict unofficial.
    # Some ffmpeg builds may gain raw-ES DV detection in the future.
    # NOTE: Do NOT use -bsf:v hevc_mp4toannexb here — V_MIXED is already
    # Annex B format. That BSF converts FROM MP4 length-prefixed NALUs and
    # would corrupt the stream.
    if (( ! prewrap_ok )); then
      rm -f "$dv_prewrap" 2>/dev/null || true
      ffmpeg "${FFMPEG_FLAGS[@]}" \
           -i "$V_MIXED" \
           -c:v copy \
           -strict unofficial \
           -tag:v dvh1 \
           -movflags +faststart \
           -f mp4 "$dv_prewrap" >"$WORKDIR/dv_prewrap.log" 2>&1 &
      local pw_ff_pid=$!
      spinner "$pw_ff_pid" "Pre-wrapping DV video (ffmpeg fallback)"
      if wait "$pw_ff_pid" 2>/dev/null && [[ -s "$dv_prewrap" ]]; then
        local pw_probe2
        pw_probe2="$(ffprobe "${FFPROBE_FLAGS[@]}" -show_streams -show_entries \
                      stream_side_data -select_streams v:0 "$dv_prewrap" 2>&1)" || true

        if printf '%s\n' "$pw_probe2" | grep -qiE "$DV_CONTAINER_PATTERN"; then
          V_DV_MP4="$dv_prewrap"
          prewrap_ok=1
          note "✅ DV pre-wrap succeeded (ffmpeg direct) — dvcC box present."
          report_add "dv_prewrap" "success (ffmpeg direct)"
        fi
      fi
    fi

    if (( ! prewrap_ok )); then
      warn "DV pre-wrap could not produce dvcC box."
      [[ -n "${MP4BOX_CMD:-}" ]] || warn "  mp4box (GPAC) is not installed — this is the recommended tool for DV container signaling."
      warn "  Final mux will use raw HEVC ES — dvcC box may be missing in output."
      warn "  Impact: Players may not activate DV rendering and fall back to HDR10/HLG."
      report_add "dv_prewrap" "failed"
    fi
  fi

  OUTPUT_HAS_DV=1
  mark_done "DV inject (profile-aware)"
}

# ===== Section 27: Audio selection & pipeline =================================================
# Note on variable scope: Several variables in run_audio_pipeline are declared
# 'local' for documentation purposes (they're "owned" by that function) but are
# read by downstream functions and mux_final. In Bash, local variables are visible
# to all functions called from the declaring function. Key variables consumed
# downstream: A_PRIMARY_LANG, A_PRIMARY_TITLE, A_PRIMARY_CHANNELS, A_STEREO_LANG,
# A_PRIMARY, AAC_STEREO, HAS_AUDIO.
# Count audio streams in source file
# Returns: Integer count (0 if none)
# Globals: METADATA_CACHE
_audio_stream_count(){
  _jq_cache '[.streams[] | select(.codec_type=="audio")] | length' || echo 0
}

# Get audio field from cached metadata (single jq call)
# Args: $1 — audio stream index (0-based, relative to audio streams)
#        $2 — field name (jq path, e.g., codec_name, channels)
# Globals: METADATA_CACHE (read)
_audio_field(){
  local idx="$1" field="$2"
  _jq_cache -r \
    "[.streams[] | select(.codec_type==\"audio\")] | .[$idx].$field // empty" | head -n1 || true
}

# Get audio tag from cached metadata (single jq call)
# Args: $1 — audio stream index, $2 — tag name (e.g., language, title)
# Globals: METADATA_CACHE (read)
_audio_tag(){
  local idx="$1" tag="$2"
  _jq_cache -r \
    "[.streams[] | select(.codec_type==\"audio\")] | .[$idx].tags.$tag // empty" | head -n1 || true
}

# Return language tag for audio stream (lowercased), defaulting to TAG_LANGUAGE_DEFAULT.
# Args: $1 — audio stream index
_audio_lang(){
  local lang
  lang="$(_audio_tag "$1" language)"; lang="${lang,,}"
  [[ -z "$lang" ]] && lang="$TAG_LANGUAGE_DEFAULT"
  echo "$lang"
}

# Return channel count for audio stream (0 if unavailable).
# Args: $1 — audio stream index
_audio_channels(){
  local ch
  ch="$(_audio_field "$1" channels)"
  [[ -z "$ch" ]] && ch=0
  echo "$ch"
}

# Return bit_rate for audio stream in bps (0 if unavailable).
# Args: $1 — audio stream index
_audio_bitrate(){
  local br
  br="$(_audio_field "$1" bit_rate)"
  [[ -z "$br" ]] && br=0
  echo "$br"
}

# Return codec_name for audio stream (lowercased, "unknown" if unavailable).
# Args: $1 — audio stream index
_audio_codec(){
  local c
  c="$(_audio_field "$1" codec_name)"; c="${c,,}"
  [[ -z "$c" ]] && c="unknown"
  echo "$c"
}

# Return title tag for audio stream (empty string if unset).
# Args: $1 — audio stream index
_audio_title(){
  _audio_tag "$1" title
}

# Map channel count to a human-readable label.
# Args: $1 — channel count, $2 — style: "long" (capitalized + Surround) or "short" (compact, default)
# Output: e.g., long: "5.1 Surround", short: "5.1"
_channel_label(){
  local ch="${1:-0}" style="${2:-short}"
  if [[ "$style" == "long" ]]; then
    case "$ch" in
      1) echo "Mono" ;;         2) echo "Stereo" ;;
      6) echo "5.1 Surround" ;; 8) echo "7.1 Surround" ;;
      *) echo "${ch}ch" ;;
    esac
  else
    case "$ch" in
      1) echo "mono" ;;   2) echo "stereo" ;;
      6) echo "5.1" ;;    8) echo "7.1" ;;
      *) echo "${ch}ch" ;;
    esac
  fi
}

# Build a human-readable audio stream title from codec and channel count.
# Args: $1 — codec name, $2 — channel count
# Output: e.g., "5.1 Surround (E-AC-3)" or "Stereo (AAC)"
_audio_descriptive_title() {
  local codec="$1" ch="${2:-0}"

  local ch_label
  ch_label="$(_channel_label "$ch" long)"

  local codec_display codec_lc="${codec,,}"
  case "$codec_lc" in
    eac3)      codec_display="E-AC-3" ;;
    ac3)       codec_display="AC-3" ;;
    aac)       codec_display="AAC" ;;
    truehd)    codec_display="TrueHD" ;;
    dts)       codec_display="DTS" ;;
    flac)      codec_display="FLAC" ;;
    alac)      codec_display="ALAC" ;;
    opus)      codec_display="Opus" ;;
    pcm_*)     codec_display="PCM" ;;
    *)         codec_display="$codec_lc" ;;
  esac

  echo "${ch_label} (${codec_display})"
}

# Return ordinal position of codec in AUDIO_CODEC_PREFERENCE list (0 = best).
# Returns 10 for unlisted codecs — low preference but not a hard penalty.
# This avoids crushing valid but uncommon codecs (e.g., Opus, FLAC) with
# the ~97-point cliff that rank 99 would create.
# Cache: rebuilds associative array only when AUDIO_CODEC_PREFERENCE changes.
# Args: $1 — codec name (lowercased)
# Globals: AUDIO_CODEC_PREFERENCE (read), _AUDIO_CODEC_RANK_CACHE/_AUDIO_CODEC_RANK_PREF (r/w)
_audio_codec_rank(){
  declare -A _AUDIO_CODEC_RANK_CACHE 2>/dev/null || true
  local codec="$1"
  if [[ "$AUDIO_CODEC_PREFERENCE" != "$_AUDIO_CODEC_RANK_PREF" ]]; then
    _AUDIO_CODEC_RANK_CACHE=()
    local item i=0
    local -a _arr
    IFS=',' read -r -a _arr <<<"$AUDIO_CODEC_PREFERENCE"
    for item in "${_arr[@]}"; do
      item="${item,,}"; item="${item// /}"
      [[ -z "$item" ]] && continue
      _AUDIO_CODEC_RANK_CACHE["$item"]=$i
      (( ++i ))
    done
    _AUDIO_CODEC_RANK_PREF="$AUDIO_CODEC_PREFERENCE"
  fi
  echo "${_AUDIO_CODEC_RANK_CACHE[$codec]:-10}"
}

# Check if a language tag matches any entry in AUDIO_LANG_PREF.
# Returns 0 (true) if the tag matches, 1 otherwise.
# Args: $1 — language tag (lowercased, e.g., "eng", "spa", "und")
# Globals: AUDIO_LANG_PREF (read)
_audio_lang_matches(){
  local lang="$1" pref
  IFS=',' read -r -a prefs <<< "$AUDIO_LANG_PREF"
  for pref in "${prefs[@]}"; do
    pref="${pref// /}"; pref="${pref,,}"
    [[ -z "$pref" ]] && continue
    [[ "$lang" == "$pref" ]] && return 0
  done
  return 1
}

# Check if an audio stream's title tag suggests commentary or descriptive audio.
# Matches common English and international keywords in the title.
# Returns 0 (true) if commentary/descriptive, 1 otherwise.
# Args: $1 — title string (will be lowercased internally)
_audio_is_commentary(){
  local title="${1,,}"
  [[ -z "$title" ]] && return 1
  # shellcheck disable=SC2254
  [[ "$title" =~ (commentary|director.?s?.*commentary|director.?s?.*cut|comentario|kommentar|descriptive|audio.description|visually.impaired) ]] && return 0
  return 1
}

# _audio_stream_info — Fetch all scoring-relevant fields for one audio stream
# in a single jq call (replaces 5 separate jq forks per stream).
# Returns: codec\tchannels\tlanguage\tbit_rate\ttitle  (tab-delimited)
# Args: $1 — audio stream index (0-based, relative to audio streams)
# Globals: METADATA_CACHE (read)
_audio_stream_info(){
  local idx="$1"
  _jq_cache -r "[.streams[] | select(.codec_type==\"audio\")] | .[$idx] |
    \"\(.codec_name // \"unknown\")\t\(.channels // 0)\t\(.tags.language // \"\")\t\(.bit_rate // \"0\")\t\(.tags.title // \"\")\"" | head -n1 || printf 'unknown\t0\t\t0\t\n'
}

# Audio stream scoring algorithm for automatic track selection.
#
# Factors (highest weight first):
#   1. Language preference   — +AUDIO_SCORE_LANG_BONUS (150) if language matches AUDIO_LANG_PREF
#      Ensures preferred language wins over higher-channel foreign tracks.
#   2. Channel count         — ch × AUDIO_SCORE_CHANNEL_MULTIPLIER (20)
#      More channels = higher fidelity; 7.1 scores higher than 5.1.
#   3. Surround bonus        — +AUDIO_SCORE_SURROUND_BONUS (30) if ≥ 6ch
#      Discrete jump to prefer surround over stereo.
#   4. Codec preference      — (10 − rank) × 10 from AUDIO_CODEC_PREFERENCE list
#      10 points per rank position. Ensures codec ordering dominates bitrate.
#      eac3 > ac3 > aac > alac > other by default.
#   5. Bitrate (tie-break)   — br / 50000  (capped at 8)
#      Small bonus for higher-bitrate tracks when all else is equal.
#      Lossless codecs with unreported bitrate get a synthetic floor so they
#      are not penalised for VBR / missing bit_rate metadata.
#   6. Commentary penalty    — −AUDIO_SCORE_COMMENTARY_PENALTY (200) if title matches
#      Demotes commentary/descriptive tracks so the main feature wins.
#
# Returns: score|idx|codec|channels|lang|title
_score_audio_stream(){
  local idx="$1"

  # Single jq call fetches all fields at once
  local info codec lang ch br title rank score
  info="$(_audio_stream_info "$idx")"
  IFS=$'\t' read -r codec ch lang br title <<< "$info"

  _normalize_codec_lang codec lang
  [[ -z "$ch" || ! "$ch" =~ ^[0-9]+$ ]] && ch=0
  [[ -z "$br" || ! "$br" =~ ^[0-9]+$ ]] && br=0

  rank="$(_audio_codec_rank "$codec")"

  score=0
  # Language bonus for preferred language(s) — strongest signal
  if _audio_lang_matches "$lang"; then
    score=$(( score + AUDIO_SCORE_LANG_BONUS ))
  fi
  # Channel count
  score=$(( score + ch * AUDIO_SCORE_CHANNEL_MULTIPLIER ))
  # Surround bonus (>=6ch)
  (( ch >= 6 )) && score=$(( score + AUDIO_SCORE_SURROUND_BONUS ))
  # Codec preference: better rank -> higher score
  # 10 points per rank position ensures codec ordering dominates the bitrate
  # tie-breaker (max ~8 pts) while staying below language/channel signals.
  local inv=$(( (10 - rank) * 10 ))
  (( inv < 0 )) && inv=0
  score=$(( score + inv ))

  # Lossless codecs (TrueHD, DTS-HD MA, FLAC, etc.) often report bit_rate=0
  # because they are VBR. Give them a synthetic floor so they are not penalised
  # relative to lossy codecs that do report bitrate.
  if (( br == 0 )) && audio_is_lossless "$codec"; then
    br=1536000   # ~1.5 Mbps — conservative TrueHD 5.1 average
  fi

  # Bitrate small tie-breaker (scaled, capped so it cannot overpower codec rank)
  if (( br > 0 )); then
    local br_bonus=$(( br / 50000 ))
    (( br_bonus > 8 )) && br_bonus=8
    score=$(( score + br_bonus ))
  fi

  # Commentary/descriptive track penalty
  if _audio_is_commentary "$title"; then
    score=$(( score - AUDIO_SCORE_COMMENTARY_PENALTY ))
  fi

  printf "%s\t%s\t%s\t%s\t%s\t%s\n" "$score" "$idx" "$codec" "$ch" "$lang" "${title:-}"
}

# select_best_audio — Pick the best audio track using the scoring algorithm.
#
# Respects AUDIO_TRACK_OVERRIDE if set (with bounds validation).
# Otherwise, scores all audio streams via _score_audio_stream and returns
# the 0-based audio-relative index of the highest-scoring track.
#
# Returns: audio stream index on stdout ("" if no audio streams exist).
# Globals: AUDIO_TRACK_OVERRIDE (read), METADATA_CACHE (read)
select_best_audio(){
  local n i best_line best_score=-999999
  n="$(_audio_stream_count)"
  (( n > 0 )) || { echo ""; return 0; }

  # Handle user override with validation
  if [[ -n "${AUDIO_TRACK_OVERRIDE:-}" ]]; then
    if [[ "$AUDIO_TRACK_OVERRIDE" =~ ^[0-9]+$ ]] && (( AUDIO_TRACK_OVERRIDE >= 0 && AUDIO_TRACK_OVERRIDE < n )); then
      echo "$AUDIO_TRACK_OVERRIDE"
      return 0
    fi
    warn "Requested --audio-track $AUDIO_TRACK_OVERRIDE is invalid (must be 0-$((n-1))). Using auto-selection."
  fi

  # Score all tracks, select best, and collect summary in one pass
  local -a score_lines=()
  local s_score s_idx s_codec s_ch s_lang s_title
  for (( i=0; i<n; i++ )); do
    local line score
    line="$(_score_audio_stream "$i")"
    score_lines+=("$line")
    score="${line%%$'\t'*}"
    if [[ "$score" =~ ^-?[0-9]+$ ]] && (( score > best_score )); then
      best_score="$score"
      best_line="$line"
    fi
  done

  # Log score breakdown when multiple tracks exist (aids debugging)
  if (( n >= 2 )); then
    local best_idx score_summary=""
    best_idx="${best_line#*$'\t'}"; best_idx="${best_idx%%$'\t'*}"
    for (( i=0; i<n; i++ )); do
      local marker=""
      # shellcheck disable=SC2034  # s_title completes the IFS destructure
      IFS=$'\t' read -r s_score s_idx s_codec s_ch s_lang s_title <<< "${score_lines[$i]}"
      [[ "$s_idx" == "$best_idx" ]] && marker=" ★"
      score_summary+="#${s_idx}: ${s_codec} ${s_ch}ch [${s_lang}] = ${s_score}${marker}  "
    done
    log "• Score: ${score_summary% }"
  fi

  # Extract index from best_line (format: score\tidx\tcodec\tch\tlang\ttitle)
  echo "${best_line#*$'\t'}" | cut -d$'\t' -f1
}

# Check if audio codec can be direct-play copied to MP4
# SYNC: Codecs listed here can reach do_copy=1 in run_audio_pipeline.
#   Any codec added here MUST have a valid ffmpeg muxer extension — if not,
#   add a mapping in _audio_copy_ext().  See also: audio_is_lossless().
audio_is_direct_play_copyable(){
  local codec="$1"
  case "$codec" in
    aac|alac|ac3|eac3) return 0 ;;
    *) return 1 ;;
  esac
}

# Check if audio codec is lossless (for AUDIO_LOSSLESS_PASSTHROUGH)
# SYNC: Codecs listed here can reach do_copy=1 via the lossless passthrough
#   path in run_audio_pipeline.  Any codec added here MUST have a valid ffmpeg
#   muxer extension — if not, add a mapping in _audio_copy_ext().
#   See also: audio_is_direct_play_copyable(), audio_lossless_muxable().
audio_is_lossless(){
  local codec="$1"
  case "$codec" in
    truehd|dts|dca|flac|alac|pcm_s16le|pcm_s24le|pcm_s32le) return 0 ;;
    *) return 1 ;;
  esac
}

# Check if lossless codec can be muxed into the target container
audio_lossless_muxable(){
  local codec="$1"
  case "$MUX_FORMAT" in
    matroska)
      # MKV supports everything
      return 0 ;;
    mp4|mov)
      # MP4/MOV support ALAC and FLAC but NOT TrueHD or DTS-HD
      case "$codec" in
        alac|flac) return 0 ;;
        *) return 1 ;;
      esac
      ;;
  esac
  return 1
}

# Check if an audio codec can be muxed into the current target container.
# Used by the skip-if-ideal remux to gate streams that would fail the mux.
# Conservative: rejects known-incompatible codecs, allows everything else
# (ffmpeg will catch any edge cases during remux as a safe failure mode).
# Args: $1 — codec name (lowercase)
# Globals: MUX_FORMAT (read)
_sii_audio_is_container_safe() {
  local codec="$1"
  [[ "$MUX_FORMAT" == "matroska" ]] && return 0
  # MP4/MOV cannot mux TrueHD, DTS/DTS-HD MA, or raw PCM
  case "$codec" in
    truehd|dts|dca|pcm_*) return 1 ;;
    *) return 0 ;;
  esac
}

# Map ffprobe codec name to a file extension ffmpeg can mux when stream-copying.
# ffmpeg auto-detects the muxer from the output filename extension. Some codecs
# (notably TrueHD and ALAC) use an ffprobe name that doesn't match any registered
# muxer extension, causing "Unable to choose an output format" errors during copy.
# This function returns a safe extension for the intermediate copy file.
# SYNC: Every codec that can reach do_copy=1 in run_audio_pipeline must produce
#   a valid extension here.  When adding codecs to audio_is_lossless() or
#   audio_is_direct_play_copyable(), verify the ffprobe name has a matching
#   ffmpeg muxer — if not, add an explicit mapping below.
# Args: $1 — codec name (lowercased, from ffprobe)
# Stdout: file extension (without dot) suitable for ffmpeg -c copy output
_audio_copy_ext(){
  local codec="$1"
  case "$codec" in
    truehd)                       echo "thd" ;;   # ffmpeg truehd muxer recognizes .thd
    alac)                         echo "m4a" ;;   # ffmpeg has no .alac muxer; .m4a (ipod) works
    pcm_s16le|pcm_s24le|pcm_s32le) echo "wav" ;;  # raw PCM needs a container
    dca)                          echo "dts" ;;    # ffprobe reports dca, muxer expects .dts
    *)                            echo "$codec" ;; # aac, ac3, eac3, flac, dts, etc. work as-is
  esac
}

# Map ffmpeg encoder name to file extension
_audio_codec_ext() {
  case "$1" in
    libopus)    echo "opus" ;;
    libmp3lame) echo "mp3" ;;
    libvorbis)  echo "ogg" ;;
    aac)        echo "aac" ;;
    ac3)        echo "ac3" ;;
    eac3)       echo "eac3" ;;
    flac)       echo "flac" ;;
    *)          echo "$1" ;;  # fallback: use codec name as-is
  esac
}

# Determine target codec and bitrate for audio transcode based on channel count.
# Outputs: "codec bitrate" (space-separated, suitable for `read`)
# Channel thresholds are centralized here to avoid divergence.
# NOTE: This function selects codec based on *source* channel count, not encoder
#   limits.  Callers must apply _codec_max_channels() to clamp effective_ch before
#   passing it to ffmpeg — e.g. eac3 supports at most 6ch despite being selected
#   for 8ch sources.
# Args: $1 — channel count
audio_transcode_target(){
  local ch="$1"
  if (( ch >= 8 )); then
    echo "eac3 $EAC3_BITRATE_7_1"
  elif (( ch >= 6 )); then
    echo "eac3 $EAC3_BITRATE_5_1"
  else
    echo "aac 192k"
  fi
}

# Return the maximum channel count supported by ffmpeg's native encoder for a
# given codec.  Used by run_audio_pipeline to clamp effective_ch *after*
# audio_transcode_target selects the codec — prevents fatal ffmpeg errors like
# "Specified channel layout '7.1' is not supported" from the eac3 encoder.
# Args: $1 — codec name (lowercased)
_codec_max_channels(){
  local codec="$1"
  case "$codec" in
    eac3) echo 6 ;;   # ffmpeg native eac3 encoder: 5.1 max
    ac3)  echo 6 ;;   # ffmpeg native ac3 encoder: 5.1 max
    aac)  echo 48 ;;  # ffmpeg native aac: effectively unlimited
    *)    echo 64 ;;  # conservative fallback — no known encoder needs >64
  esac
}

# _build_audio_keep_list — Subtractive filter for multi-track audio mode.
#
# Enumerates all audio streams and applies keep-filters:
#   1. AUDIO_LANG_PREF (if non-empty) — only keep tracks whose language matches
#   2. AUDIO_KEEP_COMMENTARY — drop commentary/descriptive tracks when 0
#
# Unlike select_best_audio (which scores and picks ONE), this keeps ALL tracks
# that pass the filters. No scoring, no ranking — just pass/fail.
#
# Output: space-separated list of 0-based audio-relative indices on stdout.
#         Empty string if no tracks survive the filter.
# Globals: AUDIO_LANG_PREF (read), AUDIO_KEEP_COMMENTARY (read),
#          METADATA_CACHE (read), TAG_LANGUAGE_DEFAULT (read)
_build_audio_keep_list(){
  local n i
  n="$(_audio_stream_count)"
  (( n > 0 )) || { echo ""; return 0; }

  local -a kept=()
  local -a dropped_reasons=()

  for (( i=0; i<n; i++ )); do
    local info codec lang ch br title
    info="$(_audio_stream_info "$i")"
    IFS=$'\t' read -r codec ch lang br title <<< "$info"
    _normalize_codec_lang codec lang

    # Filter 1: language
    if [[ -n "${AUDIO_LANG_PREF:-}" ]]; then
      if ! _audio_lang_matches "$lang"; then
        dropped_reasons+=("#$i: ${codec} ${ch}ch [$lang] — language not in AUDIO_LANG_PREF")
        continue
      fi
    fi

    # Filter 2: commentary
    if (( ! AUDIO_KEEP_COMMENTARY )) && _audio_is_commentary "$title"; then
      dropped_reasons+=("#$i: ${codec} ${ch}ch [$lang] — commentary/descriptive")
      continue
    fi

    kept+=("$i")
  done

  _log_dropped_tracks "multi-track" dropped_reasons

  echo "${kept[*]}"
}

# run_audio_pipeline_multi — Multi-track audio: filter and defer to mux_final.
#
# Called instead of the single-track pipeline when AUDIO_MULTI_TRACK=1.
# No ffmpeg calls, no intermediate files. Populates metadata arrays that
# mux_final uses to map audio streams directly from source with -c:a copy.
#
# Sets: AUDIO_COPY_FROM_SOURCE, AUDIO_MT_INDICES, AUDIO_MT_CODECS,
#       AUDIO_MT_CHANNELS, AUDIO_MT_LANGS, AUDIO_MT_TITLES,
#       HAS_AUDIO, A_PRIMARY (cleared), AAC_STEREO (cleared)
# Globals: AUDIO_MULTI_TRACK (read), METADATA_CACHE (read)
run_audio_pipeline_multi(){
  local keep_list
  keep_list="$(_build_audio_keep_list)"

  if [[ -z "$keep_list" ]]; then
    note "[Audio] Multi-track filter: no audio tracks survived filtering."
    HAS_AUDIO=0
    return 0
  fi

  # Reset single-track vars (not used in multi-track mode)
  A_PRIMARY=""
  AAC_STEREO=""

  # Populate parallel metadata arrays
  AUDIO_MT_INDICES=()
  AUDIO_MT_CODECS=()
  AUDIO_MT_CHANNELS=()
  AUDIO_MT_LANGS=()
  AUDIO_MT_TITLES=()

  local idx
  for idx in $keep_list; do
    local info codec ch lang br title
    info="$(_audio_stream_info "$idx")"
    IFS=$'\t' read -r codec ch lang br title <<< "$info"
    _normalize_codec_lang codec lang

    AUDIO_MT_INDICES+=("$idx")
    AUDIO_MT_CODECS+=("$codec")
    AUDIO_MT_CHANNELS+=("$ch")
    AUDIO_MT_LANGS+=("$lang")
    AUDIO_MT_TITLES+=("${title:-}")
  done

  AUDIO_COPY_FROM_SOURCE=1
  HAS_AUDIO=1

  # Log summary
  local n_total n_kept n_dropped
  n_total="$(_audio_stream_count)"
  n_kept="${#AUDIO_MT_INDICES[@]}"
  n_dropped=$(( n_total - n_kept ))

  # SYNC: mirror of display loop in run_audio_pipeline — keep both in sync
  say "→ Scanning audio streams (multi-track mode):"
  local i
  for (( i=0; i<n_total; i++ )); do
    local _ainfo _c _ch_i _l _br_i _t pretty marker=""
    _ainfo="$(_audio_stream_info "$i")"
    IFS=$'\t' read -r _c _ch_i _l _br_i _t <<< "$_ainfo"
    _normalize_codec_lang _c _l
    [[ -z "$_br_i" || ! "$_br_i" =~ ^[0-9]+$ ]] && _br_i=0

    # Check if this index is in the keep list
    local _is_kept=0
    for idx in "${AUDIO_MT_INDICES[@]}"; do
      (( idx == i )) && { _is_kept=1; break; }
    done

    pretty="#$i: $_c ${_ch_i}ch [$_l]"
    [[ -n "$_t" ]] && pretty="$pretty — $_t"
    _audio_is_commentary "$_t" && pretty="$pretty [commentary]"
    (( _br_i > 0 )) && pretty="$pretty, $((_br_i/1000))kbps"

    if (( _is_kept )); then
      marker=" ✓"
    else
      marker=" ✗"
    fi
    say "  $pretty$marker"
  done

  note "[Audio] Multi-track: keeping ${n_kept} of ${n_total} tracks (${n_dropped} filtered out)"
  report_add "audio_mode" "multi-track"
  report_add "audio_multi_track_kept" "$n_kept"
  report_add "audio_multi_track_dropped" "$n_dropped"

  # Report kept tracks
  local track_summary=""
  for (( i=0; i<n_kept; i++ )); do
    local _idx="${AUDIO_MT_INDICES[$i]}"
    local _codec="${AUDIO_MT_CODECS[$i]}"
    local _ch="${AUDIO_MT_CHANNELS[$i]}"
    local _lang="${AUDIO_MT_LANGS[$i]}"
    track_summary+="#${_idx}: ${_codec} ${_ch}ch [${_lang}]"
    (( i < n_kept - 1 )) && track_summary+=", "
  done
  report_add "audio_kept_tracks" "$track_summary"

  mark_done "Audio filter plan (multi-track, ${n_kept} tracks)"
}

# run_audio_pipeline — Select, copy or transcode the best audio track.
#
# Decision tree:
#   1. AUDIO_FORCE_CODEC set   → transcode to that codec (or copy if already matching)
#   2. AUDIO_LOSSLESS_PASSTHROUGH + lossless codec + container supports it → copy
#   3. Direct-play-copyable codec (aac, alac, ac3, eac3) → copy
#   4. Otherwise → transcode to eac3 (surround) or aac (stereo)
#
# Optionally creates a stereo AAC fallback track (ADD_STEREO_IF_MULTICH).
#
# Sets: A_PRIMARY, AAC_STEREO, HAS_AUDIO, A_PRIMARY_LANG, A_PRIMARY_TITLE,
#       A_STEREO_LANG
# Dies on: audio copy/transcode failure (exit 43)
run_audio_pipeline(){
  # shellcheck disable=SC2034
  local n best idx codec ch lang br title
  n="$(_audio_stream_count)"
  
  if (( n == 0 )); then
    note "No audio streams detected."
    HAS_AUDIO=0
    return 0
  fi

  # ---- Multi-track mode: filter and defer to mux_final ----
  # When AUDIO_MULTI_TRACK=1, skip single-track scoring entirely.
  # Demote to single-track if the user set overrides that are incompatible.
  if (( AUDIO_MULTI_TRACK )); then
    if [[ -n "${AUDIO_TRACK_OVERRIDE:-}" ]]; then
      note "[Audio] AUDIO_MULTI_TRACK demoted to single-track: --audio-track override is set."
    elif [[ -n "${AUDIO_FORCE_CODEC:-}" ]]; then
      note "[Audio] AUDIO_MULTI_TRACK demoted to single-track: --audio-force-codec is set."
    else
      run_audio_pipeline_multi
      return $?
    fi
  fi

  # ---- Single-track mode (score, select, copy/transcode) ----
  idx="$(select_best_audio)"
  [[ -n "$idx" ]] || { HAS_AUDIO=0; return 0; }

  codec="$(_audio_codec "$idx")"
  ch="$(_audio_channels "$idx")"
  lang="$(_audio_lang "$idx")"
  br="$(_audio_bitrate "$idx")"
  title="$(_audio_title "$idx")"

  # SYNC: mirror of display loop in run_audio_pipeline_multi — keep both in sync
  log "• Detected audio streams:"
  local i
  for (( i=0; i<n; i++ )); do
    local _ainfo _c _ch_i _l _br_i _t pretty
    _ainfo="$(_audio_stream_info "$i")"
    IFS=$'\t' read -r _c _ch_i _l _br_i _t <<< "$_ainfo"
    _normalize_codec_lang _c _l
    [[ -z "$_br_i" || ! "$_br_i" =~ ^[0-9]+$ ]] && _br_i=0

    pretty="#$i: $_c ${_ch_i}ch [$_l]"
    [[ -n "$_t" ]] && pretty="$pretty — $_t"
    _audio_is_commentary "$_t" && pretty="$pretty [commentary]"
    (( _br_i > 0 )) && pretty="$pretty, $((_br_i/1000))kbps"
    log "  $pretty"
  done

  note "[Audio] Selected track #$idx: $codec ${ch}ch [$lang]${title:+ — $title}${br:+, $((br/1000))kbps}"
  report_add "audio_source" "track #$idx: $codec ${ch}ch [$lang]"

  A_PRIMARY="$WORKDIR/audio_primary.$(_audio_copy_ext "$codec")"
  AAC_STEREO="$WORKDIR/audio_stereo.aac"
  HAS_AUDIO=1

  # Persist audio metadata for mux_final tagging
  A_PRIMARY_LANG="$lang"
  A_PRIMARY_TITLE="${title:-}"
  A_PRIMARY_CHANNELS="$ch"
  A_STEREO_LANG="$lang"

  # Enforce MAX_AUDIO_CHANNELS
  local effective_ch="$ch"
  if (( ch > MAX_AUDIO_CHANNELS )); then
    note "Capping audio channels from $ch to $MAX_AUDIO_CHANNELS (MAX_AUDIO_CHANNELS)"
    effective_ch="$MAX_AUDIO_CHANNELS"
  fi

  log "→ Preparing primary audio → $A_PRIMARY"

  if (( DRY_RUN )); then
    : > "$A_PRIMARY" 2>/dev/null || true
    mark_done "Primary audio prepared (dry-run)"
    if (( ADD_STEREO_IF_MULTICH )) && (( effective_ch > 2 )); then
      : > "$AAC_STEREO" 2>/dev/null || true
      mark_done "Stereo fallback prepared (dry-run)"
    fi
    return 0
  fi

  # Decision tree for audio handling:
  # 1. AUDIO_FORCE_CODEC set → always transcode to that codec
  # 2. AUDIO_LOSSLESS_PASSTHROUGH=1 and codec is lossless and container supports it → copy
  # 3. Direct-play-copyable codec → copy
  # 4. Otherwise → transcode

  local do_copy=0 tgt_codec="" tgt_br=""

  # Step 1: Forced codec override via AUDIO_FORCE_CODEC (--audio-force-codec)
  if [[ -n "${AUDIO_FORCE_CODEC:-}" ]]; then
    # Force codec: always transcode to target
    tgt_codec="$AUDIO_FORCE_CODEC"
    if [[ "$tgt_codec" == "$codec" ]] && (( effective_ch == ch )); then
      do_copy=1
      note "Audio already matches forced codec ($tgt_codec). Copying."
      report_add "audio_action" "copy (already $tgt_codec)"
    else
      read -r _ tgt_br <<< "$(audio_transcode_target "$effective_ch")"
      if [[ "$tgt_codec" == "aac" ]]; then
        tgt_br="256k"
      fi
      [[ -n "${AUDIO_FORCE_BITRATE:-}" ]] && tgt_br="$AUDIO_FORCE_BITRATE"
      note "Force transcoding audio: $codec → $tgt_codec (${effective_ch}ch, ${tgt_br})"
      report_add "audio_action" "transcode to $tgt_codec"
    fi
  # Step 2: Lossless passthrough (if enabled and codec is lossless)
  elif (( AUDIO_LOSSLESS_PASSTHROUGH )) && audio_is_lossless "$codec"; then
    if audio_lossless_muxable "$codec"; then
      do_copy=1
      note "Lossless audio passthrough ($codec). Copying without conversion."
      report_add "audio_action" "lossless passthrough ($codec)"
    else
      # Lossless but can't mux into target container — transcode to best compatible
      read -r tgt_codec tgt_br <<< "$(audio_transcode_target "$effective_ch")"
      note "Lossless $codec can't mux into $MUX_FORMAT — transcoding to $tgt_codec."
      report_add "audio_action" "transcode (lossless $codec incompatible with $MUX_FORMAT)"
    fi
  # Step 3: Direct-play-copyable codec (aac, alac, ac3, eac3) → copy
  elif audio_is_direct_play_copyable "$codec" && (( effective_ch == ch )); then
    do_copy=1
    note "Direct Play audio codec detected ($codec). Copying without conversion."
    report_add "audio_action" "copy ($codec direct-play compatible)"
  # Step 4: Fallback → transcode to eac3 (surround) or aac (stereo)
  else
    read -r tgt_codec tgt_br <<< "$(audio_transcode_target "$effective_ch")"
    note "Transcoding audio: $codec → $tgt_codec (channels=${effective_ch}ch, bitrate=$tgt_br)"
    report_add "audio_action" "transcode $codec → $tgt_codec"
  fi

  # Update metadata to reflect the final output codec and channel count
  if (( do_copy )); then
    A_PRIMARY_CODEC="$codec"
  else
    A_PRIMARY_CODEC="$tgt_codec"
  fi

  # Enforce encoder channel ceiling (e.g., eac3/ac3 max = 6ch).
  # audio_transcode_target selects codec based on *source* channel count, but
  # ffmpeg's native encoders may support fewer channels than the source has.
  # Without this clamp, -ac 8 + eac3 causes a fatal ffmpeg error.
  if (( ! do_copy )); then
    local codec_max
    codec_max="$(_codec_max_channels "$tgt_codec")"
    if (( effective_ch > codec_max )); then
      note "Capping channels from $effective_ch to $codec_max ($tgt_codec encoder limit)"
      effective_ch="$codec_max"
      # Re-derive bitrate for the capped channel count so it matches the actual
      # output layout (e.g., 768k 7.1 → 640k 5.1).
      read -r _ tgt_br <<< "$(audio_transcode_target "$effective_ch")"
    fi
  fi

  A_PRIMARY_CHANNELS="$effective_ch"

  if (( do_copy )); then
    ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:a:"$idx" -c copy "$A_PRIMARY" 2>"$WORKDIR/audio_primary.err" &
    local acopy_pid=$!
    spinner "$acopy_pid" "Copying audio stream"
    if ! wait "$acopy_pid" 2>/dev/null; then
      die 43 "Audio copy failed. See: $WORKDIR/audio_primary.err"
    fi
  else
    A_PRIMARY="$WORKDIR/audio_primary.$(_audio_codec_ext "$tgt_codec")"
    local -a transcode_args=("${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map "0:a:$idx")

    if [[ "$tgt_codec" == "eac3" ]]; then
      transcode_args+=(-c:a eac3 -b:a "$tgt_br")
    elif [[ "$tgt_codec" == "aac" ]]; then
      transcode_args+=(-c:a aac -b:a "$tgt_br")
    elif [[ "$tgt_codec" == "ac3" ]]; then
      transcode_args+=(-c:a ac3 -b:a "$tgt_br")
    else
      transcode_args+=(-c:a "$tgt_codec" -b:a "$tgt_br")
    fi

    # Apply channel limit
    transcode_args+=(-ac "$effective_ch")
    transcode_args+=("$A_PRIMARY")

    local total_secs
    total_secs="$(_get_source_duration_secs)"
    if ! _ffmpeg_run_with_ui transcode_args "Transcoding audio" "$WORKDIR/audio_primary.err" "$total_secs"; then
      die 43 "Audio transcode to $tgt_codec failed. See: $WORKDIR/audio_primary.err"
    fi
  fi

  # Validate primary audio
  if [[ ! -s "$A_PRIMARY" ]]; then
    die 43 "Primary audio preparation produced empty file"
  fi

  mark_done "Primary audio prepared"

  # Add stereo fallback if needed
  if (( ADD_STEREO_IF_MULTICH )) && (( effective_ch > 2 )); then
    # Scan for a native stereo track before falling back to a synthetic downmix.
    local _native_si="" _native_sc=""
    local _ns_total _ns_i _ns_info _ns_c _ns_ch _ns_l _ns_br _ns_t _ns_vi _ns_hi
    _ns_total="$(_audio_stream_count)"
    for (( _ns_i = 0; _ns_i < _ns_total; _ns_i++ )); do
      (( _ns_i == idx )) && continue
      _ns_info="$(_audio_stream_info "$_ns_i")"
      IFS=$'\t' read -r _ns_c _ns_ch _ns_l _ns_br _ns_t <<< "$_ns_info"
      _ns_c="${_ns_c,,}"; _ns_l="${_ns_l,,}"
      [[ -z "$_ns_l" ]] && _ns_l="$TAG_LANGUAGE_DEFAULT"
      [[ -z "$_ns_ch" || ! "$_ns_ch" =~ ^[0-9]+$ ]] && _ns_ch=0
      # Must be exactly 2 channels
      (( _ns_ch != 2 )) && continue
      # Language must match primary track (und matches anything)
      if [[ "$_ns_l" != "und" && "$lang" != "und" && "$_ns_l" != "$lang" ]]; then continue; fi
      # Not commentary or descriptive audio (title check)
      _audio_is_commentary "$_ns_t" && continue
      # Not flagged as visually impaired or hearing impaired (disposition flags)
      _ns_vi="$(_jq_cache -r "[.streams[] | select(.codec_type==\"audio\")] | .[$_ns_i].disposition.visual_impaired // 0")"
      _ns_hi="$(_jq_cache -r "[.streams[] | select(.codec_type==\"audio\")] | .[$_ns_i].disposition.hearing_impaired // 0")"
      (( _ns_vi )) && continue
      (( _ns_hi )) && continue
      _native_si="$_ns_i"
      _native_sc="$_ns_c"
      break
    done

    local stereo_total_secs
    stereo_total_secs="$(_get_source_duration_secs)"

    if [[ -z "$_native_si" ]]; then
      note "[Audio] No native stereo track available. Creating downmix from surround."
      log "→ Preparing stereo fallback → $AAC_STEREO"
      # shellcheck disable=SC2034  # used by name-reference in _ffmpeg_run_with_ui
      local -a stereo_cmd=("${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:a:"$idx" \
        -c:a aac -b:a "$STEREO_BITRATE" -ac 2 "$AAC_STEREO")
      if ! _ffmpeg_run_with_ui stereo_cmd "Creating stereo fallback" "$WORKDIR/audio_stereo.err" "$stereo_total_secs"; then
        warn "Stereo fallback creation failed - continuing without it. See: $WORKDIR/audio_stereo.err"
        AAC_STEREO=""
      else
        mark_done "Stereo fallback prepared"
      fi
    else
      note "[Audio] Native stereo track found (stream #${_native_si}, ${_native_sc} 2ch). Preferring over synthetic downmix."
      # Copy if codec is compatible with the output container; otherwise transcode to AAC.
      local _ns_do_copy=0
      case "$OUTPUT_EXT" in
        mkv) _ns_do_copy=1 ;;
        mp4|m4v|mov)
          case "$_native_sc" in aac|ac3|eac3) _ns_do_copy=1 ;; esac ;;
      esac
      if (( ! _ns_do_copy )); then
        # shellcheck disable=SC2034  # used by name-reference in _ffmpeg_run_with_ui
        local -a stereo_cmd=("${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map "0:a:${_native_si}" \
          -c:a aac -b:a "$STEREO_BITRATE" "$AAC_STEREO")
        if ! _ffmpeg_run_with_ui stereo_cmd "Transcoding native stereo" "$WORKDIR/audio_stereo.err" "$stereo_total_secs"; then
          warn "Native stereo transcode failed - continuing without it. See: $WORKDIR/audio_stereo.err"
          AAC_STEREO=""
        else
          mark_done "Stereo fallback prepared (native)"
        fi
      else
        ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map "0:a:${_native_si}" -c copy "$AAC_STEREO" \
          2>"$WORKDIR/audio_stereo.err" &
        local _ns_pid=$!
        spinner "$_ns_pid" "Copying native stereo track"
        if ! wait "$_ns_pid" 2>/dev/null; then
          warn "Native stereo copy failed - continuing without it. See: $WORKDIR/audio_stereo.err"
          AAC_STEREO=""
        else
          mark_done "Stereo fallback prepared (native)"
        fi
      fi
    fi
  else
    note "Primary audio is stereo (or fallback disabled); no extra stereo needed."
  fi
}

# ===== Section 28: Subtitle helpers (planner + OCR) ==========================================
# Count subtitle streams in source file
_sub_count() {
  _jq_cache '[.streams[] | select(.codec_type=="subtitle")] | length' || echo 0
}

# Emit integers 0..N-1 (one per line) for iterating all subtitle stream indices.
# Provides a standard loop target: for i in $(list_sub_indices); do ...
list_sub_indices(){
  local n i
  n="$(_sub_count)"
  for (( i=0; i<n; i++ )); do echo "$i"; done
}

# Get subtitle field from cached metadata (single jq call)
# Args: $1 — subtitle stream index (0-based, relative to subtitle streams)
#        $2 — field name (jq path, e.g., codec_name)
# Globals: METADATA_CACHE (read)
_sp_sub_field() {
  local idx="$1" field="$2"
  _jq_cache -r \
    "[.streams[] | select(.codec_type==\"subtitle\")] | .[$idx].$field // empty" | head -n1 || true
}

# Get subtitle tag from cached metadata (single jq call)
# Args: $1 — subtitle stream index, $2 — tag name (e.g., language, title)
# Globals: METADATA_CACHE (read)
_sp_sub_tag() {
  local idx="$1" tag="$2"
  _jq_cache -r \
    "[.streams[] | select(.codec_type==\"subtitle\")] | .[$idx].tags.$tag // empty" | head -n1 || true
}

# Check if subtitle stream has forced disposition (single jq call)
# Args: $1 — subtitle stream index
# Returns: 1 if forced, 0 otherwise
# Globals: METADATA_CACHE (read)
_sp_sub_dispo_forced(){
  local idx="$1"
  _jq_cache \
    "[.streams[] | select(.codec_type==\"subtitle\")] | .[$idx].disposition.forced // 0" | head -n1 || echo 0
}

# Return language tag for subtitle stream (lowercased), defaulting to TAG_LANGUAGE_DEFAULT.
# Args: $1 — subtitle stream index
_sp_sub_lang(){
  local lang
  lang="$(_sp_sub_tag "$1" language)"; lang="${lang,,}"
  [[ -z "$lang" ]] && lang="$TAG_LANGUAGE_DEFAULT"
  echo "$lang"
}

# Heuristic: check if a subtitle title string indicates forced/signs content.
# Matches: "forced", "signs", "foreign" (case-insensitive).
# Args: $1 — title string to test
# Returns: 0 if match, 1 otherwise
_is_forced_title(){
  local t="${1,,}"
  [[ "$t" =~ forced|signs|foreign ]]
}

# Heuristic: check if a subtitle title string indicates SDH/HI content.
# Matches: "sdh", "hi", "hearing", "impaired", "cc", "caption" as whole words.
# Args: $1 — title string to test
# Returns: 0 if match, 1 otherwise
_is_sdh_title(){
  local t="${1,,}"
  [[ "$t" =~ (^|[^a-z])(sdh|hi)([^a-z]|$)|hearing|impaired|cc|caption ]]
}

# _sub_stream_info — Fetch all scan-relevant fields for one subtitle stream
# in a single jq call (replaces 3–4 separate jq forks per stream).
# Returns: codec\tlanguage\ttitle\tforced  (tab-delimited)
# Args: $1 — subtitle stream index (0-based, relative to subtitle streams)
# Globals: METADATA_CACHE (read)
_sub_stream_info(){
  local idx="$1"
  _jq_cache -r "[.streams[] | select(.codec_type==\"subtitle\")] | .[$idx] |
    \"\(.codec_name // \"?\")\t\(.tags.language // \"\")\t\(.tags.title // \"\")\t\(.disposition.forced // 0)\"" | head -n1 || printf '?\t\t\t0\n'
}

# Format a subtitle stream as a human-readable one-line summary.
# Output: "#0: subrip [eng] — English (forced)" (prints to stdout)
# Args: $1 — subtitle stream index
describe_sub_stream(){
  local i="$1" info codec lang title forced flags=""
  info="$(_sub_stream_info "$i")"
  IFS=$'\t' read -r codec lang title forced <<< "$info"

  _normalize_codec_lang codec lang

  (( forced )) && flags=" (forced)"
  if _is_sdh_title "$title"; then
    [[ -n "$flags" ]] && flags="$flags, "
    flags="${flags}SDH"
  fi
  
  printf "#%s: %s [%s]%s%s\n" "$i" "${codec:-?}" "$lang" "${title:+ — $title}" "$flags"
}

# Check if codec is text-based (can be stream-copied to MP4 as mov_text or MKV as srt).
# Text: subrip, srt, ass, ssa, webvtt, vtt, mov_text
# Bitmap (not text): hdmv_pgs_subtitle, dvd_subtitle, dvb_subtitle
# Args: $1 — codec name
_is_text_sub_codec(){
  local c="$1"
  case "$c" in
    subrip|srt|ass|ssa|webvtt|vtt|mov_text) return 0 ;;
    *) return 1 ;;
  esac
}

_container_supports_bitmap_subs(){ [[ "$MUX_FORMAT" == "matroska" ]]; }

# Find the first text-based subtitle in a preferred language for direct stream copy.
# Returns: relative subtitle index on stdout (empty string if none found).
# Used as a fast path when no OCR or conversion is needed.
_pick_direct_text_sub_relidx(){
  local i lang codec
  # shellcheck disable=SC2046  # Intentional word-splitting of integer list
  for i in $(list_sub_indices); do
    lang="$(_sp_sub_lang "$i")"
    [[ ",$SUB_LANG_PREF," == *",$lang,"* ]] || continue
    codec="$(_sp_sub_field "$i" codec_name)"; codec="${codec,,}"
    if _is_text_sub_codec "$codec"; then
      echo "$i"
      return 0
    fi
  done
  echo ""
}

# Prepare subtitle for output (extract, convert, or OCR as needed).
# When SUB_PRESERVE_TEXT_FORMAT=1 and the output container is MKV,
# ASS/SSA subtitles are extracted in native format instead of converting to SRT.
# Args: subtitle_stream_index
# Returns: path to prepared subtitle file or empty string if failed
_prepare_subtitle(){
  local idx="$1" codec srt sup vob_base

  if [[ ! -d "$WORKDIR" ]]; then
    warn "Workdir disappeared — cannot extract subtitle #$idx"
    return 1
  fi

  codec="$(_sp_sub_field "$idx" codec_name)"; codec="${codec,,}"
  srt="$WORKDIR/sub.${idx}.srt"

  # Check if we should preserve native text format (ASS/SSA) for this run.
  # Conditions: SUB_PRESERVE_TEXT_FORMAT=1, output container is MKV, and codec is ASS/SSA.
  local _preserve_native=0
  if (( SUB_PRESERVE_TEXT_FORMAT )) && [[ "$MUX_FORMAT" == "matroska" ]]; then
    case "$codec" in
      ass|ssa) _preserve_native=1 ;;
    esac
  fi

  if (( DRY_RUN )); then
    if (( _preserve_native )); then
      local dry_out="$WORKDIR/sub.${idx}.${codec}"
      printf "[Script Info]\n; dry-run\n" >"$dry_out" 2>/dev/null || true
      note "[Subs] DRY-RUN: would extract subtitle #${idx} as native ${codec} (preserving styling)"
      echo "$dry_out"
    else
      printf "1\n00:00:00,000 --> 00:00:00,500\n(dry-run)\n" >"$srt" 2>/dev/null || true
      echo "$srt"
    fi
    return 0
  fi

  case "$codec" in
    subrip|srt)
      ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:s:"$idx" -c copy "$srt" 2>"$WORKDIR/sub_${idx}.err" &
      local sub_pid=$!
      spinner "$sub_pid" "Extracting subtitle #${idx} (SRT copy)"
      if wait "$sub_pid" 2>/dev/null; then
        echo "$srt"
        return 0
      fi
      warn "Failed to extract SRT subtitle #$idx. See: $WORKDIR/sub_${idx}.err"
      ;;
      
    ass|ssa|webvtt|vtt)
      if (( _preserve_native )); then
        # Extract in native format (copy, no conversion)
        local native_out="$WORKDIR/sub.${idx}.${codec}"
        ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:s:"$idx" -c:s copy "$native_out" 2>"$WORKDIR/sub_${idx}.err" &
        local sub_pid=$!
        spinner "$sub_pid" "Extracting subtitle #${idx} (${codec} native copy)"
        if wait "$sub_pid" 2>/dev/null; then
          echo "$native_out"
          return 0
        fi
        warn "Failed to extract native ${codec} subtitle #$idx. See: $WORKDIR/sub_${idx}.err"
      else
        # Convert to SRT (legacy behavior)
        ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:s:"$idx" "$srt" 2>"$WORKDIR/sub_${idx}.err" &
        local sub_pid=$!
        spinner "$sub_pid" "Converting subtitle #${idx} (${codec} → SRT)"
        if wait "$sub_pid" 2>/dev/null; then
          echo "$srt"
          return 0
        fi
        warn "Failed to convert subtitle #$idx to SRT. See: $WORKDIR/sub_${idx}.err"
      fi
      ;;
      
    hdmv_pgs_subtitle|pgs)
      local _preserve_pgs=0
      if (( SUB_PRESERVE_BITMAP )) && _container_supports_bitmap_subs && (( ! SUB_BURN_FORCED )); then
        _preserve_pgs=1
      fi

      sup="$WORKDIR/sub.${idx}.sup"

      if (( DRY_RUN )) && (( _preserve_pgs )); then
        printf "" >"$sup" 2>/dev/null || true
        note "[Subs] DRY-RUN: would stream-copy PGS subtitle #${idx} as .sup (bitmap preserved)"
        echo "$sup"
        return 0
      fi

      ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:s:"$idx" -c:s copy "$sup" 2>"$WORKDIR/sub_${idx}_extract.err" &
      local sup_pid=$!
      spinner "$sup_pid" "Extracting PGS subtitle #${idx} to SUP"
      if ! wait "$sup_pid" 2>/dev/null; then
        warn "Failed extracting PGS #$idx to .sup — skipping. See: $WORKDIR/sub_${idx}_extract.err"
        echo ""
        return 0
      fi

      if (( _preserve_pgs )); then
        note "[Subs] Preserving PGS subtitle #${idx} as bitmap (.sup stream-copy)"
        echo "$sup"
        return 0
      fi

      if (( ! SUB_ENABLE_OCR )); then
        warn "PGS subtitle #$idx requires OCR but OCR is disabled — skipping."
        echo ""
        return 0
      fi

      local _ocr_ok=0

      # Try vobsub conversion if muxer is available
      if ffmpeg_has_muxer vobsub; then
        vob_base="$WORKDIR/sub.${idx}.vob"
        ffmpeg "${FFMPEG_FLAGS[@]}" -i "$sup" -map 0:s:0 -c:s dvdsub -f vobsub "$vob_base" 2>"$WORKDIR/sub_${idx}_vobsub.err" &
        local vob_pid=$!
        spinner "$vob_pid" "Converting PGS #${idx} to VobSub"
        if ! wait "$vob_pid" 2>/dev/null; then
          warn "PGS→VobSub conversion failed for #$idx. See: $WORKDIR/sub_${idx}_vobsub.err"
          echo ""
          return 0
        fi

        # Run OCR tool on VobSub .idx
        (
          "$SUB_OCR_TOOL" "${vob_base}.idx" >"$WORKDIR/sub_${idx}_ocr.log" 2>&1 \
            || "$SUB_OCR_TOOL" -l "$SUB_OCR_LANG" "${vob_base}.idx" >"$WORKDIR/sub_${idx}_ocr.log" 2>&1 \
            || true
        ) &
        local ocr_pid=$!
        spinner "$ocr_pid" "Running OCR on subtitle #${idx}"
        wait "$ocr_pid" 2>/dev/null || true
        if [[ -s "${vob_base}.srt" ]]; then
          mv -f "${vob_base}.srt" "$srt" || true
        fi
        if [[ -s "$srt" ]]; then
          echo "$srt"
          return 0
        fi
        warn "OCR tool ('$SUB_OCR_TOOL') ran on VobSub but produced no SRT for subtitle #$idx. See: $WORKDIR/sub_${idx}_ocr.log"
        echo ""
        return 0
      fi

      # Fallback: try OCR tool directly on .sup
      (
        "$SUB_OCR_TOOL" "$sup" >"$WORKDIR/sub_${idx}_ocr_sup.log" 2>&1 \
          || "$SUB_OCR_TOOL" -l "$SUB_OCR_LANG" "$sup" >"$WORKDIR/sub_${idx}_ocr_sup.log" 2>&1 \
          || true
      ) &
      local ocr_sup_pid=$!
      spinner "$ocr_sup_pid" "Running OCR on subtitle #${idx} (SUP)"
      wait "$ocr_sup_pid" 2>/dev/null || true
      # Check common output locations for the SRT
      if [[ -s "${sup%.sup}.srt" ]]; then
        mv -f "${sup%.sup}.srt" "$srt" || true
        _ocr_ok=1
      elif [[ -s "${sup}.srt" ]]; then
        mv -f "${sup}.srt" "$srt" || true
        _ocr_ok=1
      fi
      if (( _ocr_ok )) && [[ -s "$srt" ]]; then
        echo "$srt"
        return 0
      fi

      # Provide specific diagnostic based on what failed
      if ! ffmpeg_has_muxer vobsub; then
        warn "PGS subtitle #$idx: ffmpeg lacks the 'vobsub' muxer (common on macOS Homebrew builds)."
        warn "  '$SUB_OCR_TOOL' also could not process .sup directly. See: $WORKDIR/sub_${idx}_ocr_sup.log"
        warn "  Fix: install a PGS-capable OCR tool (e.g., pgsrip) or rebuild ffmpeg with vobsub."
      else
        warn "PGS OCR failed for subtitle #$idx — '$SUB_OCR_TOOL' produced no output."
        warn "  See: $WORKDIR/sub_${idx}_ocr_sup.log"
      fi
      echo ""
      return 0
      ;;
      
    *)
      warn "Unsupported subtitle codec '$codec' for #$idx — skipping."
      ;;
  esac

  echo ""
  return 0
}

# _prepare_ext_subtitle — Prepare an external subtitle file for muxing.
#
# For text formats (srt/ass/ssa/vtt): returns the absolute path as-is.
#   ffmpeg can read these directly as -i inputs with no intermediate extraction.
# For PGS (.sup): OCR pipeline → SRT (requires SUB_ENABLE_OCR=1).
# For VobSub (.idx): OCR pipeline → SRT (requires SUB_ENABLE_OCR=1, partner .sub must exist).
#
# Args: $1 — absolute path to external subtitle file
# Returns: path to a usable subtitle file (possibly in WORKDIR), or "" on failure
# Globals: WORKDIR, SUB_ENABLE_OCR, SUB_OCR_TOOL, SUB_OCR_LANG, DRY_RUN
_prepare_ext_subtitle(){
  local ext_path="$1"
  local fext="${ext_path##*.}"; fext="${fext,,}"
  local basename_label
  basename_label="$(basename -- "$ext_path")"

  if [[ ! -f "$ext_path" ]]; then
    warn "[Subs] External subtitle not found: $ext_path"
    echo ""
    return 0
  fi

  case "$fext" in
    srt|ass|ssa|vtt)
      # Text formats: pass through directly — ffmpeg reads them as subtitle inputs
      if (( DRY_RUN )); then
        note "[Subs] DRY-RUN: would use external subtitle $basename_label"
      fi
      echo "$ext_path"
      return 0
      ;;

    sup)
      # PGS bitmap: preserve via stream-copy if container supports it, else OCR to SRT
      if (( SUB_PRESERVE_BITMAP )) && _container_supports_bitmap_subs && (( ! SUB_BURN_FORCED )); then
        if (( DRY_RUN )); then
          note "[Subs] DRY-RUN: would use external PGS $basename_label as bitmap (.sup stream-copy)"
        fi
        echo "$ext_path"
        return 0
      fi

      if (( ! SUB_ENABLE_OCR )); then
        warn "[Subs] External PGS $basename_label requires OCR but OCR is disabled — skipping."
        echo ""
        return 0
      fi

      local srt_out="$WORKDIR/ext_${basename_label%.sup}.srt"

      if (( DRY_RUN )); then
        printf "1\n00:00:00,000 --> 00:00:00,500\n(dry-run external PGS)\n" >"$srt_out" 2>/dev/null || true
        note "[Subs] DRY-RUN: would OCR external PGS $basename_label"
        echo "$srt_out"
        return 0
      fi

      (
        "$SUB_OCR_TOOL" "$ext_path" >"$WORKDIR/ext_ocr_sup.log" 2>&1 \
          || "$SUB_OCR_TOOL" -l "$SUB_OCR_LANG" "$ext_path" >"$WORKDIR/ext_ocr_sup.log" 2>&1 \
          || true
      ) &
      local ocr_pid=$!
      spinner "$ocr_pid" "OCR external PGS: $basename_label"
      wait "$ocr_pid" 2>/dev/null || true

      # Some OCR tools write .srt next to source file; relocate to workdir
      local sup_srt="${ext_path%.sup}.srt"
      if [[ -s "$sup_srt" ]]; then
        mv -f "$sup_srt" "$srt_out" || true
      fi

      if [[ -s "$srt_out" ]]; then
        echo "$srt_out"
        return 0
      fi
      warn "[Subs] OCR failed for external PGS $basename_label. See: $WORKDIR/ext_ocr_sup.log"
      echo ""
      return 0
      ;;

    idx)
      # VobSub: OCR to SRT (partner .sub must exist — checked in discover_external_subtitles)
      if (( ! SUB_ENABLE_OCR )); then
        warn "[Subs] External VobSub $basename_label requires OCR but OCR is disabled — skipping."
        echo ""
        return 0
      fi

      local srt_out="$WORKDIR/ext_${basename_label%.idx}.srt"

      if (( DRY_RUN )); then
        printf "1\n00:00:00,000 --> 00:00:00,500\n(dry-run external VobSub)\n" >"$srt_out" 2>/dev/null || true
        note "[Subs] DRY-RUN: would OCR external VobSub $basename_label"
        echo "$srt_out"
        return 0
      fi

      (
        "$SUB_OCR_TOOL" "$ext_path" >"$WORKDIR/ext_ocr_vobsub.log" 2>&1 \
          || "$SUB_OCR_TOOL" -l "$SUB_OCR_LANG" "$ext_path" >"$WORKDIR/ext_ocr_vobsub.log" 2>&1 \
          || true
      ) &
      local ocr_pid=$!
      spinner "$ocr_pid" "OCR external VobSub: $basename_label"
      wait "$ocr_pid" 2>/dev/null || true

      if [[ -s "$srt_out" ]]; then
        echo "$srt_out"
        return 0
      fi
      warn "[Subs] OCR failed for external VobSub $basename_label. See: $WORKDIR/ext_ocr_vobsub.log"
      echo ""
      return 0
      ;;

    *)
      warn "[Subs] Unsupported external subtitle format: .$fext ($basename_label)"
      echo ""
      return 0
      ;;
  esac
}

# _prepare_sub_from_source — Dispatch subtitle preparation based on source descriptor.
# Routes "embedded:N" to _prepare_subtitle (extract from source file) and
# "ext:/path" to _prepare_ext_subtitle (use external file directly or OCR).
# Args: $1 — source descriptor ("embedded:N" or "ext:/abs/path")
# Returns: path to prepared subtitle file or empty string on failure
_prepare_sub_from_source(){
  local src="$1"
  if [[ "$src" == embedded:* ]]; then
    _prepare_subtitle "${src#embedded:}"
  else
    _prepare_ext_subtitle "${src#ext:}"
  fi
}

# May hold .srt, .ass, .ssa, or .sup path; name is historical
SRT_FORCED=""
SRT_FULL=""
SRT_SDH=""
SRT_FORCED_BURN_PATH=""           # Set when SUB_BURN_FORCED=1; used by video pipeline
declare -a EXTERNAL_SRT_PATHS=()  # Paths of external SRT files exported alongside output
declare -i SRT_DIRECT_MAP=0
DIRECT_SUB_RELIDX=""

# Subtitle metadata for mux tagging (populated by build_subtitle_plan)
SRT_FORCED_LANG=""
SRT_FULL_LANG=""
SRT_SDH_LANG=""
SRT_FORCED_TITLE=""
SRT_FULL_TITLE=""
SRT_SDH_TITLE=""

# Audio metadata for mux tagging (populated by run_audio_pipeline)
A_PRIMARY_LANG=""
A_PRIMARY_TITLE=""
A_PRIMARY_CHANNELS=""
A_PRIMARY_CODEC=""
A_STEREO_LANG=""

# Process a prepared subtitle: either export as external file or embed.
# Sets _SUB_EMBED_PATH to the subtitle path if embedded, empty if exported externally.
# Args: $1 — subtitle file path (may be .srt, .ass, .ssa), $2 — label (full|sdh)
# Globals: SUB_EXPORT_EXTERNAL, OUT, OUTPUT_EXT, DRY_RUN, EXTERNAL_SRT_PATHS (modified)
_SUB_EMBED_PATH=""
_export_or_embed_sub(){
  local sub_path="$1" label="$2"
  _SUB_EMBED_PATH=""
  # Derive extension from the prepared subtitle file
  local sub_ext="${sub_path##*.}"
  if (( SUB_EXPORT_EXTERNAL )); then
    local ext_sub="${OUT%."${OUTPUT_EXT}"}.${label}.${sub_ext}"
    if (( ! DRY_RUN )); then
      cp -f "$sub_path" "$ext_sub" 2>/dev/null || true
    fi
    EXTERNAL_SRT_PATHS+=("$ext_sub")
    note "[Subs] Exported $label → external $ext_sub"
    report_add "sub_${label}" "external ${sub_ext}"
  else
    _SUB_EMBED_PATH="$sub_path"
    note "[Subs] Prepared $label → $sub_path"
    report_add "sub_${label}" "embedded (${sub_ext})"
  fi
}

# _ext_sub_codec_from_ext — Map a subtitle file extension to an ffmpeg codec name.
# Args: $1 — file extension WITHOUT leading dot (case-insensitive)
# Stdout: codec name suitable for codec comparisons (e.g. "subrip", "ass", "webvtt")
_ext_sub_codec_from_ext(){
  case "${1,,}" in
    srt) echo "subrip"             ;;
    ass) echo "ass"                ;;
    ssa) echo "ssa"                ;;
    vtt) echo "webvtt"             ;;
    sup) echo "hdmv_pgs_subtitle"  ;;
    idx) echo "dvd_subtitle"       ;;
    *)   echo "unknown"            ;;
  esac
}

# _norm_lang_code — Normalize a 2-letter ISO 639-1 language code to its ISO 639-2/T equivalent.
# If the code is already 3 letters or not recognized, it is returned unchanged.
# Only covers the most common subtitle languages.
_norm_lang_code(){
  case "${1,,}" in
    en) echo "eng" ;; es) echo "spa" ;; fr) echo "fra" ;; de) echo "deu" ;;
    ja) echo "jpn" ;; ko) echo "kor" ;; zh) echo "zho" ;; it) echo "ita" ;;
    pt) echo "por" ;; ru) echo "rus" ;; ar) echo "ara" ;; nl) echo "nld" ;;
    pl) echo "pol" ;; sv) echo "swe" ;; da) echo "dan" ;; fi) echo "fin" ;;
    no) echo "nor" ;; tr) echo "tur" ;; cs) echo "ces" ;; hu) echo "hun" ;;
    ro) echo "ron" ;; el) echo "ell" ;; he) echo "heb" ;; vi) echo "vie" ;;
    th) echo "tha" ;; id) echo "ind" ;; uk) echo "ukr" ;; sk) echo "slk" ;;
    *) echo "${1,,}" ;;
  esac
}

# _parse_ext_sub_filename — Extract language code and type from a subtitle sidecar filename.
#
# Filename convention: {stem}[.qualifier...].ext
# Qualifiers are the dot-separated segments between the source stem and the extension.
# Segment classification (case-insensitive):
#   forced|signs|foreign  → type = forced
#   sdh|hi|hearing|cc     → type = sdh
#   2-3 letter alpha      → language code (first match wins)
#   anything else         → ignored
#
# Examples:
#   movie.srt             → lang=TAG_LANGUAGE_DEFAULT, type=full
#   movie.en.srt          → lang=en,  type=full
#   movie.forced.en.srt   → lang=en,  type=forced
#   movie.en.sdh.srt      → lang=en,  type=sdh
#
# Args:    $1 — source file stem (basename without extension, may contain dots)
#          $2 — subtitle filename (basename with extension)
# Stdout:  lang TAB type
_parse_ext_sub_filename(){
  local stem="$1" fname="$2"
  # Strip the last extension to get the bare name (e.g. "movie.forced.en.srt" → "movie.forced.en")
  local bare="${fname%.*}"
  # Remove the source stem prefix, then strip any leading dot
  local suffix="${bare#"$stem"}"
  suffix="${suffix#.}"

  if [[ -z "$suffix" ]]; then
    # No qualifiers: base match only (e.g. "movie.srt")
    printf '%s\t%s\n' "$TAG_LANGUAGE_DEFAULT" "full"
    return 0
  fi

  local lang="" stype="full"
  local seg
  # Iterate dot-delimited segments; append trailing dot so the last segment is read
  while IFS= read -r -d '.' seg; do
    [[ -z "$seg" ]] && continue
    seg="${seg,,}"
    case "$seg" in
      forced|signs|foreign) stype="forced" ;;
      sdh|hi|hearing|cc)    stype="sdh"    ;;
      *)
        # Accept the first 2-3 letter purely alphabetic segment as language code
        # Normalize 2-letter ISO 639-1 codes to 3-letter ISO 639-2/T codes
        if [[ -z "$lang" ]] && [[ "$seg" =~ ^[a-z]{2,3}$ ]]; then
          lang="$(_norm_lang_code "$seg")"
        fi
        ;;
    esac
  done < <(printf '%s.' "$suffix")

  [[ -z "$lang" ]] && lang="$TAG_LANGUAGE_DEFAULT"
  printf '%s\t%s\n' "$lang" "$stype"
}

# discover_external_subtitles — Scan for sidecar subtitle files alongside the source.
#
# Searches EXT_SUB_DIR (default: directory of SRC_ABS) for files whose basename
# starts with the source stem followed by a dot and ends with a subtitle extension.
# Supported extensions: .srt .ass .ssa .vtt .sup .idx (.idx requires partner .sub)
#
# Skipped when SKIP_SUBS=1 or EXT_SUB_ENABLED=0.
#
# Sets: EXT_SUB_PATHS[], EXT_SUB_LANGS[], EXT_SUB_TYPES[], EXT_SUB_CODECS[]
# Globals: SRC_ABS (read), EXT_SUB_ENABLED (read), EXT_SUB_DIR (read),
#          TAG_LANGUAGE_DEFAULT (read), SKIP_SUBS (read)
discover_external_subtitles(){
  EXT_SUB_PATHS=()
  EXT_SUB_LANGS=()
  EXT_SUB_TYPES=()
  EXT_SUB_CODECS=()

  if (( SKIP_SUBS )) || (( ! EXT_SUB_ENABLED )); then
    return 0
  fi

  local search_dir
  if [[ -n "${EXT_SUB_DIR:-}" ]]; then
    search_dir="$EXT_SUB_DIR"
  else
    search_dir="$(dirname -- "$SRC_ABS")"
  fi

  if [[ ! -d "$search_dir" ]]; then
    warn "[Subs] External subtitle search directory not found: $search_dir"
    return 0
  fi

  local src_stem
  src_stem="$(basename -- "${SRC_ABS%.*}")"

  # Process each supported extension in priority order
  local -a sub_exts=( srt ass ssa vtt sup idx )
  local ext fpath fname parsed lang stype codec

  for ext in "${sub_exts[@]}"; do
    while IFS= read -r fpath; do
      [[ -z "$fpath" || ! -f "$fpath" ]] && continue

      # .idx requires a partner .sub file to form a valid VobSub pair
      if [[ "$ext" == "idx" ]]; then
        [[ -f "${fpath%.idx}.sub" ]] || continue
      fi

      fname="$(basename -- "$fpath")"
      parsed="$(_parse_ext_sub_filename "$src_stem" "$fname")"
      IFS=$'\t' read -r lang stype <<< "$parsed"
      codec="$(_ext_sub_codec_from_ext "$ext")"

      EXT_SUB_PATHS+=("$fpath")
      EXT_SUB_LANGS+=("$lang")
      EXT_SUB_TYPES+=("$stype")
      EXT_SUB_CODECS+=("$codec")

      note "[Subs] External subtitle found: $fname [$lang] ($stype)"
    done < <(find "$search_dir" -maxdepth 1 \
      \( -name "${src_stem}.${ext}" -o -name "${src_stem}.*.${ext}" \) \
      -print 2>/dev/null | sort)
  done

  local n="${#EXT_SUB_PATHS[@]}"
  if (( n > 0 )); then
    note "[Subs] ${n} external subtitle file(s) discovered alongside source"
    report_add "ext_subs_found" "$n"
  fi
}

# merge_subtitle_sources — Build unified subtitle stream list from embedded + external.
#
# Combines all embedded subtitle streams (from cached ffprobe metadata) with all
# discovered external subtitle files into ALL_SUB_SOURCES[], ALL_SUB_LANGS[],
# ALL_SUB_TYPES[], ALL_SUB_CODECS[], and ALL_SUB_TITLES[].
#
# Source format: "embedded:N" for embedded stream index N, "ext:/abs/path" for files.
# All subtitle filtering and planning functions iterate this unified list.
#
# Sets: ALL_SUB_SOURCES[], ALL_SUB_LANGS[], ALL_SUB_TYPES[], ALL_SUB_CODECS[], ALL_SUB_TITLES[]
# Globals: METADATA_CACHE (read), EXT_SUB_PATHS[] (read), TAG_LANGUAGE_DEFAULT (read)
merge_subtitle_sources(){
  ALL_SUB_SOURCES=()
  ALL_SUB_LANGS=()
  ALL_SUB_TYPES=()
  ALL_SUB_CODECS=()
  ALL_SUB_TITLES=()

  # Add embedded subtitle streams first
  local n
  n="$(_sub_count)"
  local i
  for (( i=0; i<n; i++ )); do
    local info codec lang title forced stype
    info="$(_sub_stream_info "$i")"
    IFS=$'\t' read -r codec lang title forced <<< "$info"
    _normalize_codec_lang codec lang

    if (( forced )) || _is_forced_title "$title"; then
      stype="forced"
    elif _is_sdh_title "$title"; then
      stype="sdh"
    else
      stype="full"
    fi

    ALL_SUB_SOURCES+=("embedded:$i")
    ALL_SUB_LANGS+=("$lang")
    ALL_SUB_TYPES+=("$stype")
    ALL_SUB_CODECS+=("$codec")
    ALL_SUB_TITLES+=("${title:-}")
  done

  # Append external subtitle files
  local j
  for (( j=0; j<${#EXT_SUB_PATHS[@]}; j++ )); do
    ALL_SUB_SOURCES+=("ext:${EXT_SUB_PATHS[$j]}")
    ALL_SUB_LANGS+=("${EXT_SUB_LANGS[$j]}")
    ALL_SUB_TYPES+=("${EXT_SUB_TYPES[$j]}")
    ALL_SUB_CODECS+=("${EXT_SUB_CODECS[$j]}")
    ALL_SUB_TITLES+=("")
  done

  local total="${#ALL_SUB_SOURCES[@]}"
  local ext_count="${#EXT_SUB_PATHS[@]}"
  if (( ext_count > 0 )); then
    note "[Subs] Unified subtitle list: $n embedded + $ext_count external = $total source(s)"
  fi
}

# _build_subtitle_keep_list — Subtractive filter for multi-track subtitle mode.
#
# Iterates ALL_SUB_SOURCES[] (unified embedded + external list) and applies filters:
#   1. SUB_LANG_PREF (if non-empty) — only keep tracks whose language matches
#   2. Type classification (forced/SDH/full) against SUB_INCLUDE_* flags
#   3. Container compatibility — bitmap subs in non-MKV containers are skipped
#
# Unlike build_subtitle_plan (which picks ONE of each type), this keeps ALL
# tracks that pass the filters. No scoring, no ranking — just pass/fail.
# The result is capped by SUB_MAX_TRACKS.
#
# Output: space-separated list of 0-based ALL_SUB_SOURCES[] indices on stdout.
#         Empty string if no tracks survive the filter.
# Globals: ALL_SUB_SOURCES[] (read), ALL_SUB_LANGS[] (read), ALL_SUB_TYPES[] (read),
#          ALL_SUB_CODECS[] (read), SUB_LANG_PREF (read), SUB_INCLUDE_FORCED (read),
#          SUB_INCLUDE_FULL (read), SUB_INCLUDE_SDH (read), SUB_MAX_TRACKS (read),
#          MUX_FORMAT (read), OUTPUT_EXT (read)
_build_subtitle_keep_list(){
  local n="${#ALL_SUB_SOURCES[@]}"
  (( n > 0 )) || { echo ""; return 0; }

  local -a kept=()
  local -a dropped_reasons=()

  local i
  for (( i=0; i<n; i++ )); do
    local src="${ALL_SUB_SOURCES[$i]}"
    local codec="${ALL_SUB_CODECS[$i]}"
    local lang="${ALL_SUB_LANGS[$i]}"
    local stype="${ALL_SUB_TYPES[$i]}"

    # Human-readable source label for diagnostic messages
    local src_label
    src_label="$(_source_label "$src")"

    # Filter 1: language
    if [[ -n "${SUB_LANG_PREF:-}" ]]; then
      if [[ ",$SUB_LANG_PREF," != *",$lang,"* ]]; then
        dropped_reasons+=("$src_label: ${codec} [$lang] — language not in SUB_LANG_PREF")
        continue
      fi
    fi

    # Filter 2: type inclusion flags
    case "$stype" in
      forced) if (( ! SUB_INCLUDE_FORCED )); then
                dropped_reasons+=("$src_label: ${codec} [$lang] — forced tracks excluded (SUB_INCLUDE_FORCED=0)")
                continue
              fi ;;
      sdh)    if (( ! SUB_INCLUDE_SDH )); then
                dropped_reasons+=("$src_label: ${codec} [$lang] — SDH tracks excluded (SUB_INCLUDE_SDH=0)")
                continue
              fi ;;
      full)   if (( ! SUB_INCLUDE_FULL )); then
                dropped_reasons+=("$src_label: ${codec} [$lang] — full tracks excluded (SUB_INCLUDE_FULL=0)")
                continue
              fi ;;
    esac

    # Filter 3: container compatibility — bitmap subs can't go into MP4/MOV
    if [[ "$MUX_FORMAT" != "matroska" ]] && ! _is_text_sub_codec "$codec"; then
      dropped_reasons+=("$src_label: ${codec} [$lang] — bitmap subtitle incompatible with ${OUTPUT_EXT} container")
      continue
    fi

    kept+=("$i")
  done

  _log_dropped_tracks "multi-track subs" dropped_reasons

  # Apply SUB_MAX_TRACKS cap
  if (( ${#kept[@]} > SUB_MAX_TRACKS )); then
    log "  [multi-track subs] Capping from ${#kept[@]} to $SUB_MAX_TRACKS tracks (SUB_MAX_TRACKS)"
    kept=("${kept[@]:0:$SUB_MAX_TRACKS}")
  fi

  echo "${kept[*]}"
}

# run_subtitle_pipeline_multi — Multi-track subtitles: filter and defer to mux_final.
#
# Called instead of the single-track pipeline when SUB_MULTI_TRACK=1.
# Iterates ALL_SUB_SOURCES[] (unified embedded + external list), applies
# _build_subtitle_keep_list() filters, and populates SUB_MT_SOURCES[] and
# related arrays that mux_final uses to map subtitle streams from source or
# external files.
#
# Embedded streams are copied directly from source (-c:s copy).
# External text subs are added as separate ffmpeg inputs in mux_final.
#
# Sets: SUB_COPY_FROM_SOURCE, SUB_MT_SOURCES[], SUB_MT_INDICES[],
#       SUB_MT_CODECS[], SUB_MT_LANGS[], SUB_MT_TITLES[], SUB_MT_TYPES[],
#       SRT_FORCED (cleared), SRT_FULL (cleared), SRT_SDH (cleared),
#       SRT_DIRECT_MAP (cleared), DIRECT_SUB_RELIDX (cleared)
# Globals: ALL_SUB_SOURCES[] (read), METADATA_CACHE (read)
run_subtitle_pipeline_multi(){
  local keep_list
  keep_list="$(_build_subtitle_keep_list)"

  if [[ -z "$keep_list" ]]; then
    note "[Subs] Multi-track filter: no subtitle tracks survived filtering."
    SUB_COPY_FROM_SOURCE=0
    return 0
  fi

  # Reset single-track vars (not used in multi-track mode)
  SRT_FORCED=""
  SRT_FULL=""
  SRT_SDH=""
  SRT_FORCED_BURN_PATH=""
  SRT_DIRECT_MAP=0
  DIRECT_SUB_RELIDX=""

  # Populate parallel metadata arrays from the unified ALL_SUB_SOURCES[] list
  SUB_MT_INDICES=()
  SUB_MT_SOURCES=()
  SUB_MT_CODECS=()
  SUB_MT_LANGS=()
  SUB_MT_TITLES=()
  SUB_MT_TYPES=()

  local uidx
  for uidx in $keep_list; do
    local src="${ALL_SUB_SOURCES[$uidx]}"
    local codec="${ALL_SUB_CODECS[$uidx]}"
    local lang="${ALL_SUB_LANGS[$uidx]}"
    local stype="${ALL_SUB_TYPES[$uidx]}"
    local title="${ALL_SUB_TITLES[$uidx]}"

    SUB_MT_SOURCES+=("$src")
    # SUB_MT_INDICES: embedded stream index for mux_final mapping; -1 for external files
    if [[ "$src" == embedded:* ]]; then
      SUB_MT_INDICES+=("${src#embedded:}")
    else
      SUB_MT_INDICES+=(-1)
    fi
    SUB_MT_CODECS+=("$codec")
    SUB_MT_LANGS+=("$lang")
    SUB_MT_TITLES+=("$title")
    SUB_MT_TYPES+=("$stype")
  done

  SUB_COPY_FROM_SOURCE=1

  # Log summary: show all unified sources with ✓/✗ markers
  local n_total n_kept n_dropped
  n_total="${#ALL_SUB_SOURCES[@]}"
  n_kept="${#SUB_MT_SOURCES[@]}"
  n_dropped=$(( n_total - n_kept ))

  say "→ Scanning subtitle streams (multi-track mode):"
  local i
  for (( i=0; i<n_total; i++ )); do
    local _src="${ALL_SUB_SOURCES[$i]}"
    local _c="${ALL_SUB_CODECS[$i]}"
    local _l="${ALL_SUB_LANGS[$i]}"
    local _t="${ALL_SUB_TITLES[$i]}"
    local _stype="${ALL_SUB_TYPES[$i]}"
    local pretty

    if [[ "$_src" == embedded:* ]]; then
      pretty="#${_src#embedded:}: ${_c} [${_l}]"
    else
      pretty="$(basename -- "${_src#ext:}"): ${_c} [${_l}]"
    fi
    [[ -n "$_t" ]]              && pretty="$pretty — $_t"
    [[ "$_stype" == "forced" ]] && pretty="$pretty (forced)"
    [[ "$_stype" == "sdh"    ]] && pretty="$pretty [SDH]"

    # Check if this unified index survived the filter
    local _is_kept=0
    local _k
    for _k in $keep_list; do
      (( _k == i )) && { _is_kept=1; break; }
    done

    if (( _is_kept )); then
      say "  $pretty ✓"
    else
      say "  $pretty ✗"
    fi
  done

  note "[Subs] Multi-track: keeping ${n_kept} of ${n_total} tracks (${n_dropped} filtered out)"
  report_add "sub_mode" "multi-track"
  report_add "sub_multi_track_kept" "$n_kept"
  report_add "sub_multi_track_dropped" "$n_dropped"

  # Report kept tracks
  local track_summary=""
  for (( i=0; i<n_kept; i++ )); do
    local _src="${SUB_MT_SOURCES[$i]}"
    local _codec="${SUB_MT_CODECS[$i]}"
    local _lang="${SUB_MT_LANGS[$i]}"
    local _stype="${SUB_MT_TYPES[$i]}"
    local _label
    if [[ "$_src" == embedded:* ]]; then
      _label="#${_src#embedded:}"
    else
      _label="$(basename -- "${_src#ext:}")"
    fi
    track_summary+="${_label}: ${_codec} [${_lang}] (${_stype})"
    (( i < n_kept - 1 )) && track_summary+=", "
  done
  report_add "sub_kept_tracks" "$track_summary"

  # Note when ASS/SSA tracks will be converted (SUB_PRESERVE_TEXT_FORMAT=0)
  if (( ! SUB_PRESERVE_TEXT_FORMAT )); then
    local _ass_convert_count=0
    for (( i=0; i<n_kept; i++ )); do
      case "${SUB_MT_CODECS[$i]}" in
        ass|ssa) _ass_convert_count=$(( _ass_convert_count + 1 )) ;;
      esac
    done
    if (( _ass_convert_count > 0 )); then
      note "[Subs] Multi-track: ${_ass_convert_count} ASS/SSA track(s) will be converted to SRT (SUB_PRESERVE_TEXT_FORMAT=0)"
      report_add "sub_ass_convert" "$_ass_convert_count"
    fi
  fi

  mark_done "Subtitle filter plan (multi-track, ${n_kept} tracks)"
}

# build_subtitle_plan — Scan, categorize, and prepare subtitle tracks.
#
# Iterates ALL_SUB_SOURCES[] (unified embedded + external list), selects the
# best candidates (up to SUB_MAX_TRACKS), and prepares them via extraction,
# conversion, OCR, or pass-through. Embedded streams use _prepare_subtitle();
# external files use _prepare_ext_subtitle() via _prepare_sub_from_source().
#
# Routes forced subtitles to either the burn-in path (SRT_FORCED_BURN_PATH) or
# embed path (SRT_FORCED) based on SUB_BURN_FORCED. Non-forced subtitles are
# either embedded or exported as external files based on SUB_EXPORT_EXTERNAL.
#
# Falls back to direct-mapping a TEXT subtitle from the embedded stream list
# if no prepared subtitles were produced and at least one SUB_INCLUDE_* flag
# is enabled (embedded-only fallback — external files are handled in main loop).
#
# Sets: SRT_FORCED, SRT_FULL, SRT_SDH, SRT_FORCED_BURN_PATH, SRT_DIRECT_MAP,
#       DIRECT_SUB_RELIDX, EXTERNAL_SRT_PATHS[], and associated *_LANG/*_TITLE vars
# Globals: ALL_SUB_SOURCES[] (read), SUB_* config vars (read)
build_subtitle_plan(){
  if (( SKIP_SUBS )); then
    SRT_FORCED=""; SRT_FULL=""; SRT_SDH=""
    SRT_DIRECT_MAP=0; DIRECT_SUB_RELIDX=""
    return 0
  fi

  # No subtitle sources at all (neither embedded nor external)
  if (( ${#ALL_SUB_SOURCES[@]} == 0 )); then
    note "[Subs] No subtitle streams detected."
    SRT_DIRECT_MAP=0
    return 0
  fi

  # ---- Multi-track mode: filter and defer to mux_final ----
  # When SUB_MULTI_TRACK=1, skip single-track selection entirely.
  # Demote to single-track if the user set overrides that are incompatible.
  if (( SUB_MULTI_TRACK )); then
    if (( SUB_BURN_FORCED )); then
      note "[Subs] SUB_MULTI_TRACK demoted to single-track: --sub-burn-forced is set."
    elif (( SUB_EXPORT_EXTERNAL )); then
      note "[Subs] Multi-track mode: --sub-export-external ignored (all subs embedded via stream-copy)."
      run_subtitle_pipeline_multi
      return $?
    else
      run_subtitle_pipeline_multi
      return $?
    fi
  fi

  # ---- Single-track mode: scan unified list, select one per type, prepare ----

  say "→ Scanning subtitle streams:"
  local i
  for (( i=0; i<${#ALL_SUB_SOURCES[@]}; i++ )); do
    local _src="${ALL_SUB_SOURCES[$i]}"
    local _c="${ALL_SUB_CODECS[$i]}"
    local _l="${ALL_SUB_LANGS[$i]}"
    local _t="${ALL_SUB_TITLES[$i]}"
    local _stype="${ALL_SUB_TYPES[$i]}"
    if [[ "$_src" == embedded:* ]]; then
      say "  #${_src#embedded:}: ${_c} [${_l}]${_t:+ — $_t} (${_stype})"
    else
      say "  $(basename -- "${_src#ext:}"): ${_c} [${_l}] (${_stype})"
    fi
  done

  local forced_uidx="" full_uidx="" sdh_uidx=""

  # Find best candidates from unified list (first match per type wins)
  for (( i=0; i<${#ALL_SUB_SOURCES[@]}; i++ )); do
    local lang="${ALL_SUB_LANGS[$i]}"
    local stype="${ALL_SUB_TYPES[$i]}"

    # Language filter
    if [[ -n "${SUB_LANG_PREF:-}" ]]; then
      [[ ",$SUB_LANG_PREF," == *",$lang,"* ]] || continue
    fi

    case "$stype" in
      forced)
        if (( SUB_INCLUDE_FORCED )) && [[ -z "$forced_uidx" ]]; then
          forced_uidx="$i"
        fi
        ;;
      sdh)
        if (( SUB_INCLUDE_SDH )) && [[ -z "$sdh_uidx" ]]; then
          sdh_uidx="$i"
        fi
        ;;
      full)
        if (( SUB_INCLUDE_FULL )) && [[ -z "$full_uidx" ]]; then
          full_uidx="$i"
        fi
        ;;
    esac
  done

  # Sole-external-sub fallback: if the language filter produced no candidates but there is
  # exactly one external sidecar subtitle and zero embedded subtitle streams, include that
  # subtitle regardless of its language tag. This handles the common case of a sidecar file
  # with no language qualifier in its filename (tagged 'und' by default) that would otherwise
  # be silently dropped by SUB_LANG_PREF. Disable with --no-sub-sole-ext-fallback.
  if [[ -z "$forced_uidx" && -z "$full_uidx" && -z "$sdh_uidx" ]] \
     && (( SUB_SOLE_EXT_FALLBACK )) \
     && (( SUB_INCLUDE_FORCED || SUB_INCLUDE_FULL || SUB_INCLUDE_SDH )); then
    local _emb_count=0 _ext_count=0 _sole_ext_uidx=""
    local _j
    for (( _j=0; _j<${#ALL_SUB_SOURCES[@]}; _j++ )); do
      if [[ "${ALL_SUB_SOURCES[$_j]}" == embedded:* ]]; then
        _emb_count=$(( _emb_count + 1 ))
      else
        _ext_count=$(( _ext_count + 1 ))
        _sole_ext_uidx="$_j"
      fi
    done
    if (( _emb_count == 0 && _ext_count == 1 )); then
      local _sole_stype="${ALL_SUB_TYPES[$_sole_ext_uidx]}"
      local _sole_lang="${ALL_SUB_LANGS[$_sole_ext_uidx]}"
      local _sole_name; _sole_name="$(basename -- "${ALL_SUB_SOURCES[$_sole_ext_uidx]#ext:}")"
      note "[Subs] Sole-external fallback: 1 sidecar, 0 embedded — including $_sole_name [$_sole_lang] (language filter bypassed)."
      case "$_sole_stype" in
        forced) (( SUB_INCLUDE_FORCED )) && forced_uidx="$_sole_ext_uidx" ;;
        sdh)    (( SUB_INCLUDE_SDH    )) && sdh_uidx="$_sole_ext_uidx"    ;;
        full)   (( SUB_INCLUDE_FULL   )) && full_uidx="$_sole_ext_uidx"   ;;
      esac
    fi
  fi

  # Prepare selected subtitles (up to SUB_MAX_TRACKS)
  local sub_path pick_count=0
  if [[ -n "$forced_uidx" ]]; then
    sub_path="$(_prepare_sub_from_source "${ALL_SUB_SOURCES[$forced_uidx]}")"
    if [[ -z "$sub_path" ]]; then
      : # preparation failed; skip silently
    elif (( SUB_BURN_FORCED )); then
      # Route forced sub to burn path (video pipeline will handle it)
      SRT_FORCED_LANG="${ALL_SUB_LANGS[$forced_uidx]}"
      SRT_FORCED_TITLE="Forced"
      SRT_FORCED_BURN_PATH="$sub_path"
      note "[Subs] Prepared Forced for burn-in → $SRT_FORCED_BURN_PATH"
      report_add "sub_forced" "burn-in"
    else
      SRT_FORCED_LANG="${ALL_SUB_LANGS[$forced_uidx]}"
      SRT_FORCED_TITLE="Forced"
      SRT_FORCED="$sub_path"
      pick_count=$(( pick_count + 1 ))
      note "[Subs] Prepared Forced → $SRT_FORCED"
      report_add "sub_forced" "embedded"
    fi
  fi
  if [[ -n "$full_uidx" && $pick_count -lt $SUB_MAX_TRACKS ]]; then
    sub_path="$(_prepare_sub_from_source "${ALL_SUB_SOURCES[$full_uidx]}")"
    if [[ -n "$sub_path" ]]; then
      SRT_FULL_LANG="${ALL_SUB_LANGS[$full_uidx]}"
      SRT_FULL_TITLE="${ALL_SUB_TITLES[$full_uidx]:-Full}"
      _export_or_embed_sub "$sub_path" "full"
      if [[ -n "$_SUB_EMBED_PATH" ]]; then
        SRT_FULL="$_SUB_EMBED_PATH"
        pick_count=$(( pick_count + 1 ))
      fi
    fi
  fi
  if [[ -n "$sdh_uidx" && $pick_count -lt $SUB_MAX_TRACKS ]]; then
    sub_path="$(_prepare_sub_from_source "${ALL_SUB_SOURCES[$sdh_uidx]}")"
    if [[ -n "$sub_path" ]]; then
      SRT_SDH_LANG="${ALL_SUB_LANGS[$sdh_uidx]}"
      SRT_SDH_TITLE="SDH"
      _export_or_embed_sub "$sub_path" "sdh"
      if [[ -n "$_SUB_EMBED_PATH" ]]; then
        SRT_SDH="$_SUB_EMBED_PATH"
        pick_count=$(( pick_count + 1 ))
      fi
    fi
  fi

  # Fallback: try direct-mapping a TEXT subtitle from embedded streams if no SRTs prepared.
  # Only attempt when at least one SUB_INCLUDE_* flag is enabled and all preparation failed.
  # External files are always handled via the main selection loop above (not the fallback).
  if [[ -z "$SRT_FORCED" && -z "$SRT_FULL" && -z "$SRT_SDH" ]] \
     && (( SUB_INCLUDE_FORCED || SUB_INCLUDE_FULL || SUB_INCLUDE_SDH )); then
    DIRECT_SUB_RELIDX="$(_pick_direct_text_sub_relidx)"
    if [[ -n "$DIRECT_SUB_RELIDX" ]]; then
      SRT_DIRECT_MAP=1
      note "[Subs] No external SRTs prepared — enabling direct-map of TEXT subtitle stream #$DIRECT_SUB_RELIDX."
    else
      SRT_DIRECT_MAP=0
      note "[Subs] No usable subtitles prepared. Proceeding without subtitles."
    fi
  else
    SRT_DIRECT_MAP=0
  fi
}

# ===== Section 29: Final mux ==================================================================
# mux_final — Assemble all prepared streams into the final output container.
#
# Combines video (from source copy, DV pre-wrap MP4, or encoded ES/MKV),
# primary audio, optional stereo fallback, and subtitle tracks into a single
# MP4/MOV/MKV file. Handles:
#   - Stream mapping with correct input indices
#   - Codec assignment (copy for A/V, mov_text/srt for subs)
#   - Language/title/disposition metadata tagging per stream
#   - DV container signaling (-strict unofficial, -tag:v dvh1)
#   - Chapter and metadata stripping policies
#   - MP4 faststart optimization
#   - Post-mux validation via ffprobe
#
# Dies on: missing video stream, ffmpeg mux failure, corrupt output.
# Globals: numerous — see individual stream sections below.
mux_final() {
  log "→ Muxing final ${OUTPUT_EXT^^} with ffmpeg → $TMP_OUT"

  if (( DRY_RUN )); then
    : > "$TMP_OUT" 2>/dev/null || true
    mark_done "Mux final (dry-run)"
    return 0
  fi

  # Sanity check: workdir must still exist for stream files to be valid
  if [[ ! -d "$WORKDIR" ]]; then
    die 42 "Workdir disappeared before mux — cannot assemble output. Temp files lost."
  fi

  local -a ff_in=()
  local -a ff_map=()
  local -a ff_codec=()

  ff_in+=( "${FFMPEG_FLAGS[@]}" )

  local next_idx=0
  local vid_idx="" a_primary_idx="" a_stereo_idx=""
  local s_forced_idx="" s_full_idx="" s_sdh_idx=""
  local forced_present=0 full_present=0 sdh_present=0
  local src_sub_idx=""
  local _src_input_idx=""   # shared index when source is used as ffmpeg input
  # Parallel arrays for deduplicating external subtitle file inputs in multi-track mode
  local -a _ext_sub_paths=()   # unique external subtitle file paths (insertion order)
  local -a _ext_sub_idxs=()    # ffmpeg -i index for each unique external subtitle path

  # Validate and add video stream
  if (( SKIP_VIDEO )); then
    die 42 "Video was skipped but output container requires a video stream."
  fi
  
  if (( VIDEO_COPY_FROM_SOURCE )); then
    # Map video directly from source to preserve container-level metadata
    # (DOVI configuration record, displaymatrix, etc.)
    ff_in+=( -i "$SRC_ABS" )
    _src_input_idx=$next_idx
    vid_idx=$next_idx
    next_idx=$(( next_idx + 1 ))
  elif [[ -n "${V_DV_MP4:-}" && -s "$V_DV_MP4" ]]; then
    # Prefer DV pre-wrapped MP4 over raw ES — it carries the dvcC/dvvC box
    # that ffmpeg will copy through to the final output container.
    note "Using DV pre-wrapped MP4 as video input (dvcC box present)."
    ff_in+=( -i "$V_DV_MP4" )
    vid_idx=$next_idx
    next_idx=$(( next_idx + 1 ))
  elif [[ -n "${V_MIXED:-}" && -s "$V_MIXED" ]]; then
    # Validate video before muxing
    if ! ffprobe -v error "$V_MIXED" >/dev/null 2>&1; then
      die 42 "Encoded video exists but is invalid/corrupt"
    fi
    ff_in+=( -i "$V_MIXED" )
    vid_idx=$next_idx
    next_idx=$(( next_idx + 1 ))
  else
    die 42 "No encoded video stream found."
  fi

  # Add audio streams — multi-track or single-track
  if (( ! SKIP_AUDIO )) && (( HAS_AUDIO )) && (( AUDIO_COPY_FROM_SOURCE )); then
    # Multi-track: map audio streams directly from source.
    # Reuse the source input if VIDEO_COPY_FROM_SOURCE already added it.
    if [[ -z "$_src_input_idx" ]]; then
      ff_in+=( -i "$SRC_ABS" )
      _src_input_idx=$next_idx
      next_idx=$(( next_idx + 1 ))
    fi
    # Mapping and tagging handled below in the multi-track section.
  else
    # Single-track: use extracted/transcoded intermediate files
    if (( ! SKIP_AUDIO )) && (( HAS_AUDIO )) && [[ -n "${A_PRIMARY:-}" && -s "$A_PRIMARY" ]]; then
      ff_in+=( -i "$A_PRIMARY" )
      a_primary_idx=$next_idx
      next_idx=$(( next_idx + 1 ))
    fi
    
    if (( ! SKIP_AUDIO )) && [[ -n "${AAC_STEREO:-}" && -s "$AAC_STEREO" ]]; then
      ff_in+=( -i "$AAC_STEREO" )
      a_stereo_idx=$next_idx
      next_idx=$(( next_idx + 1 ))
    fi
  fi

  # Add subtitle streams — multi-track or single-track
  if (( ! SKIP_SUBS )) && (( SUB_COPY_FROM_SOURCE )) && (( ${#SUB_MT_SOURCES[@]} > 0 )); then
    # Multi-track mode: embedded streams reuse the shared source input;
    # external files each get their own -i input (deduplicated by path).

    # Determine if any embedded subtitle streams are in the kept list
    local _has_emb_mt_subs=0
    local _chk_src
    for _chk_src in "${SUB_MT_SOURCES[@]}"; do
      [[ "$_chk_src" == embedded:* ]] && { _has_emb_mt_subs=1; break; }
    done

    # Add source as input if needed (shared with video/audio)
    if (( _has_emb_mt_subs )) && [[ -z "$_src_input_idx" ]]; then
      ff_in+=( -i "$SRC_ABS" )
      _src_input_idx=$next_idx
      next_idx=$(( next_idx + 1 ))
    fi

    # Add unique external subtitle files as separate ffmpeg inputs
    local _mt_src
    for _mt_src in "${SUB_MT_SOURCES[@]}"; do
      if [[ "$_mt_src" == ext:* ]]; then
        local _ep="${_mt_src#ext:}"
        # Check whether this path has already been registered
        local _ep_found=0 _epk
        for (( _epk=0; _epk<${#_ext_sub_paths[@]}; _epk++ )); do
          [[ "${_ext_sub_paths[$_epk]}" == "$_ep" ]] && { _ep_found=1; break; }
        done
        if (( ! _ep_found )); then
          ff_in+=( -i "$_ep" )
          _ext_sub_paths+=("$_ep")
          _ext_sub_idxs+=("$next_idx")
          next_idx=$(( next_idx + 1 ))
        fi
      fi
    done
    # Stream mapping and codec tagging handled below in the multi-track subtitle section.
  elif (( ! SKIP_SUBS )); then
    # Single-track: use prepared subtitle files
    if [[ -n "${SRT_FORCED:-}" && -s "$SRT_FORCED" ]]; then
      ff_in+=( -i "$SRT_FORCED" )
      s_forced_idx=$next_idx
      next_idx=$(( next_idx + 1 ))
      forced_present=1
    fi

    if [[ -n "${SRT_FULL:-}" && -s "$SRT_FULL" ]]; then
      ff_in+=( -i "$SRT_FULL" )
      s_full_idx=$next_idx
      next_idx=$(( next_idx + 1 ))
      full_present=1
    fi

    if [[ -n "${SRT_SDH:-}" && -s "$SRT_SDH" ]]; then
      ff_in+=( -i "$SRT_SDH" )
      s_sdh_idx=$next_idx
      next_idx=$(( next_idx + 1 ))
      sdh_present=1
    fi
  fi

  # Add source for direct subtitle mapping if needed (single-track fallback only)
  if (( ! SKIP_SUBS )) && (( ! SUB_COPY_FROM_SOURCE )) && (( SRT_DIRECT_MAP )) && [[ -n "${DIRECT_SUB_RELIDX:-}" ]]; then
    if [[ -z "$_src_input_idx" ]]; then
      ff_in+=( -i "$SRC_ABS" )
      _src_input_idx=$next_idx
      next_idx=$(( next_idx + 1 ))
    fi
    src_sub_idx="$_src_input_idx"
  fi

  # Build stream mapping
  # When VIDEO_COPY_FROM_SOURCE, source is the first input; -map N:v:0
  # selects only the video stream, excluding audio/subs/data tracks.
  ff_map+=( -map "$vid_idx":v:0 )

  # Audio mapping: multi-track from source or single-track from files
  if (( AUDIO_COPY_FROM_SOURCE )) && [[ -n "$_src_input_idx" ]]; then
    local _mt_i
    for _mt_i in "${AUDIO_MT_INDICES[@]}"; do
      ff_map+=( -map "${_src_input_idx}:a:${_mt_i}" )
    done
  else
    [[ -n "$a_primary_idx" ]] && ff_map+=( -map "$a_primary_idx":a:0 )
    [[ -n "$a_stereo_idx"  ]] && ff_map+=( -map "$a_stereo_idx":a:0 )
  fi

  # Subtitle mapping: multi-track (mixed embedded/external) or single-track from files
  if (( SUB_COPY_FROM_SOURCE )) && (( ${#SUB_MT_SOURCES[@]} > 0 )); then
    local _mt_si
    for (( _mt_si=0; _mt_si<${#SUB_MT_SOURCES[@]}; _mt_si++ )); do
      local _mt_src="${SUB_MT_SOURCES[$_mt_si]}"
      if [[ "$_mt_src" == embedded:* ]]; then
        # _emb_idx is the 0-based subtitle-stream-relative index as assigned by
        # merge_subtitle_sources (which iterates 0..sub_count-1).  ffmpeg's :s:N
        # selector also uses the subtitle-relative index, so no remapping is needed.
        local _emb_idx="${_mt_src#embedded:}"
        ff_map+=( -map "${_src_input_idx}:s:${_emb_idx}" )
      else
        # External file: find the pre-registered ffmpeg input index
        local _ep="${_mt_src#ext:}"
        local _found_eidx="" _epk
        for (( _epk=0; _epk<${#_ext_sub_paths[@]}; _epk++ )); do
          [[ "${_ext_sub_paths[$_epk]}" == "$_ep" ]] && { _found_eidx="${_ext_sub_idxs[$_epk]}"; break; }
        done
        ff_map+=( -map "${_found_eidx}:s:0" )
      fi
    done
  else
    (( forced_present )) && ff_map+=( -map "$s_forced_idx":s:0 )
    (( full_present   )) && ff_map+=( -map "$s_full_idx":s:0 )
    (( sdh_present    )) && ff_map+=( -map "$s_sdh_idx":s:0 )

    if [[ -n "$src_sub_idx" ]]; then
      ff_map+=( -map "$src_sub_idx":s:"$DIRECT_SUB_RELIDX"? )
    fi
  fi

  # Codec settings: copy everything; subtitle codecs are assigned per-stream below
  ff_codec+=( -c copy )

  # _sub_codec_for_file — Determine the ffmpeg subtitle codec flag for a prepared file.
  # ASS/SSA files in MKV are stream-copied to preserve styling; all others convert.
  # Args: $1 — path to prepared subtitle file
  # Stdout: codec name suitable for -c:s:N (e.g., "copy", "srt", "mov_text")
  _sub_codec_for_file(){
    local ext="${1##*.}"
    if [[ "$MUX_FORMAT" == "matroska" ]]; then
      case "$ext" in
        ass|ssa) echo "copy" ;;   # preserve native ASS/SSA in MKV
        sup)     echo "copy" ;;   # preserve PGS bitmap in MKV
        *)       echo "srt" ;;
      esac
    else
      echo "mov_text"
    fi
  }

  # Subtitle metadata: language, title, disposition, and per-stream codec tagging.
  # Output subtitle index tracks which output stream we're tagging.
  local -i out_s_idx=0
  if (( SUB_COPY_FROM_SOURCE )) && (( ${#SUB_MT_SOURCES[@]} > 0 )); then
    # Multi-track: tag each kept subtitle stream copied from source
    local _mt_si
    for (( _mt_si=0; _mt_si<${#SUB_MT_INDICES[@]}; _mt_si++ )); do
      local _mt_slang="${SUB_MT_LANGS[$_mt_si]}"
      local _mt_stitle="${SUB_MT_TITLES[$_mt_si]}"
      local _mt_stype="${SUB_MT_TYPES[$_mt_si]}"

      # Codec: copy by default; convert ASS/SSA when SUB_PRESERVE_TEXT_FORMAT=0
      # or when the container can't carry ASS (MP4/MOV).
      local _mt_scodec="${SUB_MT_CODECS[$_mt_si]}"
      case "$_mt_scodec" in
        ass|ssa)
          if (( SUB_PRESERVE_TEXT_FORMAT )) && [[ "$MUX_FORMAT" == "matroska" ]]; then
            ff_codec+=( "-c:s:${out_s_idx}" copy )
          elif [[ "$MUX_FORMAT" == "matroska" ]]; then
            ff_codec+=( "-c:s:${out_s_idx}" srt )
          else
            ff_codec+=( "-c:s:${out_s_idx}" mov_text )
          fi
          ;;
        *)
          ff_codec+=( "-c:s:${out_s_idx}" copy )
          ;;
      esac

      # Language
      [[ -n "$_mt_slang" ]] && ff_codec+=( "-metadata:s:s:${out_s_idx}" "language=$_mt_slang" )

      # Title: preserve source title if present, otherwise use type label
      if [[ -n "$_mt_stitle" ]]; then
        ff_codec+=( "-metadata:s:s:${out_s_idx}" "title=$_mt_stitle" )
      else
        # Capitalize first letter: forced→Forced, full→Full, sdh→SDH
        local _mt_type_label
        case "$_mt_stype" in
          sdh) _mt_type_label="SDH" ;;
          *)   _mt_type_label="${_mt_stype^}" ;;
        esac
        ff_codec+=( "-metadata:s:s:${out_s_idx}" "title=$_mt_type_label" )
      fi

      # Disposition from type
      case "$_mt_stype" in
        forced) ff_codec+=( "-disposition:s:${out_s_idx}" forced ) ;;
        sdh)    ff_codec+=( "-disposition:s:${out_s_idx}" hearing_impaired ) ;;
        *)      ff_codec+=( "-disposition:s:${out_s_idx}" 0 ) ;;
      esac

      out_s_idx=$(( out_s_idx + 1 ))
    done
  else
    # Single-track: hardcoded forced/full/sdh slots
    if (( forced_present )); then
      ff_codec+=( "-c:s:${out_s_idx}" "$(_sub_codec_for_file "$SRT_FORCED")" )
      [[ -n "$SRT_FORCED_LANG" ]]  && ff_codec+=( "-metadata:s:s:${out_s_idx}" "language=$SRT_FORCED_LANG" )
      [[ -n "$SRT_FORCED_TITLE" ]] && ff_codec+=( "-metadata:s:s:${out_s_idx}" "title=$SRT_FORCED_TITLE" )
      ff_codec+=( "-disposition:s:${out_s_idx}" forced )
      out_s_idx=$(( out_s_idx + 1 ))
    fi
    if (( full_present )); then
      ff_codec+=( "-c:s:${out_s_idx}" "$(_sub_codec_for_file "$SRT_FULL")" )
      [[ -n "$SRT_FULL_LANG" ]]  && ff_codec+=( "-metadata:s:s:${out_s_idx}" "language=$SRT_FULL_LANG" )
      [[ -n "$SRT_FULL_TITLE" ]] && ff_codec+=( "-metadata:s:s:${out_s_idx}" "title=$SRT_FULL_TITLE" )
      ff_codec+=( "-disposition:s:${out_s_idx}" 0 )
      out_s_idx=$(( out_s_idx + 1 ))
    fi
    if (( sdh_present )); then
      ff_codec+=( "-c:s:${out_s_idx}" "$(_sub_codec_for_file "$SRT_SDH")" )
      [[ -n "$SRT_SDH_LANG" ]]  && ff_codec+=( "-metadata:s:s:${out_s_idx}" "language=$SRT_SDH_LANG" )
      [[ -n "$SRT_SDH_TITLE" ]] && ff_codec+=( "-metadata:s:s:${out_s_idx}" "title=$SRT_SDH_TITLE" )
      ff_codec+=( "-disposition:s:${out_s_idx}" hearing_impaired )
      out_s_idx=$(( out_s_idx + 1 ))
    fi
    if [[ -n "$src_sub_idx" ]]; then
      # Direct-mapped subtitle from source: check if we should preserve native format
      local _dm_codec
      _dm_codec="$(_sp_sub_field "$DIRECT_SUB_RELIDX" codec_name)"; _dm_codec="${_dm_codec,,}"
      if (( SUB_PRESERVE_TEXT_FORMAT )) && [[ "$MUX_FORMAT" == "matroska" ]]; then
        case "$_dm_codec" in
          ass|ssa) ff_codec+=( "-c:s:${out_s_idx}" copy ) ;;
          *)       ff_codec+=( "-c:s:${out_s_idx}" srt ) ;;
        esac
      elif [[ "$MUX_FORMAT" == "matroska" ]]; then
        ff_codec+=( "-c:s:${out_s_idx}" srt )
      else
        ff_codec+=( "-c:s:${out_s_idx}" mov_text )
      fi
      out_s_idx=$(( out_s_idx + 1 ))
    fi
  fi

  # Audio metadata: language, title, and disposition tagging.
  # Output audio index tracks which output stream we're tagging.
  local -i out_a_idx=0
  if (( AUDIO_COPY_FROM_SOURCE )) && (( ${#AUDIO_MT_INDICES[@]} > 0 )); then
    # Multi-track: tag each kept audio stream copied from source
    local _mt_i
    for (( _mt_i=0; _mt_i<${#AUDIO_MT_INDICES[@]}; _mt_i++ )); do
      local _mt_lang="${AUDIO_MT_LANGS[$_mt_i]}"
      local _mt_codec="${AUDIO_MT_CODECS[$_mt_i]}"
      local _mt_ch="${AUDIO_MT_CHANNELS[$_mt_i]}"
      local _mt_title="${AUDIO_MT_TITLES[$_mt_i]}"

      [[ -n "$_mt_lang" ]] && ff_codec+=( "-metadata:s:a:${out_a_idx}" "language=$_mt_lang" )

      if (( INCLUDE_AUDIO_TITLES )); then
        local _mt_desc
        _mt_desc="$(_audio_descriptive_title "$_mt_codec" "$_mt_ch")"
        ff_codec+=( "-metadata:s:a:${out_a_idx}" "title=$_mt_desc" )
      elif [[ -n "$_mt_title" ]]; then
        ff_codec+=( "-metadata:s:a:${out_a_idx}" "title=$_mt_title" )
      fi

      # First track gets default disposition; rest get none
      if (( out_a_idx == 0 )); then
        ff_codec+=( "-disposition:a:${out_a_idx}" default )
      else
        ff_codec+=( "-disposition:a:${out_a_idx}" 0 )
      fi

      out_a_idx=$(( out_a_idx + 1 ))
    done
  else
    # Single-track: primary + optional stereo fallback
    if [[ -n "$a_primary_idx" ]]; then
      [[ -n "${A_PRIMARY_LANG:-}" ]]  && ff_codec+=( "-metadata:s:a:${out_a_idx}" "language=$A_PRIMARY_LANG" )
      if (( INCLUDE_AUDIO_TITLES )) && [[ -n "${A_PRIMARY_CODEC:-}" ]]; then
        local _desc_title
        _desc_title="$(_audio_descriptive_title "$A_PRIMARY_CODEC" "${A_PRIMARY_CHANNELS:-0}")"
        ff_codec+=( "-metadata:s:a:${out_a_idx}" "title=$_desc_title" )
      elif [[ -n "${A_PRIMARY_TITLE:-}" ]]; then
        ff_codec+=( "-metadata:s:a:${out_a_idx}" "title=$A_PRIMARY_TITLE" )
      fi
      ff_codec+=( "-disposition:a:${out_a_idx}" default )
      out_a_idx=$(( out_a_idx + 1 ))
    fi
    if [[ -n "$a_stereo_idx" ]]; then
      [[ -n "${A_STEREO_LANG:-}" ]] && ff_codec+=( "-metadata:s:a:${out_a_idx}" "language=$A_STEREO_LANG" )
      if (( INCLUDE_AUDIO_TITLES )); then
        ff_codec+=( "-metadata:s:a:${out_a_idx}" "title=$(_audio_descriptive_title aac 2)" )
      else
        ff_codec+=( "-metadata:s:a:${out_a_idx}" "title=Stereo" )
      fi
      ff_codec+=( "-disposition:a:${out_a_idx}" 0 )
      out_a_idx=$(( out_a_idx + 1 ))
    fi
  fi

  # MP4/MOV optimization
  if [[ "$MUX_FORMAT" != "matroska" ]]; then
    ff_codec+=( -movflags +faststart )
  fi

  # Dolby Vision container signalling for MP4/MOV.
  # ffmpeg refuses to write the DOVI configuration record (dvcC/dvvC MP4 box)
  # without -strict unofficial. Without this box, players cannot identify the
  # stream as Dolby Vision even when RPU NAL units are present in the bitstream.
  # -tag:v dvh1 sets the codec tag required by Apple devices (Apple TV, iPhone,
  # iPad) — Apple's player ignores dvhe/hev1 tagged DV streams.
  if (( OUTPUT_HAS_DV )) && [[ "$MUX_FORMAT" != "matroska" ]]; then
    ff_codec+=( -strict unofficial -tag:v dvh1 )
    note "Adding DV container signalling: -strict unofficial -tag:v dvh1"
    report_add "dv_mux_flags" "strict unofficial + dvh1 tag"
  fi

  # Chapter handling
  if (( ! KEEP_CHAPTERS )); then
    ff_codec+=( -map_chapters -1 )
    note "Stripping chapter markers from output."
    report_add "chapters" "stripped"
  else
    report_add "chapters" "preserved"
  fi

  # Metadata stripping
  if (( STRIP_METADATA )); then
    ff_codec+=( -map_metadata -1 )
    note "Stripping non-essential metadata from output."
    report_add "metadata" "stripped"
  else
    report_add "metadata" "preserved"
  fi

  # Profile comment metadata (tagline identifying the encode profile).
  # Applied after -map_metadata so it survives STRIP_METADATA — this is our
  # metadata, not inherited source junk.
  if (( PROFILE_COMMENT )) && [[ -n "${PROFILE_NAME:-}" ]]; then
    local _pcomment
    _pcomment="$(_profile_comment)"
    if [[ -n "$_pcomment" ]]; then
      ff_codec+=( -metadata "comment=$_pcomment" )
      report_add "comment" "$_pcomment"
    fi
  fi

  # Execute final mux
  ffmpeg "${ff_in[@]}" "${ff_map[@]}" "${ff_codec[@]}" -f "$MUX_FORMAT" "$TMP_OUT" 2>"$WORKDIR/mux.err" &
  local mux_pid=$!
  spinner "$mux_pid" "Muxing final ${OUTPUT_EXT^^}"
  if ! wait "$mux_pid" 2>/dev/null; then
    _check_disk_full "$WORKDIR/mux.err"
    die 41 "ffmpeg final mux failed. See: $WORKDIR/mux.err"
  fi

  # Validate muxed output
  _validate_media_file "$TMP_OUT" "Final mux"

  mark_done "Mux final ${OUTPUT_EXT}"
}

# ===== Section 30: Main =======================================================================
main() {
  say "=== ${APP_NAME} v${VERSION} — CLI: ${CLI_NAME}"
  say "=== Input      : $SRC_ABS"
  say "=== Output     : $OUT"
  say "=== Workdir    : $WORKDIR"
  say "=== Defaults   : CRF=$CRF_VALUE  StereoBitrate=$STEREO_BITRATE  Preset=$PRESET_VALUE"
  [[ -n "${PROFILE_NAME:-}" ]] && say "=== Profile    : $PROFILE_NAME"

  (( DRY_RUN )) && note "DRY-RUN is ON"
  [[ ${#MUXM_CONFIG_LOADED[@]} -gt 0 ]] && note "Loaded config: ${MUXM_CONFIG_LOADED[*]}"
  (( SKIP_VIDEO )) && note "[Quick Test] Video processing disabled (--skip-video)"
  (( SKIP_AUDIO )) && note "[Quick Test] Audio processing disabled (--skip-audio)"
  (( SKIP_SUBS  )) && note "[Quick Test] Subtitle processing disabled (--skip-subs)"

  # Cache metadata once for all operations
  cache_stream_metadata

  # Smart disk space preflight — runs here so METADATA_CACHE is available for estimation
  disk_free_warn

  # Validate source contains at least one video stream
  _has_stream video || die 12 "Source file contains no video streams"

  # Discover external subtitle files and build unified stream list
  discover_external_subtitles
  merge_subtitle_sources

  # Skip-if-ideal: check early and exit if source is already compliant
  if (( SKIP_IF_IDEAL )); then
    if check_skip_if_ideal; then
      # Source is ideal — write report and exit clean
      write_json_report
      if (( ! DRY_RUN )); then
        # Determine if a remux is needed (metadata stamping or stream filtering)
        local _sii_needs_remux=0
        (( INCLUDE_AUDIO_TITLES && ${#SII_AUDIO_INDICES[@]} > 0 )) && _sii_needs_remux=1
        (( PROFILE_COMMENT )) && [[ -n "${PROFILE_NAME:-}" ]] && _sii_needs_remux=1
        # Stream filtering: if keep-lists exclude any streams, we must remux
        local _sii_total_a _sii_total_s
        _sii_total_a="$(_audio_stream_count)"
        _sii_total_s="$(_sub_count)"
        (( ${#SII_AUDIO_INDICES[@]} < _sii_total_a )) && _sii_needs_remux=1
        (( ${#SII_SUB_INDICES[@]} < _sii_total_s )) && _sii_needs_remux=1

        if (( _sii_needs_remux )); then
          # Build explicit per-stream maps from validated keep-lists
          local -a _sii_meta=( "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" )

          # Video: always map
          _sii_meta+=( -map 0:v:0 )

          # Audio: map only validated streams
          local _sii_a_idx
          for _sii_a_idx in "${SII_AUDIO_INDICES[@]}"; do
            _sii_meta+=( -map "0:a:${_sii_a_idx}" )
          done

          # Subtitles: map only validated streams
          local _sii_s_idx
          for _sii_s_idx in "${SII_SUB_INDICES[@]}"; do
            _sii_meta+=( -map "0:s:${_sii_s_idx}" )
          done

          _sii_meta+=( -c copy )

          # Audio titles: use output indices (sequential) not source indices
          if (( INCLUDE_AUDIO_TITLES )) && (( ${#SII_AUDIO_INDICES[@]} > 0 )); then
            local _sii_out_a=0 _sii_src_a _sii_codec _sii_ch _sii_title
            for _sii_src_a in "${SII_AUDIO_INDICES[@]}"; do
              _sii_codec="$(_audio_codec "$_sii_src_a")"
              _sii_ch="$(_audio_channels "$_sii_src_a")"
              _sii_title="$(_audio_descriptive_title "$_sii_codec" "$_sii_ch")"
              _sii_meta+=( "-metadata:s:a:${_sii_out_a}" "title=$_sii_title" )
              _sii_out_a=$(( _sii_out_a + 1 ))
            done
          fi

          # Profile comment
          if (( PROFILE_COMMENT )) && [[ -n "${PROFILE_NAME:-}" ]]; then
            local _sii_comment
            _sii_comment="$(_profile_comment)"
            [[ -n "$_sii_comment" ]] && _sii_meta+=( -metadata "comment=$_sii_comment" )
          fi
          [[ "$MUX_FORMAT" != "matroska" ]] && _sii_meta+=( -movflags +faststart )
          _sii_meta+=( -f "$MUX_FORMAT" "$TMP_OUT" )
          ffmpeg "${_sii_meta[@]}" 2>"$WORKDIR/skip_ideal_remux.err" &
          local _sii_pid=$!
          spinner "$_sii_pid" "Applying metadata (copy-remux)"
          if ! wait "$_sii_pid" 2>/dev/null; then
            _check_disk_full "$WORKDIR/skip_ideal_remux.err"
            die 41 "Skip-if-ideal metadata remux failed. See: $WORKDIR/skip_ideal_remux.err"
          fi
          _validate_media_file "$TMP_OUT" "Skip-if-ideal remux"

          # Log stream counts if filtering occurred
          if (( ${#SII_AUDIO_INDICES[@]} < _sii_total_a )) || (( ${#SII_SUB_INDICES[@]} < _sii_total_s )); then
            note "Streams: ${#SII_AUDIO_INDICES[@]}/${_sii_total_a} audio, ${#SII_SUB_INDICES[@]}/${_sii_total_s} subtitle (container-filtered)."
          fi
          note "Applied metadata via copy-remux (already ideal)."
        else
          # No titles, no comment, no filtering — hardlink (instant on same FS); fall back to copy
          if ! ln -f "$SRC_ABS" "$TMP_OUT" 2>/dev/null; then
            cp -f "$SRC_ABS" "$TMP_OUT" &
            local _sii_cp_pid=$!
            spinner "$_sii_cp_pid" "Copying source to output"
            wait "$_sii_cp_pid" 2>/dev/null \
              || die 41 "Failed to copy source to output (skip-if-ideal)"
          fi
          _validate_media_file "$TMP_OUT" "Skip-if-ideal copy"
          note "Linked/copied source to output (already ideal)."
        fi
      fi
      mark_done "Skip-if-ideal (source compliant)"
      FAILED=0
      return 0
    fi
  fi
  
  # Detect Dolby Vision
  # detect_dv returns: 0=detected, 1=not found, 2=skipped (DISABLE_DV).
  # Use || to capture non-zero returns without triggering errexit.
  local _dv_rc=0
  detect_dv || _dv_rc=$?

  if (( _dv_rc == 0 )); then
    IS_DV=1
    note "Dolby Vision detected — extraction/injection will be attempted in the video pipeline."
    report_add "dv_detected" "true"

    # Extract detailed DV source info (profile, compat_id, layer flags)
    detect_dv_info

    # Validate output container supports DV muxing before starting any encode.
    # ffmpeg can read DV from MOV but cannot reliably write DV signalling back
    # into MOV. Only MP4 and MKV are supported.
    case "${OUTPUT_EXT,,}" in
      mp4|m4v|mkv) ;;
      *)
        die 11 "Dolby Vision detected but output container .${OUTPUT_EXT} is not supported for DV muxing by ffmpeg.
   Either switch to a supported container (--output-ext mkv or --output-ext mp4)
   or disable DV handling (--no-dv) to proceed without DV metadata."
        ;;
    esac

    # Warn if hdr10-hq profile will strip DV from a source without HDR10 fallback metadata.
    # DV-only sources (especially P5 and some P7) may lack mastering display / MaxCLL data,
    # which causes dim or washed-out playback when DV is stripped and only HDR10 remains.
    if (( DISABLE_DV )) && [[ "${PROFILE_NAME:-}" == "hdr10-hq" ]]; then
      _check_hdr10_static_metadata
    fi
  elif (( _dv_rc == 2 )); then
    # Detection was skipped because DISABLE_DV=1. Check the metadata cache
    # so we can tell the user if the source actually contains DV.
    IS_DV=0
    local _dv_skip_source="--no-dv"
    [[ -n "${PROFILE_NAME:-}" ]] && _dv_skip_source="profile '${PROFILE_NAME}'"
    if _source_has_dv_metadata; then
      warn "Source contains Dolby Vision but DV handling is disabled (${_dv_skip_source}). Use --dv to override."
      report_add "dv_detected" "skipped (present in source)"
    else
      note "DV detection skipped (disabled by ${_dv_skip_source})."
      report_add "dv_detected" "skipped"
    fi
  else
    IS_DV=0
    note "No Dolby Vision detected."
    report_add "dv_detected" "false"
  fi

  # Warn: ASS/SSA subtitles + MP4 container + SUB_PRESERVE_TEXT_FORMAT=1
  # ASS/SSA native format cannot be carried by MP4; subtitles will be flattened to mov_text.
  if (( SUB_PRESERVE_TEXT_FORMAT )) && [[ "${OUTPUT_EXT,,}" == "mp4" || "${OUTPUT_EXT,,}" == "m4v" ]]; then
    local _has_ass_sub=0
    local _acs_i
    for _acs_i in "${!ALL_SUB_CODECS[@]}"; do
      case "${ALL_SUB_CODECS[$_acs_i]}" in
        ass|ssa) _has_ass_sub=1; break ;;
      esac
    done
    if (( _has_ass_sub )); then
      warn "ASS/SSA subtitle preservation requested (SUB_PRESERVE_TEXT_FORMAT=1) but output container .${OUTPUT_EXT,,} cannot carry native ASS. Subtitles will be converted to mov_text (plain text — formatting, positioning, and styling will be lost)."
    fi
  fi

  # Warn: lossless audio passthrough + MP4 container with codecs that have limited MP4 support
  # TrueHD/DTS-HD MA cannot be muxed into MP4; FLAC can be muxed but has limited device playback support.
  if (( AUDIO_LOSSLESS_PASSTHROUGH )) && [[ "${OUTPUT_EXT,,}" == "mp4" || "${OUTPUT_EXT,,}" == "m4v" ]]; then
    local _has_problematic_lossless=0
    local _alp_n _alp_i _alp_codec _alp_profile
    _alp_n="$(_audio_stream_count)"
    for (( _alp_i=0; _alp_i<_alp_n; _alp_i++ )); do
      _alp_codec="$(_audio_field "$_alp_i" codec_name)"
      _alp_codec="${_alp_codec,,}"
      case "$_alp_codec" in
        truehd|mlp|flac)
          _has_problematic_lossless=1; break ;;
        dts|dca)
          _alp_profile="$(_audio_field "$_alp_i" profile)"
          if [[ "${_alp_profile,,}" == *"hd ma"* ]]; then
            _has_problematic_lossless=1; break
          fi
          ;;
      esac
    done
    if (( _has_problematic_lossless )); then
      warn "Lossless audio passthrough enabled but output container .${OUTPUT_EXT,,} has limited lossless playback support. TrueHD/FLAC tracks may not play on most devices. Consider --output-ext mkv for full lossless compatibility."
    fi
  fi

  # Decide color space and build encoder params
  decide_color_and_pixfmt
  case "$VIDEO_CODEC" in
    libsvt-av1|libaom-av1) build_av1_params ;;
    *)                     build_x265_params ;;
  esac

  # Deferred warning: H.264 + HDR source + no tone-mapping → washed-out output
  if (( _H264_HDR_WARN_PENDING )) && [[ "$PROFILE_DESC" == "HDR10" || "$PROFILE_DESC" == "HLG" ]]; then
    warn "Source is HDR but tone-mapping is disabled. H.264 cannot preserve HDR metadata — output will appear washed out."
  fi

  [[ -n "$LEVEL_VALUE" ]] && apply_level_vbv "$LEVEL_VALUE"

  # When burning forced subs, we need the subtitle plan BEFORE video encode
  if (( SUB_BURN_FORCED && ! SKIP_SUBS )); then
    build_subtitle_plan
    mark_done "Subtitle plan (pre-video for burn-in)"
  fi

  # Run pipelines
  if (( SKIP_VIDEO )); then
    die 42 "--skip-video is incompatible with producing a valid output file."
  else
    run_video_pipeline
  fi

  if (( SKIP_AUDIO )); then
    note "[Quick Test] --skip-audio: skipping audio selection/transcode"
    HAS_AUDIO=0
    A_PRIMARY=""
    AAC_STEREO=""
  else
    run_audio_pipeline
  fi

  # Build subtitle plan if not already done (non-burn case)
  if (( ! SUB_BURN_FORCED || SKIP_SUBS )); then
    build_subtitle_plan
  fi

  mux_final

  # Verify DV container signaling is present in output (dvcC/dvvC box for MP4/MOV)
  verify_dv_container_record

  if (( DRY_RUN )); then
    note "DRY-RUN: DV output status not evaluated (no real encode performed)."
  elif (( OUTPUT_HAS_DV )); then
    note "Dolby Vision present in output."
    report_add "dv_output" "preserved"
  elif (( IS_DV == 1 && DISABLE_DV == 0 )); then
    warn "Dolby Vision was detected in source but could not be preserved in output."
    report_add "dv_output" "failed"
  else
    note "Output is non-DV."
  fi

  say "→ Verifying output…"
  if (( DRY_RUN )); then
    say "  DRY-RUN: ffprobe verify $TMP_OUT"
    say "  DRY-RUN: size of $TMP_OUT"
  else
    # Full ffprobe dump → log only (not to terminal)
    log "--- ffprobe output streams (full) ---"
    ffprobe -hide_banner -show_streams "$TMP_OUT" 2>/dev/null >> "$LOGFILE" || true
    log "--- end ffprobe output ---"

    # Compact stream summary → terminal + log (via say)
    local verify_json
    verify_json="$(ffprobe -v error -show_streams -of json "$TMP_OUT" 2>/dev/null)" || true
    if [[ -n "${verify_json:-}" ]]; then
      # Batch: fetch all video summary fields in a single jq call
      local v_codec v_res v_fps s_count _v_summary
      _v_summary="$(printf '%s\n' "$verify_json" | jq -r '
        ([.streams[] | select(.codec_type=="video")][0] |
          "\(.codec_name // "?") \(.profile // "")"
          + "\t" + "\(.width)x\(.height)"
          + "\t" + (.r_frame_rate // "?"))
        + "\t" + ([.streams[] | select(.codec_type=="subtitle")] | length | tostring)' 2>/dev/null)"
      IFS=$'\t' read -r v_codec v_res v_fps s_count <<< "$_v_summary"
      v_codec="${v_codec% }"
      # Convert fractional fps like 24000/1001 to decimal
      if [[ "$v_fps" == */* ]]; then
        v_fps="$(echo "scale=3; $v_fps" | bc 2>/dev/null | sed 's/0*$//' | sed 's/\.$//')"
      fi

      say "  Video : ${v_codec:-?} ${v_res:-?} @ ${v_fps:-?} fps"

      # Audio: rich per-track metadata (codec, channels, language, bitrate, title)
      # Single jq call extracts all fields per track as tab-delimited lines.
      local a_track_count
      a_track_count="$(printf '%s\n' "$verify_json" | jq '[.streams[] | select(.codec_type=="audio")] | length' 2>/dev/null)"
      if [[ "${a_track_count:-0}" != "0" ]]; then
        local a_idx=0
        while (( a_idx < a_track_count )); do
          local a_codec a_ch a_lang a_br a_title a_layout a_line a_ch_label _vinfo
          # Batch: fetch all audio fields in one jq call per track
          _vinfo="$(printf '%s\n' "$verify_json" | jq -r "
            [.streams[] | select(.codec_type==\"audio\")][$a_idx] |
            \"\(.codec_name // \"?\")\t\(.channels // 0)\t\(.tags.language // \"und\")\t\(.bit_rate // \"\")\t\(.tags.title // \"\")\t\(.channel_layout // \"\")\"" 2>/dev/null)"
          IFS=$'\t' read -r a_codec a_ch a_lang a_br a_title a_layout <<< "$_vinfo"

          # Descriptive channel label
          a_ch_label="$(_channel_label "${a_ch:-0}")"
          # Prefer channel_layout if available and more descriptive
          [[ -n "$a_layout" && "$a_layout" != "unknown" ]] && a_ch_label="$a_layout"

          a_line="${a_codec} ${a_ch_label} [${a_lang}]"
          [[ -n "$a_br" && "$a_br" =~ ^[0-9]+$ ]] && (( a_br > 0 )) && a_line+=" $(( a_br / 1000 ))kbps"
          [[ -n "$a_title" ]] && a_line+=" — $a_title"

          if (( a_idx == 0 )); then
            say "  Audio : $a_line"
          else
            say "          $a_line"
          fi
          a_idx=$(( a_idx + 1 ))
        done
      else
        say "  Audio : none"
      fi

      [[ "${s_count:-0}" != "0" ]] && say "  Subs  : ${s_count} track(s)"
      (( OUTPUT_HAS_DV )) && say "  DV    : present"
    fi

    # File size
    say "  Size  : $(filesize_pretty "$TMP_OUT")"
  fi
  mark_done "Verify output"

  # Write JSON report if requested
  write_json_report

  # Note external SRT files
  if [[ ${#EXTERNAL_SRT_PATHS[@]} -gt 0 ]]; then
    note "External subtitle files:"
    for ext_path in "${EXTERNAL_SRT_PATHS[@]}"; do
      note "  → $ext_path"
    done
  fi

  note "✅ Staging complete — will atomically move to: $OUT"
}

main "$@"
