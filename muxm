# ===== Section 5: Basic helpers ===============================================================
# ---- Logging helpers ----
# All output goes to stderr to keep stdout clean for piping.
# say()  — plain informational message (no prefix)
# note() — informational with ℹ️  prefix
# warn() — warning with ⚠️  prefix
# die()  — fatal error with ❌ prefix; exits with code (default 1)
#           Usage: die "message" or die <code> "message"
say()  { printf "%s\n" "$@" >&2; }
note() { printf "ℹ️  %s\n" "$@" >&2; }
warn() { printf "⚠️  %s\n" "$@" >&2; }

# log() — write ONLY to the log file, not to the terminal.
# Falls back to say() if LOGFILE isn't set yet (pre–Section 17).
log() {
  if [[ -n "${LOGFILE:-}" && -w "${LOGFILE:-}" ]]; then
    printf "%s\n" "$@" >> "$LOGFILE"
  else
    say "$@"
  fi
}

# ---- Terminal FD for interactive UI (spinner / progress bar) ----
# Saved in Section 17 before the exec > >(tee …) redirect.
# Falls back to stderr if not yet initialised.
TERM_FD=""
# shellcheck disable=SC2059  # Callers pass printf format + args intentionally
_term_print() { printf -- "$@" >&"${TERM_FD:-2}"; }

# ---- Spinner — indeterminate progress indicator ----
# spinner PID "Message"
# Display an animated spinner on the terminal while a background process runs.
# Args: $1 — PID to poll, $2 — status message to display
# NOTE: spinner NEVER calls wait — it only polls with kill -0.
#       The caller MUST call wait "$pid" afterward to collect exit status.
# Globals: TERM_FD (read)
spinner() {
  local pid=$1 msg=$2 i=0
  local -a sym=( '|' '/' '—' $'\\' )
  local -i show=1
  [[ -t ${TERM_FD:-2} ]] || show=0
  while kill -0 "$pid" 2>/dev/null; do
    (( show )) && _term_print '\r  %s  [ %s ]' "$msg" "${sym[i]}" || true
    (( i = (i+1) % 4 ))
    sleep 0.2
  done
  (( show )) && _term_print '\r  %s  [ done ]\n' "$msg" || true
}

# run_with_spinner CMD_ARRAY_NAME "Message"
# Runs a command (passed as array name) in the background with a spinner.
# Returns the exit status of the background command.
run_with_spinner() {
  local -n _cmd_arr=$1
  local msg="$2"
  "${_cmd_arr[@]}" &
  local bg_pid=$!
  spinner "$bg_pid" "$msg"
  wait "$bg_pid" 2>/dev/null
  return $?
}

# _make_progress_pipe — Create a named pipe (FIFO) for ffmpeg -progress output.
# Args: $1 — path for the FIFO
# Returns: 0 if FIFO created successfully, 1 on failure (with warning logged).
# On failure, callers should fall back to spinner-only mode (no -progress flag).
_make_progress_pipe() {
  local pipe_path="$1"
  if mkfifo "$pipe_path" 2>/dev/null; then
    return 0
  fi
  warn "Could not create progress pipe ($pipe_path) — progress display unavailable."
  return 1
}

# _repeat_char — print a character n times using pure bash (no seq dependency).
# Portable alternative to `printf '%0.s' $(seq 1 n)`.
# Args: $1 — character to repeat, $2 — count (0 or negative prints nothing)
_repeat_char() { local char="$1" n="${2:-0}" i; for (( i=0; i<n; i++ )); do printf '%s' "$char"; done; }

# ---- Progress bar — percentage-based for ffmpeg encodes ----
# Reads ffmpeg -progress output from a named pipe and renders a terminal bar.
# Args: $1 = ffmpeg PID, $2 = progress pipe path, $3 = total duration (seconds),
#       $4 = label
# Returns: the exit status of the ffmpeg process.
#
# IMPORTANT: This function calls `wait "$pid"` internally. The caller should NOT
# call wait again. The wait at the end of this function is the authoritative
# collection of the ffmpeg exit status — it fires after the progress pipe is
# fully drained or the process has exited.
ffmpeg_progress_bar() {
  local pid=$1 pipe=$2 total_secs=$3 label=$4
  local pct=0 bar="" elapsed_us=0

  # If we can't show a progress bar (no terminal or unknown duration),
  # we MUST still drain the named pipe — otherwise ffmpeg blocks forever
  # trying to open the FIFO for writing with no reader on the other end.
  if [[ ! -t ${TERM_FD:-2} ]] || (( total_secs <= 0 )); then
    cat "$pipe" >/dev/null 2>&1 &
    local drain_pid=$!
    spinner "$pid" "$label"
    wait "$pid" 2>/dev/null
    local rc=$?
    # Clean up the FIFO drain process (may already be gone if pipe hit EOF)
    kill "$drain_pid" 2>/dev/null || true
    wait "$drain_pid" 2>/dev/null || true
    return $rc
  fi

  local -i cols=40
  while IFS='=' read -r key val 2>/dev/null; do
    case "$key" in
      out_time_us)
        elapsed_us="${val:-0}"
        # Guard against non-numeric values
        [[ "$elapsed_us" =~ ^-?[0-9]+$ ]] || continue
        (( elapsed_us < 0 )) && elapsed_us=0
        pct=$(( elapsed_us * 100 / (total_secs * 1000000) ))
        (( pct > 100 )) && pct=100
        local filled empty
        filled=$(( pct * cols / 100 ))
        empty=$(( cols - filled ))
        bar="$(_repeat_char '█' "$filled")"
        bar+="$(_repeat_char '░' "$empty")"
        _term_print '\r  %s  [%s] %3d%%' "$label" "$bar" "$pct"
        ;;
      progress)
        # ffmpeg writes "progress=end" when done
        [[ "$val" == "end" ]] && break
        ;;
    esac
  done < "$pipe"

  # Ensure the bar reaches 100% visually
  bar="$(_repeat_char '█' "$cols")"
  _term_print '\r  %s  [%s] 100%%\n' "$label" "$bar"

  wait "$pid" 2>/dev/null
  return $?
}

# _ffmpeg_run_with_ui — launch ffmpeg with a progress bar when possible, else spinner.
# Args: $1 = nameref to command array (args after "ffmpeg", without -progress flag),
#       $2 = label string, $3 = error file path, $4 = total duration in seconds.
# Returns: ffmpeg exit status. Caller is responsible for die/warn on failure.
_ffmpeg_run_with_ui() {
  local -n _ffui_cmd=$1
  local _ffui_label="$2"
  local _ffui_err="$3"
  local _ffui_secs="${4:-0}"
  local _ffui_pipe="$WORKDIR/_ffui.$$.pipe"

  if _make_progress_pipe "$_ffui_pipe"; then
    ffmpeg "${_ffui_cmd[@]}" -progress "$_ffui_pipe" 2>"$_ffui_err" &
    local _ffui_pid=$!
    # ffmpeg_progress_bar calls wait internally and returns ffmpeg's exit status
    ffmpeg_progress_bar "$_ffui_pid" "$_ffui_pipe" "$_ffui_secs" "$_ffui_label"
    local _ffui_rc=$?
    rm -f "$_ffui_pipe" 2>/dev/null || true
    return $_ffui_rc
  else
    ffmpeg "${_ffui_cmd[@]}" 2>"$_ffui_err" &
    local _ffui_pid=$!
    spinner "$_ffui_pid" "$_ffui_label"
    wait "$_ffui_pid" 2>/dev/null
    return $?
  fi
}

# _get_source_duration_secs — extract source video duration in whole seconds.
#
# Three-tier lookup (each tier falls through on null, "N/A", or non-numeric):
#   1. streams[].duration           — standard per-stream field (MP4, TS)
#   2. format.duration              — container-level (requires -show_format in cache)
#   3. streams[].tags.DURATION      — Matroska/MKV tag, format "HH:MM:SS.nnnnnnnnn"
#
# Tier 3 is the most reliable for MKV sources: Matroska stores per-track duration
# in stream tags even when the standard duration field and Segment Duration are absent.
#
# Result is cached in _CACHED_SRC_DURATION_SECS after the first call — subsequent
# calls return instantly without jq forks. Source duration doesn't change mid-run.
#
# Globals: METADATA_CACHE (read), _CACHED_SRC_DURATION_SECS (read/write)
_get_source_duration_secs() {
  # Return cached result if available
  if [[ -n "$_CACHED_SRC_DURATION_SECS" ]]; then
    echo "$_CACHED_SRC_DURATION_SECS"
    return
  fi

  local dur="" result=0

  # Tier 1: standard stream-level duration (common in MP4, rare in MKV)
  dur="$(_jq_cache -r \
    '[.streams[] | select(.codec_type=="video")] | .[0].duration // empty' | head -n1)"
  if [[ "$dur" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
    log "Duration source: stream duration = ${dur}s"
    result="$(printf '%.0f' "$dur")"
  fi

  # Tier 2: container/format-level duration (most containers)
  if [[ "$result" == "0" ]]; then
    dur="$(_jq_cache -r \
      '.format.duration // empty' | head -n1)"
    if [[ "$dur" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
      log "Duration source: format duration = ${dur}s"
      result="$(printf '%.0f' "$dur")"
    fi
  fi

  # Tier 3: Matroska tags — DURATION as "HH:MM:SS.nnnnnnnnn"
  if [[ "$result" == "0" ]]; then
    local tag_dur
    tag_dur="$(_jq_cache -r \
      '[.streams[] | select(.codec_type=="video")] | .[0].tags.DURATION // empty' | head -n1)"
    if [[ "$tag_dur" =~ ^([0-9]+):([0-9]+):([0-9]+)(\.[0-9]+)?$ ]]; then
      local h="${BASH_REMATCH[1]}" m="${BASH_REMATCH[2]}" s="${BASH_REMATCH[3]}"
      result=$(( 10#$h * 3600 + 10#$m * 60 + 10#$s ))
      log "Duration source: Matroska tag DURATION = ${tag_dur} → ${result}s"
    fi
  fi

  [[ "$result" == "0" ]] && \
    log "Duration: unable to determine from stream, format, or Matroska tags — progress bar unavailable"

  _CACHED_SRC_DURATION_SECS="$result"
  echo "$result"
}

# Lowercase a string. For non-hot-path use where readability is preferred.
# Hot paths (per-stream loops in Sections 27–28) use ${var,,} directly to avoid fork overhead.
_lower(){ printf '%s' "$1" | LC_ALL=C tr '[:upper:]' '[:lower:]'; }

# _jq_cache — Run jq against the cached METADATA_CACHE JSON.
# Absorbs stderr (jq errors) so callers don't need to redirect individually.
# All jq flags (-r, -e, etc.) and the filter expression are passed through.
# Usage: _jq_cache -r '.format.duration // empty'
#        _jq_cache -e '[.streams[] | …] | length > 0'
# Globals: METADATA_CACHE (read)
# Debug mode (DEBUG=1): logs filter, exit code, result, and any jq stderr to help
# diagnose probe failures. Uses a reusable temp file in WORKDIR to avoid per-call
# mktemp overhead; acceptable in debug mode where performance is not the priority.
_jq_cache() {
  if [[ "${DEBUG:-0}" != "1" ]]; then
    printf '%s\n' "$METADATA_CACHE" | jq "$@" 2>/dev/null
    return
  fi
  # Debug mode: capture stderr and log inputs/outputs for probe-failure diagnosis
  local _jq_out _jq_rc _jq_err
  local _jq_err_file="${WORKDIR:-/tmp}/jq_debug_err.tmp"
  _jq_out="$(printf '%s\n' "$METADATA_CACHE" | jq "$@" 2>"$_jq_err_file")"
  _jq_rc=$?
  _jq_err="$(<"$_jq_err_file" 2>/dev/null)"
  log "[jq_cache] filter: $*"
  log "[jq_cache] rc=${_jq_rc}  result=${_jq_out:0:300}"
  [[ -n "$_jq_err" ]] && log "[jq_cache] jq stderr: ${_jq_err:0:300}"
  printf '%s\n' "$_jq_out"
  return $_jq_rc
}

# Error handling strategy:
#   die()      — Called explicitly for expected failures (bad input, missing tool,
#                validation error). Sets FAILED/EXIT_CODE/FAIL_MSG and exits
#                immediately; the EXIT trap (on_exit) handles cleanup.
#   on_error() — ERR trap, fires on any unexpected non-zero exit under set -eEuo pipefail.
#                Sets the same globals but does NOT call exit; the shell exits
#                automatically after the ERR trap returns (due to set -e), which
#                then triggers on_exit for cleanup.
#   on_exit()  — EXIT trap that always runs. Reads FAILED/EXIT_CODE/FAIL_MSG to
#                decide whether to commit the output or clean up after failure.
die()  {
  local code=1
  if [[ $# -gt 1 && "$1" =~ ^[0-9]+$ ]]; then code="$1"; shift; fi
  FAILED=1; EXIT_CODE="$code"; FAIL_MSG="Fatal: $*"
  printf "❌ ERROR: %s\n" "$FAIL_MSG" >&2
  exit "$code"
}

on_error(){
  local lineno="$1" cmd="$2" status="$3"
  FAILED=1
  EXIT_CODE="${EXIT_CODE:-$status}"
  FAIL_MSG="Command failed at line $lineno: $cmd (exit $status)"
  printf "❌ ERROR: %s\n" "$FAIL_MSG" >&2
  # Note: This trap does not call exit directly. Under set -e, the shell
  # exits after the ERR trap returns, which triggers the EXIT trap (on_exit)
  # where FAILED/EXIT_CODE/FAIL_MSG are used for cleanup and reporting.
}

mark_done(){ COMPLETED_STEPS+=("$1"); }

need(){
  command -v "$1" >/dev/null 2>&1 || die 10 "Missing required tool: $1"
}

# Cross-platform tool detection pattern used throughout this section:
# Several tools ship under different names or have different flag syntax on macOS
# (typically via Homebrew) vs Linux. The general approach is:
#   1. Try the macOS/Homebrew variant first (e.g., MP4Box, stat -f, sed -i '')
#   2. Fall back to the GNU/Linux variant (e.g., mp4box, stat -c, sed -i)
#   3. Fall back to POSIX-portable alternatives (e.g., wc -c instead of stat)
# Functions that implement this pattern: _detect_mp4box, realpath_fallback,
# filesize_pretty, write_checksum, _sed_inplace (Section 9).
#
# Audit notes (verified 2026-04-11):
#   - stat:      handled via BSD (-f%z) / GNU (-c%s) / gstat / wc fallback chain
#   - sed -i:    handled via _sed_inplace (BSD requires '', GNU does not)
#   - sed (pipe):non-inplace sed uses only POSIX s-commands; no -E flag or
#                GNU extensions — portable on both BSD/macOS and GNU/Linux
#   - date:      all calls use POSIX-compatible format strings (+%Y%m%d, etc.)
#   - mktemp:    template-argument form used (POSIX-compatible on BSD and GNU)
#   - grep:      only -i, -E, -o, -q, -v flags used (all POSIX/BSD-compatible)
#   - readlink:  not used; path resolution handled via realpath_fallback
#   - seq:       eliminated; replaced with _repeat_char (pure bash, fully portable)

# Detect mp4box binary (name varies: MP4Box on macOS Homebrew, mp4box on Linux).
# Sets global MP4BOX_CMD to the found binary name, or empty string if not found.
# Returns: 0 if found, 1 if not found
_detect_mp4box(){
  if command -v MP4Box >/dev/null 2>&1; then
    MP4BOX_CMD="MP4Box"
  elif command -v mp4box >/dev/null 2>&1; then
    MP4BOX_CMD="mp4box"
  else
    MP4BOX_CMD=""
    return 1
  fi
  return 0
}

# Improved realpath that handles non-existent files on all platforms
realpath_fallback(){
  local p="$1"
  
  # Try GNU realpath with -m (allows missing files)
  if command -v realpath >/dev/null 2>&1; then
    if realpath -m "$p" 2>/dev/null; then
      return 0
    fi
  fi
  
  # Fallback for macOS/BSD and systems without realpath
  local dir base
  dir="$(dirname -- "$p")"
  base="$(basename -- "$p")"
  
  if [[ -d "$dir" ]]; then
    echo "$(cd "$dir" 2>/dev/null && pwd)/$base"
  elif [[ "$p" =~ ^/ ]]; then
    # Already absolute
    echo "$p"
  else
    # Make absolute from current directory
    echo "$PWD/$p"
  fi
}

# Improved filesize_pretty - outputs human-readable file size string to stdout.
# Composable: callers format/route the output (e.g., say "Size: $(filesize_pretty f)")
filesize_pretty(){
  local file="$1" bytes=""
  [[ -f "$file" ]] || { echo "unknown (file not found)"; return 1; }

  # Get raw byte count (try multiple methods for portability)
  if stat -f "%z" "$file" >/dev/null 2>&1; then
    bytes="$(stat -f "%z" "$file")"            # macOS / BSD
  elif stat -c "%s" "$file" >/dev/null 2>&1; then
    bytes="$(stat -c "%s" "$file")"            # GNU / Linux
  elif command -v gstat >/dev/null 2>&1; then
    bytes="$(gstat -c "%s" "$file")"           # Homebrew GNU stat
  elif command -v wc >/dev/null 2>&1; then
    bytes="$(wc -c < "$file" | tr -d ' ')"     # POSIX fallback
  fi

  if [[ -z "$bytes" || ! "$bytes" =~ ^[0-9]+$ ]]; then
    echo "unknown size"
    return 0
  fi

  # Human-readable formatting
  if (( bytes >= 1073741824 )); then
    printf '%.2f GB (%s bytes)\n' "$(echo "scale=2; $bytes/1073741824" | bc)" "$bytes"
  elif (( bytes >= 1048576 )); then
    printf '%.1f MB (%s bytes)\n' "$(echo "scale=1; $bytes/1048576" | bc)" "$bytes"
  elif (( bytes >= 1024 )); then
    printf '%.0f KB\n' "$(echo "scale=0; $bytes/1024" | bc)"
  else
    printf '%s bytes\n' "$bytes"
  fi
}

write_checksum(){
  local file_path="$1"
  local -a cmd=()
  local ext spinner_msg

  case "${CHECKSUM_ALGO:-sha256}" in
    blake2b)
      if command -v b2sum >/dev/null 2>&1; then
        cmd=(b2sum); ext="b2"; spinner_msg="Computing BLAKE2b checksum"
      else
        warn "b2sum not found; cannot write BLAKE2b checksum"; return 0
      fi
      ;;
    auto)
      if command -v b2sum >/dev/null 2>&1; then
        cmd=(b2sum); ext="b2"; spinner_msg="Computing BLAKE2b checksum"
      elif command -v sha256sum >/dev/null 2>&1; then
        cmd=(sha256sum); ext="sha256"; spinner_msg="Computing SHA-256 checksum"
      elif command -v shasum >/dev/null 2>&1; then
        cmd=(shasum -a 256); ext="sha256"; spinner_msg="Computing SHA-256 checksum"
      else
        warn "Checksum tool not found"; return 0
      fi
      ;;
    sha256|*)
      if command -v sha256sum >/dev/null 2>&1; then
        cmd=(sha256sum)
      elif command -v shasum >/dev/null 2>&1; then
        cmd=(shasum -a 256)
      else
        warn "Checksum tool not found"; return 0
      fi
      ext="sha256"; spinner_msg="Computing SHA-256 checksum"
      ;;
  esac

  note "Writing checksum → ${file_path}.${ext}"
  "${cmd[@]}" "$file_path" > "${file_path}.${ext}" &
  local _cksum_pid=$!
  spinner "$_cksum_pid" "$spinner_msg"
  wait "$_cksum_pid" 2>/dev/null
}

# Validate that a media file exists, is non-empty, and is parseable by ffprobe.
# Two-step approach:
#   Step 1 — file must exist and have non-zero size (catches disk-full / write failure)
#   Step 2 — ffprobe must confirm a valid video stream is present (catches corrupt mux)
# Args: $1 — file path, $2 — context label for error message
# Dies on failure.
_validate_media_file(){
  local file="$1" label="${2:-output}"
  # Step 1: file exists and has non-zero size
  if [[ ! -s "$file" ]]; then
    _check_disk_full "$file"
    die 41 "$label produced empty file"
  fi
  # Step 2: ffprobe confirms a video stream is present (not just that the file is parseable)
  local _vcodec
  _vcodec="$(ffprobe -v error -select_streams v:0 \
    -show_entries stream=codec_name -of csv=p=0 "$file" 2>/dev/null)" \
    || die 41 "$label produced unreadable file (ffprobe failed)"
  [[ -n "$_vcodec" ]] || die 41 "$label produced file with no video stream (ffprobe found: none)"
  log "[validate] $label: OK — video codec=${_vcodec}, size=$(filesize_pretty "$file")"
}

# _check_disk_full — inspect an ffmpeg error log (or a file path on a volume)
# for ENOSPC ("No space left on device") and emit a specific warning if found.
# Call this before die() when an ffmpeg command or file operation fails, so the
# user gets an actionable message instead of a generic "encode failed".
# Args: $1 — error log file path (or any file on the relevant volume)
# Globals: WORKDIR (read, for volume fallback)
_check_disk_full() {
  local errfile="${1:-}"
  # Check error log text first (most reliable — ffmpeg prints the OS error)
  if [[ -f "$errfile" ]] && grep -q "No space left on device" "$errfile" 2>/dev/null; then
    warn "Disk full: 'No space left on device' detected — free space on the output volume and retry."
    return 0
  fi
  # Fallback: check available space on the workdir volume directly
  local avail_kb=""
  local check_dir="${WORKDIR:-${OUT_DIR:-.}}"
  avail_kb="$(df -Pk "$check_dir" 2>/dev/null | awk 'NR==2{print $4}')"
  if [[ -n "$avail_kb" ]] && (( avail_kb < 1024 )); then
    warn "Disk full: less than 1 MB free on temp volume ($check_dir) — free space and retry."
  fi
}

# Check if ffmpeg supports a given muxer (e.g., "vobsub" — missing on macOS Homebrew).
# Args: $1 — muxer name
# Returns: 0 if supported, 1 otherwise
ffmpeg_has_muxer(){
  local mux="$1"
  ffmpeg -hide_banner -muxers 2>/dev/null | awk '{print $1}' | grep -qx "$mux"
}

# Validate ffmpeg/ffprobe log level values.
# Used by config-file validation (Section 6) and CLI parsing (Section 12).
is_valid_loglevel(){
  case "$1" in
    quiet|panic|fatal|error|warning|info|verbose|debug|trace) return 0;;
    *) return 1;;
  esac
}

# _normalize_codec_lang — lowercase codec and lang in-place; default lang to
# TAG_LANGUAGE_DEFAULT when empty. Uses namerefs so callers can pass any variable names.
# Args: $1 — name of codec variable, $2 — name of lang variable
# Globals: TAG_LANGUAGE_DEFAULT (read)
_normalize_codec_lang() {
  local -n _ncl_c=$1 _ncl_l=$2
  _ncl_c="${_ncl_c,,}"
  _ncl_l="${_ncl_l,,}"
  if [[ -z "$_ncl_l" ]]; then _ncl_l="$TAG_LANGUAGE_DEFAULT"; fi
}

# _log_dropped_tracks — emit each entry in a dropped-reasons array to the log file.
# Args: $1 — label string (e.g. "multi-track"), $2 — name of dropped_reasons array (nameref)
_log_dropped_tracks() {
  local _ldt_label="$1"
  local -n _ldt_reasons=$2
  if (( ${#_ldt_reasons[@]} > 0 )); then
    local _ldt_r
    for _ldt_r in "${_ldt_reasons[@]}"; do
      log "  [$_ldt_label] Dropped $_ldt_r"
    done
  fi
}

# _source_label — human-readable label for a subtitle source entry.
# Embedded streams produce "#N"; external files produce their basename.
# Args: $1 — source string ("embedded:N" or "ext:/abs/path")
_source_label() {
  local _sl_src="$1"
  if [[ "$_sl_src" == embedded:* ]]; then
    echo "#${_sl_src#embedded:}"
  else
    basename -- "${_sl_src#ext:}"
  fi
}

# _check_filter_ideality — call a keep-list builder and set ideal=0 if any tracks
# are dropped. Used by check_skip_if_ideal to avoid duplicated counting logic.
# Args: $1 — stream type label (e.g. "audio"), $2 — builder fn name,
#        $3 — count fn name, $4 — nameref to ideal variable, $5 — nameref to reason variable
_check_filter_ideality() {
  local _cfi_label="$1" _cfi_builder="$2" _cfi_counter="$3"
  local -n _cfi_ideal=$4 _cfi_reason=$5
  local _cfi_keep
  _cfi_keep="$("$_cfi_builder")"
  local -a _cfi_keep_arr
  read -r -a _cfi_keep_arr <<< "$_cfi_keep"
  local _cfi_n_keep="${#_cfi_keep_arr[@]}"
  local _cfi_n_total
  _cfi_n_total="$("$_cfi_counter")"
  if [[ "$_cfi_n_keep" != "$_cfi_n_total" ]]; then
    _cfi_ideal=0
    _cfi_reason="$_cfi_label filter would drop $(( _cfi_n_total - _cfi_n_keep )) of $_cfi_n_total tracks"
  fi
}

# ===== Section 6: Config chain: Defaults → /etc → ~ → project =================================
# Config files are sourced as shell scripts — they can execute arbitrary code.
# Security note: The project-level ./.muxmrc is sourced from $PWD intentionally.
# A malicious .muxmrc placed in a directory the user cd's into could execute
# arbitrary commands. This is the same trust model as .envrc (direnv), Makefile,
# etc. — standard for developer tooling. See README.md (Config Chain section)
# and docs/config_profile.md for profile behavior details.
# Source a config file if it exists and is readable. Tracks loaded files for diagnostics.
# Args: $1 — file path
# Globals: MUXM_CONFIG_LOADED (modified)
_muxm_try_source(){
  local f="$1"
  [[ -r "$f" ]] || return 0
  # shellcheck disable=SC1090
  . "$f"
  MUXM_CONFIG_LOADED+=("$f")
}
# Capture script-builtin defaults before any .muxmrc is sourced.
# _create_config_emit diffs against this snapshot to identify which variables
# a profile actually changes — so that config-file values that coincidentally
# match the profile value don't suppress the uncommented output.
declare -Ag _MUXM_PRE_CONFIG=()
for _pcd_v in \
  VIDEO_CODEC CRF_VALUE PRESET_VALUE X265_PARAMS_BASE X264_PARAMS_BASE SVT_AV1_PARAMS_BASE \
  AV1_MAXRATE AV1_BUFSIZE \
  LEVEL_VALUE CONSERVATIVE_VBV \
  LEVEL_VBV_4_1_MAXRATE LEVEL_VBV_4_1_BUFSIZE \
  LEVEL_VBV_5_0_MAXRATE LEVEL_VBV_5_0_BUFSIZE \
  LEVEL_VBV_5_1_MAXRATE LEVEL_VBV_5_1_BUFSIZE \
  LEVEL_VBV_5_2_MAXRATE LEVEL_VBV_5_2_BUFSIZE \
  VIDEO_COPY_IF_COMPLIANT MAX_COPY_BITRATE \
  FORCE_CHROMA_420 SDR_USE_10BIT_IF_SRC_10BIT SDR_FORCE_10BIT HDR_TARGET_PIXFMT \
  TONEMAP_HDR_TO_SDR \
  THREADS \
  DISABLE_DV ALLOW_DV_FALLBACK DV_CONVERT_TO_P81_IF_FAIL \
  AUDIO_LANG_PREF AUDIO_CODEC_PREFERENCE \
  AUDIO_MULTI_TRACK AUDIO_KEEP_COMMENTARY \
  STEREO_BITRATE MAX_AUDIO_CHANNELS ADD_STEREO_IF_MULTICH \
  EAC3_BITRATE_5_1 EAC3_BITRATE_7_1 AUDIO_FORCE_CODEC AUDIO_FORCE_BITRATE AUDIO_LOSSLESS_PASSTHROUGH \
  SUB_LANG_PREF SUB_INCLUDE_FORCED SUB_INCLUDE_FULL SUB_INCLUDE_SDH SUB_MAX_TRACKS \
  SUB_BURN_FORCED SUB_EXPORT_EXTERNAL SUB_PRESERVE_TEXT_FORMAT \
  SUB_MULTI_TRACK \
  OUTPUT_EXT KEEP_CHAPTERS STRIP_METADATA PROFILE_COMMENT INCLUDE_AUDIO_TITLES \
  CHECKSUM CHECKSUM_ALGO SKIP_IF_IDEAL REPORT_JSON \
  FFMPEG_LOGLEVEL; do
  _MUXM_PRE_CONFIG[$_pcd_v]="${!_pcd_v}"
done
unset _pcd_v

_muxm_try_source /etc/.muxmrc
_muxm_try_source "$HOME/.muxmrc"
_muxm_try_source "./.muxmrc"   # Sources from $PWD — intentional project-level override (see section header)

# Deprecation bridge: AUDIO_SCORE_LANG_BONUS_ENG → AUDIO_SCORE_LANG_BONUS (v1.1)
if [[ -n "${AUDIO_SCORE_LANG_BONUS_ENG:-}" ]]; then
  AUDIO_SCORE_LANG_BONUS="$AUDIO_SCORE_LANG_BONUS_ENG"
  # shellcheck disable=SC2016
  printf '⚠️  Deprecated: AUDIO_SCORE_LANG_BONUS_ENG → rename to AUDIO_SCORE_LANG_BONUS in your .muxmrc\n' >&2
fi

# Validate loglevel values from config files (catch typos early, before ffmpeg sees them)
[[ -n "$FFMPEG_LOGLEVEL" ]] && ! is_valid_loglevel "$FFMPEG_LOGLEVEL" && \
  die 11 "Invalid FFMPEG_LOGLEVEL=\"$FFMPEG_LOGLEVEL\" in config. Valid values: quiet, panic, fatal, error, warning, info, verbose, debug, trace"
[[ -n "$FFPROBE_LOGLEVEL" ]] && ! is_valid_loglevel "$FFPROBE_LOGLEVEL" && \
  die 11 "Invalid FFPROBE_LOGLEVEL=\"$FFPROBE_LOGLEVEL\" in config. Valid values: quiet, panic, fatal, error, warning, info, verbose, debug, trace"

# ===== Section 7: Dependency installer ========================================================
# Invoked via --install-dependencies. Checks for all tools required by muxm and
# installs any that are missing via Homebrew and pipx. Exits after completion.
# Config chain (Section 6) is sourced before this so the installer sees the
# user's resolved SUB_OCR_TOOL and other config-file settings.
#
# Required:     ffmpeg (with libass, via homebrew-ffmpeg tap), ffprobe, jq, bc
# DV pipeline:  dovi_tool, mp4box (gpac)
# Subtitles:    tesseract, pgsrip (Python, via pipx)

# Check-only mode for non-Homebrew systems (Linux distros without brew).
# Reports which tools are present/missing and prints a manual-install reference.
# Does NOT attempt to install anything — the user's package manager is unknown.
_dep_check_only(){
  say "=== ${APP_NAME} v${VERSION} — Dependency Check (no package manager detected) ==="
  printf '\n'
  say "Homebrew not found — skipping automatic installation."
  say "Checking which tools are already available:"
  printf '\n'

  local -i total=0 found=0 missing=0

  _check_tool(){
    local _tool="$1"
    total=$(( total + 1 ))
    printf "  %-14s" "$_tool"
    if command -v "$_tool" >/dev/null 2>&1; then
      printf "✅ found (%s)\n" "$(command -v "$_tool")"
      found=$(( found + 1 ))
    else
      printf "❌ not found\n"
      missing=$(( missing + 1 ))
    fi
  }

  say "Core (required):"
  _check_tool ffmpeg
  # Check for libass support in ffmpeg (needed for --sub-burn-forced)
  if command -v ffmpeg >/dev/null 2>&1; then
    printf "  %-14s" "  └ libass"
    if ffmpeg -version 2>/dev/null | grep -q -- "--enable-libass"; then
      printf "✅ built with libass support\n"
    else
      printf "⚠️  built without libass — --sub-burn-forced will not work\n"
    fi
  fi
  _check_tool ffprobe
  _check_tool jq
  _check_tool bc
  printf '\n'

  say "Dolby Vision pipeline (recommended):"
  _check_tool dovi_tool
  # mp4box: binary name varies by platform (MP4Box vs mp4box)
  total=$(( total + 1 ))
  printf "  %-14s" "mp4box"
  if _detect_mp4box; then
    printf "✅ found (%s)\n" "$(command -v "$MP4BOX_CMD")"
    found=$(( found + 1 ))
  else
    printf "❌ not found\n"
    missing=$(( missing + 1 ))
  fi
  printf '\n'

  say "Subtitle OCR (recommended):"
  _check_tool tesseract
  _check_tool pgsrip
  printf '\n'

  say "Summary: $total checked, $found found, $missing missing"
  printf '\n'

  if (( missing > 0 )); then
    say "Install missing tools with your system package manager:"
    printf '\n'
    printf "  %-14s %-24s %-24s %s\n" "Tool" "apt (Debian/Ubuntu)" "dnf (Fedora/RHEL)" "brew (macOS)"
    printf "  %-14s %-24s %-24s %s\n" "──────────" "────────────────────" "────────────────────" "────────────────"
    printf "  %-14s %-24s %-24s %s\n" "ffmpeg"     "apt install ffmpeg"     "dnf install ffmpeg"     "brew install ffmpeg"
    printf "  %-14s %-24s %-24s %s\n" "jq"         "apt install jq"         "dnf install jq"         "brew install jq"
    printf "  %-14s %-24s %-24s %s\n" "bc"         "apt install bc"         "dnf install bc"         "brew install bc"
    printf "  %-14s %-24s %-24s %s\n" "dovi_tool"  "(GitHub release)"       "(GitHub release)"       "brew install dovi_tool"
    printf "  %-14s %-24s %-24s %s\n" "mp4box"     "apt install gpac"       "dnf install gpac"       "brew install gpac"
    printf "  %-14s %-24s %-24s %s\n" "tesseract"  "apt install tesseract-ocr" "dnf install tesseract" "brew install tesseract"
    printf "  %-14s %-24s %-24s %s\n" "pgsrip"     "pipx install pgsrip"    "pipx install pgsrip"    "pipx install pgsrip"
    printf '\n'
    say "After installing, re-run: ${CLI_NAME} --install-dependencies"
    exit 1
  fi

  say "✅ All tools found."
  exit 0
}

_dep_install_dependencies(){
  say "=== ${APP_NAME} v${VERSION} — Dependency Installer ==="
  printf '\n'

  # ---- Preflight: need Homebrew for auto-install; fall back to check-only mode
  if ! command -v brew >/dev/null 2>&1; then
    _dep_check_only
    # _dep_check_only always exits; this line is unreachable
  fi

  local -i total=0 installed=0 skipped=0 failed=0

  # Helper: check + brew install
  _brew_ensure(){
    local _tool="$1" formula="${2:-$1}"
    total=$(( total + 1 ))
    printf "  %-14s" "$_tool"
    if command -v "$_tool" >/dev/null 2>&1; then
      printf "✅ already installed (%s)\n" "$(command -v "$_tool")"
      skipped=$(( skipped + 1 ))
    else
      printf "⏳ installing via brew (%s)...\n" "$formula"
      if brew install "$formula" 2>&1 | sed 's/^/    /'; then
        if command -v "$_tool" >/dev/null 2>&1; then
          printf "  %-14s✅ installed successfully\n" "$_tool"
          installed=$(( installed + 1 ))
        else
          printf "  %-14s⚠️  brew install succeeded but '%s' not found in PATH\n" "$_tool" "$_tool"
          failed=$(( failed + 1 ))
        fi
      else
        printf "  %-14s❌ brew install failed\n" "$_tool"
        failed=$(( failed + 1 ))
      fi
    fi
  }

  # Helper: check + pipx install (for Python CLI tools)
  _pipx_ensure(){
    local _tool="$1" pkg="${2:-$1}"
    total=$(( total + 1 ))
    printf "  %-14s" "$_tool"
    if command -v "$_tool" >/dev/null 2>&1; then
      printf "✅ already installed (%s)\n" "$(command -v "$_tool")"
      skipped=$(( skipped + 1 ))
    else
      # Ensure pipx is available
      if ! command -v pipx >/dev/null 2>&1; then
        printf "⏳ installing pipx first...\n"
        brew install pipx 2>&1 | sed 's/^/    /'
        pipx ensurepath 2>/dev/null || true
        # Add pipx bin dir to current PATH (without eval of arbitrary output)
        local _pipx_bin
        _pipx_bin="$(pipx environment --value PIPX_BIN_DIR 2>/dev/null)" || true
        if [[ -n "$_pipx_bin" && -d "$_pipx_bin" ]]; then
          export PATH="$_pipx_bin:$PATH"
        fi
        export PATH="$HOME/.local/bin:$PATH"
      fi
      printf "  %-14s⏳ installing via pipx (%s)...\n" "$_tool" "$pkg"
      if pipx install "$pkg" 2>&1 | sed 's/^/    /'; then
        export PATH="$HOME/.local/bin:$PATH"
        if command -v "$_tool" >/dev/null 2>&1; then
          printf "  %-14s✅ installed successfully\n" "$_tool"
          installed=$(( installed + 1 ))
        else
          printf "  %-14s⚠️  pipx install succeeded but '%s' not found in PATH\n" "$_tool" "$_tool"
          printf "              Try: pipx ensurepath && source ~/.zshrc\n"
          failed=$(( failed + 1 ))
        fi
      else
        printf "  %-14s❌ pipx install failed\n" "$_tool"
        failed=$(( failed + 1 ))
      fi
    fi
  }

  # Helper: check for Tesseract language data
  _tessdata_ensure(){
    local lang="$1"
    total=$(( total + 1 ))
    printf "  %-14s" "tess:$lang"
    local tessdir
    tessdir="$(brew --prefix 2>/dev/null)/share/tessdata"
    if [[ -f "$tessdir/${lang}.traineddata" ]]; then
      printf "✅ language data present (%s)\n" "$tessdir/${lang}.traineddata"
      skipped=$(( skipped + 1 ))
    else
      printf "⏳ installing tesseract-lang for full language support...\n"
      if brew install tesseract-lang 2>&1 | sed 's/^/    /'; then
        if [[ -f "$tessdir/${lang}.traineddata" ]]; then
          printf "  %-14s✅ language data installed\n" "tess:$lang"
          installed=$(( installed + 1 ))
        else
          printf "  %-14s⚠️  installed but %s.traineddata not found in %s\n" "tess:$lang" "$lang" "$tessdir"
          failed=$(( failed + 1 ))
        fi
      else
        printf "  %-14s❌ brew install tesseract-lang failed\n" "tess:$lang"
        failed=$(( failed + 1 ))
      fi
    fi
  }

  # Helper: install ffmpeg with libass support for --sub-burn-forced.
  # Detection uses ffmpeg's compiled-in configure flags (ffmpeg -version),
  # which are stable across versions — unlike filter list output which varies.
  # If ffmpeg is already built with --enable-libass, this is a no-op.
  _ensure_ffmpeg_full(){
    total=$(( total + 1 ))
    printf "  %-14s" "ffmpeg"
    if command -v ffmpeg >/dev/null 2>&1; then
      # Check compiled-in build flags — most reliable across all install methods
      if ffmpeg -version 2>/dev/null | grep -q -- "--enable-libass"; then
        local _needs_av1_reinstall=0
        ffmpeg -encoders 2>/dev/null | grep -q 'libsvtav1' || _needs_av1_reinstall=1
        if (( _needs_av1_reinstall )); then
          printf "⚠️  installed with libass but missing AV1 encoders — reinstalling with AV1 support...\n"
        else
          printf "✅ already installed with libass and AV1 support (%s)\n" "$(command -v ffmpeg)"
          skipped=$(( skipped + 1 ))
          return
        fi
      else
        printf "⚠️  installed but built without libass (needed for --sub-burn-forced)\n"
      fi

      # Identify which Homebrew formula is currently providing ffmpeg so we
      # uninstall the right one. Without this, `brew uninstall ffmpeg` may
      # miss a tapped formula (e.g., homebrew-ffmpeg/ffmpeg/ffmpeg).
      local _current_formula=""
      if brew ls --versions homebrew-ffmpeg/ffmpeg/ffmpeg >/dev/null 2>&1; then
        _current_formula="homebrew-ffmpeg/ffmpeg/ffmpeg"
      elif brew list 2>/dev/null | grep -q '^ffmpeg-full$'; then
        _current_formula="ffmpeg-full"
      elif brew ls --versions ffmpeg >/dev/null 2>&1; then
        _current_formula="ffmpeg"
      fi

      if [[ -n "$_current_formula" ]]; then
        printf "  %-14s⏳ removing %s before reinstall...\n" "" "$_current_formula"
        brew uninstall --ignore-dependencies "$_current_formula" 2>&1 | sed 's/^/    /' || true
      fi
    else
      printf "⏳ installing via homebrew-ffmpeg tap (--with-libass)...\n"
    fi

    brew tap homebrew-ffmpeg/ffmpeg 2>&1 | sed 's/^/    /' || true
    if ! brew install homebrew-ffmpeg/ffmpeg/ffmpeg --with-libass --with-svt-av1 --with-libaom 2>&1 | sed 's/^/    /'; then
      # Fallback: if the tap fails, install standard ffmpeg so the tool is at least usable
      printf "  %-14s⚠️  homebrew-ffmpeg tap failed — falling back to standard ffmpeg\n" ""
      if brew install ffmpeg 2>&1 | sed 's/^/    /'; then
        printf "  %-14s✅ installed (standard build — --sub-burn-forced may not work)\n" "ffmpeg"
        installed=$(( installed + 1 ))
        if ! ffmpeg -encoders 2>/dev/null | grep -q 'libsvtav1'; then
          printf "  %-14s⚠️  AV1 encoder (libsvtav1/SVT-AV1) not available in this ffmpeg build\n" ""
        fi
        if ! ffmpeg -encoders 2>/dev/null | grep -q 'libaom-av1'; then
          printf "  %-14s⚠️  AV1 encoder (libaom-av1) not available in this ffmpeg build\n" ""
        fi
      else
        printf "  %-14s❌ ffmpeg install failed\n" ""
        failed=$(( failed + 1 ))
      fi
      return
    fi
    if ! command -v ffmpeg >/dev/null 2>&1; then
      printf "  %-14s⚠️  install succeeded but ffmpeg not found in PATH\n" "ffmpeg"
      failed=$(( failed + 1 ))
      return
    fi
    if ffmpeg -version 2>/dev/null | grep -q -- "--enable-libass"; then
      printf "  %-14s✅ installed with libass\n" "ffmpeg"
    else
      printf "  %-14s✅ installed (verify libass with: ffmpeg -version | grep enable-libass)\n" "ffmpeg"
    fi
    if ! ffmpeg -encoders 2>/dev/null | grep -q 'libsvtav1'; then
      printf "  %-14s⚠️  AV1 encoder (libsvtav1/SVT-AV1) not available in this ffmpeg build\n" ""
    fi
    if ! ffmpeg -encoders 2>/dev/null | grep -q 'libaom-av1'; then
      printf "  %-14s⚠️  AV1 encoder (libaom-av1) not available in this ffmpeg build\n" ""
    fi
    installed=$(( installed + 1 ))
  }

  say "Core tools (required):"
  _ensure_ffmpeg_full
  # ffprobe ships with ffmpeg — verify it's on PATH
  total=$(( total + 1 ))
  printf "  %-14s" "ffprobe"
  if command -v ffprobe >/dev/null 2>&1; then
    printf "✅ already installed (%s)\n" "$(command -v ffprobe)"
    skipped=$(( skipped + 1 ))
  else
    printf "❌ not found (should have been installed with ffmpeg)\n"
    failed=$(( failed + 1 ))
  fi
  _brew_ensure jq       jq
  _brew_ensure bc       bc
  printf '\n'

  say "Dolby Vision pipeline (recommended):"
  _brew_ensure dovi_tool dovi_tool
  # mp4box: binary name varies by platform (MP4Box vs mp4box)
  total=$(( total + 1 ))
  printf "  %-14s" "mp4box"
  if _detect_mp4box; then
    printf "✅ already installed (%s)\n" "$(command -v "$MP4BOX_CMD")"
    skipped=$(( skipped + 1 ))
  else
    printf "⏳ installing via brew (gpac)...\n"
    if brew install gpac 2>&1 | sed 's/^/    /'; then
      if _detect_mp4box; then
        printf "  %-14s✅ installed successfully\n" "mp4box"
        installed=$(( installed + 1 ))
      else
        printf "  %-14s⚠️  brew install succeeded but mp4box/MP4Box not found in PATH\n" "mp4box"
        failed=$(( failed + 1 ))
      fi
    else
      printf "  %-14s❌ brew install gpac failed\n" "mp4box"
      failed=$(( failed + 1 ))
    fi
  fi
  printf '\n'

  say "Subtitle OCR pipeline (recommended for PGS/Blu-ray subtitles):"
  _brew_ensure tesseract tesseract
  _tessdata_ensure eng
  _pipx_ensure pgsrip   pgsrip
  printf '\n'

  # TESSDATA_PREFIX check
  say "Environment:"
  local tessdir_resolved
  tessdir_resolved="$(brew --prefix 2>/dev/null)/share/tessdata"
  printf "  %-14s" "TESSDATA"
  if [[ -n "${TESSDATA_PREFIX:-}" ]]; then
    printf "✅ TESSDATA_PREFIX=%s\n" "$TESSDATA_PREFIX"
  elif [[ -d "$tessdir_resolved" ]]; then
    printf "⚠️  TESSDATA_PREFIX not set. Add to ~/.zshrc:\n"
    printf "              export TESSDATA_PREFIX=\"%s\"\n" "$tessdir_resolved"
  else
    printf "⚠️  No tessdata directory found\n"
  fi

  # .muxmrc OCR tool configuration check
  printf "  %-14s" "OCR config"
  if command -v pgsrip >/dev/null 2>&1; then
    if [[ "${SUB_OCR_TOOL:-sub2srt}" == "sub2srt" ]]; then
      printf "⚠️  pgsrip is installed but SUB_OCR_TOOL is '%s'.\n" "${SUB_OCR_TOOL:-sub2srt}"
      printf "              Set in ~/.muxmrc:  SUB_OCR_TOOL=\"pgsrip\"\n"
      printf "              Or use per-run:    --ocr-tool pgsrip\n"
    else
      printf "✅ SUB_OCR_TOOL=%s\n" "$SUB_OCR_TOOL"
    fi
  else
    printf "ℹ️  SUB_OCR_TOOL=%s (pgsrip not installed)\n" "${SUB_OCR_TOOL:-sub2srt}"
  fi
  printf '\n'

  # Post-install AV1 advisory: if ffmpeg is still missing AV1 encoder support after
  # the automated install attempt above, print a note. Not a failure.
  if command -v ffmpeg >/dev/null 2>&1; then
    local _missing_av1=0
    ffmpeg -encoders 2>/dev/null | grep -q 'libsvtav1' || _missing_av1=1
    ffmpeg -encoders 2>/dev/null | grep -q 'libaom-av1' || _missing_av1=1
    if (( _missing_av1 )); then
      say ""
      warn "ffmpeg is installed but one or more AV1 encoders are still missing."
      warn "  The automated install attempted: homebrew-ffmpeg/ffmpeg/ffmpeg --with-libass --with-svt-av1 --with-libaom"
      warn "  If that tap or build failed, try manually:"
      warn "    brew tap homebrew-ffmpeg/ffmpeg"
      warn "    brew install homebrew-ffmpeg/ffmpeg/ffmpeg --with-libass --with-svt-av1 --with-libaom"
      warn "  AV1 profiles (--video-codec libsvtav1 / libaom-av1) will not work without this."
    fi
  fi

  # Summary
  say "Summary: $total checked, $installed installed, $skipped already present, $failed failed"
  if (( failed > 0 )); then
    warn "Some dependencies could not be installed. Check output above for details."
    exit 1
  fi
  say "✅ All dependencies satisfied."
  exit 0
}

# Pre-scan for --install-dependencies (must run before config/profile/CLI parsing)
for _arg in "$@"; do
  if [[ "$_arg" == "--install-dependencies" ]]; then
    _dep_install_dependencies
    # _dep_install_dependencies always exits; this line is unreachable
  fi
done
unset _arg

# ===== Section 8: Man page installer (--install-man / --uninstall-man) =========================
# Embedded man page content, installed to the system man1 directory.
# Detects Homebrew prefix on macOS (Apple Silicon vs Intel) and falls back to
# /usr/local/share/man/man1. Uses sudo if the target directory isn't writable.

_man_target_dir(){
  # Prefer Homebrew man path if brew is installed
  if command -v brew >/dev/null 2>&1; then
    echo "$(brew --prefix)/share/man/man1"
  else
    echo "/usr/local/share/man/man1"
  fi
}

# <<< embedded man page >>>
_man_emit(){
  cat <<'MANPAGE_EOF'
.TH MUXM 1 "2026-04-11" "MuxMaster v1.4.0" "User Commands"
.SH NAME
muxm \- Universal AV1/DV/HLG/HDR10/SDR video encoder/muxer with format profiles
.SH SYNOPSIS
.B muxm
[\fIoptions\fR] [\fB\-\-\fR] \fIsource\fR [\fItarget\fR]
.SH DESCRIPTION
MuxMaster converts and muxes video for various playback targets including
Apple TV direct play, Plex/Jellyfin streaming, archival storage, animation
workflows, and universal compatibility. It handles Dolby Vision
(extract/convert/inject), HDR/HLG/SDR color handling, tone-mapping HDR to
SDR, audio selection/transcoding, and subtitle selection with optional
PGS\(->SRT OCR.
.PP
Configuration layers (lowest to highest precedence):
.PP
Defaults \(-> /etc/.muxmrc \(-> ~/.muxmrc \(-> ./.muxmrc \(-> \-\-profile \(-> CLI flags
.PP
.B muxm
requires
.B bash 4.3
or later. macOS ships bash\ 3.2; install a modern version
(e.g.,
.BR "brew install bash" )
and ensure it appears first in
.BR PATH .
.SH FORMAT PROFILES
Profiles are named presets that configure muxm for a specific use case in a
single flag. Every setting a profile changes can be individually overridden
with CLI flags.
.TP
.B \-\-profile \fINAME\fR[,\fINAME\fR,...]
Select one or more encoding profiles. When a single name is given, the pipeline
runs once with that profile's settings. When multiple names are separated by
commas (e.g. \fB\-\-profile youtube\-upload,streaming\-hevc\fR), each profile runs as
a separate sequential pass from the same source.
.PP
In multi\-profile mode, output files are auto\-suffixed with the profile name
(e.g. \fIsource.youtube\-upload.mp4\fR, \fIsource.streaming\-hevc.mp4\fR). If an
explicit output filename is provided, its stem and directory are used as the
base; its extension is ignored (each profile determines its own container). A
warning listing all output paths is printed before encoding starts.
.PP
.\" NOTE: Profile names below must match VALID_PROFILES in muxm (Section 2).
Available profiles:
.TP
.B archive
Remux\-first archival. DV + HDR10, multi\-track, copy only. Passthrough container
(MKV sources stay MKV, MP4 sources stay MP4). Commentary/descriptive audio tracks
dropped by default.
Audio filterable via
.BR AUDIO_LANG_PREF " and " AUDIO_KEEP_COMMENTARY ;
subtitles filterable via
.BR SUB_LANG_PREF ", " SUB_INCLUDE_FORCED / FULL / SDH ", and " SUB_MAX_TRACKS .
Skip if already ideal. JSON report.
.PP
The former name
.B dv\-archival
is accepted as a backwards\-compatible alias and emits a deprecation notice.
.TP
.B hdr10\-hq
Strip DV, keep HDR10. CRF 17, lossless audio + stereo fallback. MKV.
.TP
.B atv\-directplay\-hq
Apple TV Direct Play. DV\-aware, E\-AC\-3. Passthrough container
(MKV sources stay MKV, MP4 sources stay MP4). HEVC Main10, DV P8.1,
AAC stereo fallback. Forced subs burned for MP4; soft with native ASS preservation for MKV.
.TP
.B atv\-directplay\-animation
Apple TV Direct Play, animation quality. CRF 16, E\-AC\-3, ASS/SSA + PGS bitmap subs.
Passthrough container. HEVC 10\-bit (even SDR), animation\-tuned x265,
multi\-track subs. Lossless audio transcoded to E\-AC\-3 (ATV cannot Direct Play TrueHD/DTS\-HD MA).
Forced subs burned for MP4; soft with native ASS preservation for MKV.
.TP
.B streaming\-hevc
HEVC CRF 20 for Plex/Jellyfin. HDR10, E\-AC\-3. MP4. Preset medium,
AAC stereo. Targets Shield, Fire TV, Roku, smart TVs, web.
The former name
.B streaming
is accepted as a backwards\-compatible alias and emits a deprecation notice.
.TP
.B av1\-hq
High\-quality AV1 archival via SVT\-AV1. CRF 20, preset 6. HDR10 preserved,
DV disabled. MKV. Lossless audio passthrough with AAC stereo fallback.
SHA\-256 checksum. VMAF 93.48 at 4K HDR (parity with HEVC CRF 18).
See
.I docs/AV1_CALIBRATION.md
for methodology.
.TP
.B streaming\-av1
AV1 streaming. CRF 30, preset 6. Opus 256k surround
.RB ( AUDIO_FORCE_BITRATE=256k ),
AAC stereo fallback. MP4 container.
Optimized for platforms that accept AV1 (YouTube, Netflix ingest).
VMAF 97.70 at 1080p SDR, 90.65 at 4K HDR.
.TP
.B animation
Anime/cartoon. CRF 16, lossless audio, ASS subs. MKV. HEVC 10\-bit (even SDR),
animation\-tuned x265 (low psy\-rd, adjusted deblock, extra b\-frames),
multi\-track subs (ASS/SSA + PGS bitmap).
.TP
.B universal
H.264 SDR, AAC stereo. Lean, play anywhere. MP4. Tone\-map HDR, burn forced subs,
strip chapters/metadata.
.TP
.B youtube\-upload
H.264 high\-profile, CRF 16, preset slow. AAC stereo 256k, burn forced subs,
export full subs as external SRT. MP4. Strips metadata, keeps chapters.
No tone\-mapping (YouTube handles HDR). Designed for master\-quality uploads.
.SH COMMON OPTIONS
.TP
.BR \-h ", " \-\-help
Show condensed usage and available profiles.
.TP
.BR \-V ", " \-\-version
Show version.
.TP
.BR \-\-dry\-run
Plan steps without encoding/muxing (creates placeholders only).
.TP
.BR \-\-print\-effective\-config
Show the resolved configuration after all sources merge, then exit.
.TP
.BR \-\-setup
Run full first\-time setup: installs dependencies, the manual page, and
tab completion in a single command. Equivalent to running
\fB\-\-install\-dependencies\fR, \fB\-\-install\-man\fR, and
\fB\-\-install\-completions\fR in sequence.
.TP
.BR \-\-install\-dependencies
Check and install required/optional tools via Homebrew and pipx.
.TP
.BR \-\-install\-man
Install this manual page to the system man directory. Uses sudo if the
target directory is not writable. Detects Homebrew prefix automatically.
.TP
.BR \-\-uninstall\-man
Remove the installed manual page.
.TP
.BR \-\-install\-completions
Install bash/zsh tab\-completion to \fI~/.muxm/\fR and add a
\fBsource\fR line to the user's shell RC files
(\fI~/.bashrc\fR, \fI~/.bash_profile\fR, \fI~/.zshrc\fR).
.TP
.BR \-\-uninstall\-completions
Remove the tab\-completion file from \fI~/.muxm/\fR and clean
the \fBsource\fR lines from shell RC files.
.TP
.BR \-\-create\-config " " \fISCOPE\fR " " [\fIPROFILE\fR]
Generate a \fI.muxmrc\fR config file at the location specified by \fISCOPE\fR
and exit. Profile\-specific variables are uncommented and set; all other
variables are commented with defaults.
.RS
.TP
.B system
writes to \fI/etc/.muxmrc\fR (may require sudo)
.TP
.B user
writes to \fI~/.muxmrc\fR
.TP
.B project
writes to \fI$PWD/.muxmrc\fR
.RE
.IP
\fIPROFILE\fR defaults to \fBatv\-directplay\-hq\fR if omitted.
Refuses to overwrite an existing file; use \fB\-\-force\-create\-config\fR
to overwrite.
.PP
Additional CLI flags may follow the scope and profile to pre\-populate specific
values. For example, \fB\-\-create\-config user atv\-directplay\-hq \-\-crf 20
\-\-preset medium\fR generates a config with \fBCRF_VALUE=20\fR and
\fBPRESET_VALUE="medium"\fR uncommented. Supported overrides include
\fB\-\-crf\fR, \fB\-\-preset\fR, \fB\-\-output\-ext\fR, \fB\-\-level\fR,
\fB\-\-video\-codec\fR, \fB\-\-stereo\-bitrate\fR, \fB\-\-sub\-lang\-pref\fR,
\fB\-\-audio\-lang\-pref\fR, and common boolean toggles. Unrecognized flags
produce an error. Without overrides, behaviour is unchanged.
.TP
.BR \-\-force\-create\-config " " \fISCOPE\fR " " [\fIPROFILE\fR]
Same as \fB\-\-create\-config\fR but overwrites an existing file.
.SH VIDEO OPTIONS
.TP
.BR \-\-crf " " \fIN\fR
Video quality CRF (lower = higher quality). Typical: 16\(en22.
.TP
.BR \-p ", " \-\-preset " " \fINAME\fR
Encoder preset: ultrafast \fIto\fR placebo. Default: slower.
.TP
.BR \-\-video\-codec " " libx265|libx264|libsvt-av1|libaom-av1
Video encoder. Default: libx265. Use \fBlibsvt-av1\fR or \fBlibaom-av1\fR for AV1 output.
.TP
.BR \-l ", " \-\-level " " \fIN\fR
x265 level\-idc (e.g., 5.1). Ignored for AV1 codecs.
.TP
.BR \-\-x265\-params " " \fISTR\fR
Advanced x265 parameter string.
.TP
.BR \-\-x264\-params " " \fISTR\fR
Advanced x264 parameter string (used by
.B youtube\-upload
profile; e.g.,
.BR "profile=high:rc-lookahead=60:aq-mode=2:aq-strength=1.0" ).
.TP
.BR \-\-av1\-params " " \fISTR\fR
Advanced AV1 parameter string passed to \fB\-svtav1\-params\fR. Colon-separated key=value pairs
(e.g., \fBfilm-grain=0:enable-overlays=1:scd=1\fR). Only used with \fBlibsvt-av1\fR.
.TP
.BR \-\-av1\-maxrate " " \fIRATE\fR
Optional maximum bitrate for AV1 VBV-style rate control (e.g., \fB20000k\fR).
.TP
.BR \-\-av1\-bufsize " " \fISIZE\fR
Optional VBV buffer size for AV1 rate control (e.g., \fB40000k\fR).
.TP
.BR \-\-tonemap " , " \-\-no\-tonemap
Enable/disable HDR/HLG to SDR tone\-mapping.
.TP
.BR \-\-sdr\-force\-10bit " , " \-\-no\-sdr\-force\-10bit
Force/don't force 10\-bit output for SDR sources regardless of source bit
depth. Useful for animation where 8\-bit sources cause visible banding in
gradients. Default: disabled (follow source bit depth).
.TP
.BR \-\-video\-copy\-if\-compliant " , " \-\-no\-video\-copy\-if\-compliant
Copy/re\-encode video stream when source already matches target profile.
.TP
.BR \-\-max\-copy\-bitrate " " \fIRATE\fR
Maximum average bitrate for
.B \-\-video\-copy\-if\-compliant
to accept a stream copy. Sources exceeding this value are re\-encoded.
Uses ffprobe\(aqs reported bitrate when available, falling back to
.RI ( file_size\~\[mu]\~8\~/\~duration ).
Format: number with k suffix (e.g.,
.BR 50000k ).
Empty (default) disables the check.
.TP
.BR \-\-dv " , " \-\-no\-dv
Enable or disable Dolby Vision extraction/injection. Use \fB\-\-dv\fR to
re\-enable DV handling after a profile disables it (e.g., \fBanimation\fR).
.TP
.BR \-\-allow\-dv\-fallback " , " \-\-no\-allow\-dv\-fallback
If DV handling fails, fall back to non\-DV output (default) or hard\-fail.
.TP
.BR \-\-dv\-convert\-p81 " , " \-\-no\-dv\-convert\-p81
Enable/disable automatic conversion to DV Profile 8.1 when native DV
injection fails. Default: enabled.
.SS Dolby Vision Fallback Chain
When DV handling is active, muxm attempts each step in order and advances
to the next only on failure:
.IP 1. 4n
Extract the RPU from the source and inject it into the encoded base layer
as\-is (native profile preserved).
.IP 2.
If step 1 fails and
.B \-\-dv\-convert\-p81
is enabled (default): convert the RPU to DV Profile 8.1 and retry
injection. Profile\ 5 and dual\-layer Profile\ 7 sources are the primary
targets for this conversion.
.IP 3.
If step 2 also fails (or
.B \-\-no\-dv\-convert\-p81
was given) and
.B \-\-allow\-dv\-fallback
is enabled (default): produce non\-DV output. The base\-layer encode is
kept; DV metadata is silently discarded. A warning is printed.
.IP 4.
If
.B \-\-no\-allow\-dv\-fallback
is set: exit with status\ 40. Use this in automated pipelines where
silent DV loss would be unacceptable.
.PP
Summary of the controlling flags:
.RS
.TP
.B \-\-no\-dv
Skip DV handling entirely from the start (step 1 never runs).
.TP
.B \-\-no\-dv\-convert\-p81
Disable the P8.1 conversion attempt (step 2 skipped).
.TP
.B \-\-no\-allow\-dv\-fallback
Treat any DV failure as fatal rather than producing non\-DV output.
.RE
.TP
.BR \-\-conservative\-vbv " , " \-\-no\-conservative\-vbv
Enable/disable VBV guardrails that cap bitrate and buffer size per x265
level. Default: enabled.
.TP
.BR \-\-threads " " \fIN\fR
Number of threads for ffmpeg encoding.
.SH AUDIO OPTIONS
.TP
.BR \-\-audio\-track " " \fIN\fR
Select specific audio stream index (0\-based).
.TP
.BR \-\-audio\-lang\-pref " " \fILIST\fR
Preferred audio languages (comma\-separated, e.g., eng,spa).
.TP
.BR \-\-audio\-force\-codec " " \fICODEC\fR
Force all audio to a specific codec (e.g., aac).
.TP
.BR \-\-audio\-force\-bitrate " " \fIRATE\fR
Override the bitrate for all non\-lossless audio output (e.g., 256k).
Takes precedence over codec\-specific bitrate variables
.RB ( EAC3_BITRATE_5_1 ", " EAC3_BITRATE_7_1 ", " STEREO_BITRATE )
when set. The
.B streaming\-av1
profile sets this to 256k to pin Opus surround at an appropriate bitrate.
.TP
.BR \-\-audio\-lossless\-passthrough " , " \-\-no\-audio\-lossless\-passthrough
Allow/disallow lossless codecs (TrueHD, DTS\-HD MA, FLAC) to copy through.
.TP
.BR \-\-stereo\-fallback " , " \-\-no\-stereo\-fallback
Enable/disable automatic AAC stereo track when primary >2ch.
.TP
.BR \-\-stereo\-bitrate " " \fIRATE\fR
Stereo track bitrate (e.g., 192k).
.TP
.BR \-\-audio\-titles " , " \-\-no\-audio\-titles
Generate/suppress descriptive titles for audio streams
(e.g., \(lq5.1 Surround (E\-AC\-3)\(rq). Default: enabled.
.SS Audio Track Selection
When multiple audio streams exist, muxm scores each track and selects the highest.
Factors (in order of weight): language match against
.BR AUDIO_LANG_PREF ,
channel count, surround bonus (\[>=]6ch), codec preference order, and bitrate
(tie\-break). Tracks whose title contains "commentary", "descriptive", or
similar keywords receive a penalty
.RB ( AUDIO_SCORE_COMMENTARY_PENALTY ).
.PP
Scoring weights are configurable via
.IR .muxmrc :
.BR AUDIO_SCORE_LANG_BONUS " (default 150),"
.BR AUDIO_SCORE_CHANNEL_MULTIPLIER " (default 20),"
.BR AUDIO_SCORE_SURROUND_BONUS " (default 30),"
.BR AUDIO_SCORE_COMMENTARY_PENALTY " (default 200)."
.PP
Language preference is the strongest signal by default, ensuring that a
preferred\-language stereo track beats a foreign surround track. Reduce
.B AUDIO_SCORE_LANG_BONUS
to ~25 to prefer higher channel counts regardless of language.
.SS Multi\-Track Audio (Archival)
The
.B archive
profile uses multi\-track mode
.RB ( AUDIO_MULTI_TRACK=1 ),
which keeps all audio tracks that pass a subtractive filter instead of
scoring and selecting one. All surviving tracks are stream\-copied from
source (never transcoded). No stereo fallback is created.
.PP
Filters (configured via
.IR .muxmrc ):
.TP
.B AUDIO_LANG_PREF
When non\-empty, only tracks whose language matches the comma\-separated
list are kept. When empty (the default for
.BR archive ),
all languages pass.
.TP
.B AUDIO_KEEP_COMMENTARY
When 0 (the
.B archive
default), tracks whose title matches commentary or audio\-description
keywords are dropped. Set to 1 to keep them.
.PP
Multi\-track mode is automatically demoted to single\-track if
.B \-\-audio\-track
or
.B \-\-audio\-force\-codec
is set on the CLI (the explicit flag wins).
.SH SUBTITLE OPTIONS
.TP
.BR \-\-no\-subtitles
Disable all subtitle processing.
.TP
.BR \-\-sub\-lang\-pref " " \fILIST\fR
Preferred subtitle languages (comma\-separated).
.TP
.BR \-\-sub\-burn\-forced " , " \-\-no\-sub\-burn\-forced
Burn/don't burn forced subtitles into the video stream.
.TP
.BR \-\-sub\-export\-external " , " \-\-no\-sub\-export\-external
Export/embed subtitles as external .srt files.
.IP
.BR Note :
When combined with
.BR \-\-sub\-burn\-forced ,
players that auto\-load .srt sidecars with matching filenames (VLC, some
smart TVs) will display both the burned forced subtitles and the loaded
external track, resulting in doubled text for foreign\-dialogue segments.
Use
.B \-\-no\-sub\-export\-external
if targeting these players.
.TP
.BR \-\-no\-sub\-sdh
Exclude SDH/HI subtitle tracks.
.TP
.BR \-\-no\-ocr
Disable PGS\(->SRT OCR.
.TP
.BR \-\-sub\-preserve\-format " , " \-\-no\-sub\-preserve\-format
Preserve/convert native text subtitle formats (ASS/SSA).
When enabled and the output container is MKV, ASS/SSA subtitles are
stream\-copied in their native format, preserving positioning, fonts,
and typesetting. When disabled (or when the output container is MP4/MOV),
ASS/SSA subtitles are converted to plain\-text SRT.
The
.B animation
profile enables this by default.
.TP
.BR \-\-ocr\-tool " " \fITOOL\fR
OCR backend: pgsrip or sub2srt.
.TP
.BR \-\-ocr\-lang " " \fILANG\fR
OCR language (default: eng).
.TP
.BR \-\-no\-ext\-subs
Disable external subtitle sidecar discovery. When set, muxm ignores any
subtitle files found alongside the source and uses only embedded streams.
.TP
.BR \-\-ext\-subs
Re\-enable external subtitle sidecar discovery after
.B \-\-no\-ext\-subs
(or after a config file sets
.BR EXT_SUB_ENABLED=0 ).
Discovery is on by default; this flag is only needed to override an
explicit disable.
.TP
.BR \-\-ext\-subs\-dir " " \fIDIR\fR
Search
.I DIR
for subtitle sidecar files instead of the source file's own directory.
The directory must exist; muxm exits with status\~11 if it does not.
.TP
.BR \-\-sub\-sole\-ext\-fallback " , " \-\-no\-sub\-sole\-ext\-fallback
Enable or disable the sole\-sidecar language\-filter bypass (default: enabled).
When enabled, if the language filter would drop all subtitles but there is
exactly one external sidecar and zero embedded subtitle streams, that
sidecar is included regardless of its language tag.
This handles the common case of a sidecar with no language qualifier
(tagged
.B und
by default) that would otherwise be silently excluded by
.BR SUB_LANG_PREF .
Disable with
.B \-\-no\-sub\-sole\-ext\-fallback
or by setting
.B SUB_SOLE_EXT_FALLBACK=0
in
.IR .muxmrc .
.SS External Subtitle Discovery
muxm automatically scans the source file's directory (or the directory
given by
.BR \-\-ext\-subs\-dir )
for subtitle sidecar files whose basename begins with the source file's
stem followed by a dot.
.PP
Supported sidecar extensions:
.BR .srt ", " .ass ", " .ssa ", " .vtt ", " .sup ", " .idx
(\fB.idx\fR requires a matching
.B .sub
partner file in the same directory).
.PP
.B Filename parsing convention
.PP
.in +4n
.nf
\fI{stem}\fR[\fI.qualifier\fR\&...]\fI.ext\fR
.fi
.in
.PP
Qualifiers are the dot\-separated segments between the source stem and the
file extension, matched case\-insensitively:
.TP
.BR forced ", " signs ", " foreign
Track type is set to
.BR forced .
.TP
.BR sdh ", " hi ", " hearing ", " cc
Track type is set to
.BR sdh .
.TP
.I "2- or 3-letter alpha code"
Treated as an ISO\~639 language code and normalised to ISO\~639\-2/T
(e.g.,
.BR en " \(-> " eng ,
.BR es " \(-> " spa ).
.PP
Qualifiers not matching any of the above are ignored.
If no language qualifier is found, the language defaults to
.BR TAG_LANGUAGE_DEFAULT .
.PP
Examples:
.in +4n
.nf
movie.srt            \(-> lang=TAG_LANGUAGE_DEFAULT, type=full
movie.en.srt         \(-> lang=eng,  type=full
movie.forced.en.srt  \(-> lang=eng,  type=forced
movie.en.sdh.srt     \(-> lang=eng,  type=sdh
movie.fr.forced.sup  \(-> lang=fra,  type=forced
.fi
.in
.PP
Discovered external subtitles are merged with embedded subtitle streams
before any filtering takes place.
They then pass through the same filter pipeline as embedded tracks:
.BR SUB_LANG_PREF ", " SUB_INCLUDE_FORCED / FULL / SDH ", and " SUB_MAX_TRACKS .
Using
.B \-\-no\-subtitles
suppresses all subtitle processing including external sidecar discovery.
.SS Multi\-Track Subtitles
The
.BR archive ", " animation ", and " atv\-directplay\-animation
profiles use multi\-track subtitle mode
.RB ( SUB_MULTI_TRACK=1 ),
which keeps all subtitle tracks that pass a subtractive filter instead of
selecting one per type. Surviving tracks are stream\-copied from
source (no OCR, no intermediate files). The one exception is ASS/SSA
tracks when
.B SUB_PRESERVE_TEXT_FORMAT
is 0 (or the output container is MP4/MOV): these are converted inline
to SRT or mov_text respectively. All other codecs (PGS, SRT, VobSub)
are always stream\-copied.
.PP
Filters (configured via
.IR .muxmrc ):
.TP
.B SUB_LANG_PREF
When non\-empty, only tracks whose language matches the comma\-separated
list are kept. When empty (the default for
.BR archive ),
all languages pass.
.TP
.B SUB_INCLUDE_FORCED / SUB_INCLUDE_FULL / SUB_INCLUDE_SDH
Type filters. When 0, tracks of that type are excluded. All three
default to 1 in
.BR archive ", " animation ", and " atv\-directplay\-animation .
.TP
.B SUB_MAX_TRACKS
Maximum number of subtitle tracks to keep (applied after all other
filters as a cap). Defaults to 99 for
.BR archive ,
6 for
.BR animation " and " atv\-directplay\-animation .
.PP
Bitmap subtitles (PGS, VobSub) that cannot be muxed into the target
container (e.g., PGS into MP4) are silently skipped.
.BR archive ", " animation ", and " atv\-directplay\-animation
use MKV (or passthrough MKV), which handles all subtitle formats.
.PP
Multi\-track subtitle mode is automatically demoted to single\-track if
.B \-\-sub\-burn\-forced
is set on the CLI (burn\-in requires extracting and processing a single
forced track).
.SH OUTPUT OPTIONS
.TP
.BR \-\-output\-ext " " \fIEXT\fR
Output container: mp4|m4v|mov|mkv. Default: mp4.
Profiles with container passthrough
.RB ( archive ", " atv\-directplay\-hq ", " atv\-directplay\-animation )
set this to empty, deriving the output container from the source file extension
(mkv\(->mkv, mp4\(->mp4, etc.).
Sources with unsupported containers fall back to mkv.
.B \-\-output\-ext
on the CLI always overrides passthrough resolution.
.PP
When an explicit output filename is provided with a recognised extension
(\fB.mp4\fR, \fB.m4v\fR, \fB.mov\fR, \fB.mkv\fR), the container format is
inferred from that extension as if \fB\-\-output\-ext\fR had been passed. An
explicit \fB\-\-output\-ext\fR flag always takes precedence. This inference is
disabled in multi\-profile mode.
.TP
.BR \-\-keep\-chapters " , " \-\-no\-keep\-chapters
Keep/strip chapter markers.
.TP
.BR \-\-strip\-metadata " , " \-\-no\-strip\-metadata
Strip/keep non\-essential metadata.
.TP
.BR \-\-profile\-comment " , " \-\-no\-profile\-comment
Embed/suppress profile tagline in container comment metadata. Default: on.
When a profile is active, a short descriptive comment is written to the
output container's comment field (MP4 \(cocmt, MKV COMMENT).
.TP
.BR \-\-skip\-if\-ideal " , " \-\-no\-skip\-if\-ideal
Skip processing if source already matches profile requirements.
.PP
The following conditions prevent a source from being considered ideal, even when
this flag is set: video codec or pixel format mismatch; container mismatch;
\fBVIDEO_COPY_IF_COMPLIANT=0\fR (profile requires re\-encode);
\fBTONEMAP_HDR_TO_SDR=1\fR on an HDR source; \fBADD_STEREO_IF_MULTICH=1\fR
with surround audio (stereo fallback needed); discovered external subtitle
sidecar files that need muxing in.
.TP
.BR \-\-report\-json " , " \-\-no\-report\-json
Generate/suppress JSON report alongside output.
.TP
.BR \-\-checksum " , " \-\-no\-checksum
Write/suppress SHA\-256 checksum for final output.
.TP
.BR \-\-disk\-check " , " \-\-no\-disk\-check
Enable/disable the smart disk\-space preflight (default: on).
When enabled, muxm estimates the encoded output size from the source bitrate,
CRF value, preset, and audio configuration before encoding begins, then warns
if the available space on the output or temp volume appears insufficient.
Estimation uses per\-codec CRF\-to\-bitrate\-ratio tables and preset size
multipliers; a 25\ % safety margin and a floor of
.BR DISK_FREE_WARN_GB
are applied.
Set
.B DISK_CHECK=0
in
.I .muxmrc
or pass
.B \-\-no\-disk\-check
to silence the warning.
.TP
.BR \-K ", " \-\-keep\-temp\-always
Keep temporary workdir even on success.
.TP
.BR \-k ", " \-\-keep\-temp
Keep temporary workdir on failure.
.SH QUICK TEST OPTIONS
.TP
.BR \-\-skip\-video " , " \-\-skip\-audio " , " \-\-skip\-subs
Disable respective pipelines (useful for quick tests).
.SH FFMPEG OPTIONS
.TP
.BR \-\-ffmpeg\-loglevel " " \fILEVEL\fR
Set ffmpeg log verbosity (e.g., quiet, error, warning, info). Default: error.
.TP
.BR \-\-ffprobe\-loglevel " " \fILEVEL\fR
Set ffprobe log verbosity. Default: error.
.TP
.BR \-\-no\-hide\-banner
Show the ffmpeg/ffprobe startup banner (hidden by default).
.TP
.BR \-\-no\-overwrite
Do not overwrite existing intermediate files (ffmpeg overwrites by default).
.TP
.BR \-\-replace\-source
Replace the original source file with the encoded output. Prompts for
confirmation before proceeding. Requires an interactive terminal (stdin
must be a TTY); in non\-interactive shells (scripts, pipelines), this flag
is rejected with an error directing you to use
.BR \-\-force\-replace\-source .
.TP
.BR \-\-force\-replace\-source
Replace the original source file with the encoded output without prompting
for confirmation. This is the scripting\-friendly variant of
.BR \-\-replace\-source .
.PP
.B Source collision auto\-versioning:
When the derived output path matches the source file and neither
.B \-\-replace\-source
nor
.B \-\-force\-replace\-source
is given, muxm automatically appends a version number to avoid collision:
.IR movie(1).mp4 ", " movie(2).mp4 ,
etc.
.SH EXAMPLES
.TP
.B muxm Movie.mkv
Encode using default settings (no profile). Output name is
derived from input. Use \fB\-\-profile\fR for device\-optimized settings.
.TP
.B muxm \-\-profile atv\-directplay\-hq Movie.mkv
Encode for Apple TV direct play with Dolby Vision P8.1, E\-AC\-3 surround,
AAC stereo fallback, and burned forced subtitles.
.TP
.B muxm \-\-profile streaming\-hevc \-\-audio\-lang\-pref spa,eng Movie.mkv
Encode for Plex/Jellyfin streaming, preferring Spanish audio over English.
.TP
.B muxm \-\-profile archive Movie.mkv
Archival remux: copy video/audio without re\-encoding, preserve Dolby Vision
and lossless audio. Skips the file if it already matches.
.TP
.B muxm \-\-profile animation \-\-crf 14 Anime.mkv
Anime encode with animation\-tuned x265, overriding the profile's CRF 16
down to 14 for higher quality.
.TP
.B muxm \-\-profile universal Movie.mkv
Maximum compatibility: tone\-map HDR to SDR, H.264, AAC stereo, burned
forced subs. Plays on virtually any device.
.TP
.B muxm \-\-crf 18 \-p slow \-\-no\-subtitles Movie.mkv out.mp4
Custom encode without any profile: CRF 18, slow preset, strip all
subtitles, explicit output filename.
.TP
.B muxm \-\-ext\-subs\-dir /media/subs Movie.mkv
Encode Movie.mkv and pick up subtitle sidecar files from /media/subs
instead of the same directory as the source.
.TP
.B muxm \-\-no\-ext\-subs Movie.mkv
Encode Movie.mkv using only subtitle tracks embedded in the source;
ignore any .srt/.ass/.sup files in the same directory.
.TP
.B muxm \-\-profile hdr10\-hq \-\-audio\-lossless\-passthrough Movie.mkv
HDR10 encode keeping lossless audio (TrueHD/DTS\-HD MA) passed through
instead of transcoding.
.TP
.B muxm \-\-profile av1\-hq Movie.mkv
High\-quality AV1 encode via SVT\-AV1. CRF 20, lossless audio, HDR10
preserved. MKV output. Requires ffmpeg built with SVT\-AV1 support.
.TP
.B muxm \-\-profile streaming\-av1 Movie.mkv
AV1 streaming encode. CRF 30, Opus surround, MP4.
Smaller files than streaming\-hevc on AV1\-capable clients.
.TP
.B muxm \-\-dry\-run \-\-profile streaming\-hevc Movie.mkv
Preview what muxm would do without actually encoding. Creates placeholder
files and prints the planned pipeline.
.TP
.B muxm \-\-profile atv\-directplay\-hq \-\-print\-effective\-config
Show every resolved setting after config files and profile merge, then exit.
Useful for debugging config precedence.
.TP
.B muxm \-\-create\-config user streaming\-hevc
Generate a ~/.muxmrc pre\-filled with streaming\-hevc profile defaults. Edit to
taste; CLI flags still override everything.
.TP
.B muxm \-\-setup
Full first\-time setup: install dependencies, the manual page, and tab
completion all at once.
.TP
.B muxm \-\-install\-dependencies
Check for and install all required/optional tools (ffmpeg, dovi_tool,
pgsrip, etc.) via Homebrew and pipx.
.TP
.B muxm \-\-install\-man
Install this manual page so \fBman muxm\fR works.
.TP
.B muxm \-\-install\-completions
Install bash/zsh tab completion. Adds a source line to your shell RC files.
.SH EXIT STATUS
.TP
.B 0
Success.
.TP
.B 1
General error (config write failure, dependency check failure, unhandled runtime error).
.TP
.B 10
Missing required tool (ffmpeg, ffprobe, or jq not found).
.TP
.B 11
Invalid arguments, unknown option or profile, bad input/output path, or security
check failure (control characters in filename, source/output collision).
.TP
.B 12
Source file unusable: no video streams, corrupt metadata, or ffprobe JSON parse failure.
.TP
.B 40
Video encode or Dolby Vision RPU extraction/validation failure (with fallback disabled).
.TP
.B 41
DV RPU injection failure, intermediate file validation failure, or final mux failure.
.TP
.B 42
Video pipeline structural error (e.g., \-\-skip\-video with no alternative, missing
or corrupt encoded video stream).
.TP
.B 43
Audio transcode or copy failure.
.TP
.B 130
Interrupted by user (SIGINT / Ctrl\-C).
.TP
.B 143
Terminated by signal (SIGTERM).
.SH FILES
.TP
\fI/etc/.muxmrc\fR
System\-wide configuration (sourced first).
.TP
\fI~/.muxmrc\fR
Per\-user configuration (sourced second).
.TP
\fI./.muxmrc\fR
Per\-project configuration (sourced last, from
.BR $PWD ).
.PP
Configuration files use shell variable syntax and are sourced as bash
scripts. CLI flags always override config files. Profiles override
config files but are overridden by CLI flags.
.TP
\fI~/.muxm/muxm\-completion.bash\fR
Tab\-completion script installed by \fB\-\-install\-completions\fR.
.SH CONFIGURATION
All behavior can be tuned via shell variables set in
.I .muxmrc
files. Run
.B muxm \-\-create\-config user
to generate a fully\-commented template at
.I ~/.muxmrc
with every variable documented and preset for a chosen profile.
Variables set by the selected profile are uncommented; all others are
commented with their defaults.
.PP
Major variable groups:
.TP
.B Video
.BR CRF_VALUE ", " PRESET_VALUE ", " VIDEO_CODEC ", " X265_PARAMS_BASE ", " X264_PARAMS_BASE ", " SVT_AV1_PARAMS_BASE ", "
.BR LEVEL_VALUE ", " CONSERVATIVE_VBV ", " FORCE_CHROMA_420 ", "
.BR SDR_USE_10BIT_IF_SRC_10BIT ", " SDR_FORCE_10BIT ", "
.BR HDR_TARGET_PIXFMT ", " MAX_COPY_BITRATE ", "
.BR TONEMAP_HDR_TO_SDR ", " TONEMAP_FILTER .
.TP
.B Dolby Vision
.BR DISABLE_DV ", " ALLOW_DV_FALLBACK ", " DV_CONVERT_TO_P81_IF_FAIL .
.TP
.B Audio
.BR AUDIO_LANG_PREF ", " AUDIO_CODEC_PREFERENCE ", "
.BR AUDIO_TRACK_OVERRIDE ", " AUDIO_FORCE_CODEC ", "
.BR MAX_AUDIO_CHANNELS ", " ADD_STEREO_IF_MULTICH ", "
.BR STEREO_BITRATE ", " EAC3_BITRATE_5_1 ", " EAC3_BITRATE_7_1 ", "
.BR AUDIO_LOSSLESS_PASSTHROUGH ", " INCLUDE_AUDIO_TITLES .
.TP
.B Audio scoring
.BR AUDIO_SCORE_LANG_BONUS ", " AUDIO_SCORE_CHANNEL_MULTIPLIER ", "
.BR AUDIO_SCORE_SURROUND_BONUS ", " AUDIO_SCORE_COMMENTARY_PENALTY .
.TP
.B Multi\-track audio (archival)
.BR AUDIO_MULTI_TRACK ", " AUDIO_KEEP_COMMENTARY .
.TP
.B Subtitles
.BR SUB_LANG_PREF ", " SUB_INCLUDE_FORCED ", " SUB_INCLUDE_FULL ", "
.BR SUB_INCLUDE_SDH ", " SUB_MAX_TRACKS ", " SUB_BURN_FORCED ", "
.BR SUB_EXPORT_EXTERNAL ", " SUB_PRESERVE_TEXT_FORMAT ", "
.BR SUB_ENABLE_OCR ", " SUB_OCR_TOOL ", "
.BR SUB_OCR_LANG .
.TP
.B Multi\-track subtitles (archival)
.BR SUB_MULTI_TRACK .
.TP
.B External subtitle discovery
.BR EXT_SUB_ENABLED " (default\ 1; set to 0 to disable sidecar discovery),"
.BR EXT_SUB_DIR " (directory to scan; defaults to source file's directory),"
.BR SUB_SOLE_EXT_FALLBACK " (default\ 1; set to 0 to disable the sole\-sidecar language\-filter bypass)."
.TP
.B Output / operational
.BR OUTPUT_EXT ", " KEEP_CHAPTERS ", " STRIP_METADATA ", "
.BR SKIP_IF_IDEAL ", " REPORT_JSON ", " CHECKSUM ", "
.BR DISK_FREE_WARN_GB " (default\ 5; minimum free\-space floor in GB),"
.BR DISK_CHECK " (default\ 1; set to 0 to disable smart disk preflight),"
.BR TAG_LANGUAGE_DEFAULT .
.TP
.B ffmpeg / ffprobe
.BR FFMPEG_LOGLEVEL ", " FFPROBE_LOGLEVEL ", " FFMPEG_HIDE_BANNER ", "
.BR FFMPEG_OVERWRITE ", " THREADS .
.TP
.B VBV guardrails
.BR LEVEL_VBV_4_1_MAXRATE ", " LEVEL_VBV_4_1_BUFSIZE ", "
.BR LEVEL_VBV_5_0_MAXRATE ", " LEVEL_VBV_5_0_BUFSIZE ", "
.BR LEVEL_VBV_5_1_MAXRATE ", " LEVEL_VBV_5_1_BUFSIZE ", "
.BR LEVEL_VBV_5_2_MAXRATE ", " LEVEL_VBV_5_2_BUFSIZE .
.TP
.B X264_PARAMS_BASE
Base x264 parameter string for H.264 encodes. Appended to the ffmpeg
\fB\-x264\-params\fR flag. Used by the \fByoutube\-upload\fR profile.
Default: empty.
.TP
.B SVT_AV1_PARAMS_BASE
Base SVT-AV1 parameter string for AV1 encodes (\fBlibsvt-av1\fR). Passed via
\fB\-svtav1\-params\fR. Default: \fBfilm-grain=0:enable-overlays=1:scd=1\fR.
.TP
.B AV1_MAXRATE
Optional maximum bitrate for AV1 VBV-style rate control. Example: \fB20000k\fR.
Default: empty (no VBV).
.TP
.B AV1_BUFSIZE
Optional VBV buffer size for AV1 rate control. Example: \fB40000k\fR.
Default: empty.
.PP
Use
.B \-\-print\-effective\-config
to inspect the fully\-resolved configuration after all layers merge.
.SH ENVIRONMENT
.TP
.B DEBUG
Set to
.B 1
to enable bash trace output
.RB ( "set \-x" )
and suppress automatic temp\-directory cleanup. Useful for diagnosing
pipeline failures.
.TP
.B TESSDATA_PREFIX
Path to Tesseract OCR language data. Required by
.B pgsrip
for PGS subtitle OCR. Typically set to the Homebrew tessdata directory
(e.g.,
.IR /opt/homebrew/share/tessdata ).
Run
.B muxm \-\-install\-dependencies
to check and configure.
.SH NOTES
.SS Security: .muxmrc sourcing
Configuration files are sourced as shell scripts and can execute
arbitrary code. The project\-level
.I ./.muxmrc
is sourced from
.BR $PWD ,
so a malicious file placed in a directory you
.B cd
into could run arbitrary commands. This follows the same trust model as
.BR Makefile ", " .envrc " (direnv),"
and similar developer tooling. Only source project\-level configs in
directories you trust.
.SS Double\-dash separator
Use
.B \-\-
to mark the end of options. This is necessary when the source filename
begins with a hyphen:
.IP
.B muxm \-\-profile streaming\-hevc \-\- \-unusual\-name.mkv
.SH DEPENDENCIES
.TP
.B Required
\fBffmpeg\fR, \fBffprobe\fR \(em core encoding and media inspection.
.br
\fBjq\fR \(em JSON parsing for stream metadata and reporting.
.br
\fBbc\fR \(em arithmetic evaluation for frame\-rate and bitrate calculations.
.TP
.B Optional
\fBffmpeg with libass\fR (\fBffmpeg\-full\fR on Homebrew) \(em required for
subtitle burn\-in via \fB\-\-sub\-burn\-forced\fR. The standard \fBffmpeg\fR
package works for all other features.
.br
\fBdovi_tool\fR \(em Dolby Vision RPU extraction/injection. DV handling is
automatically disabled if missing.
.br
\fBMP4Box\fR (gpac) \(em DV container\-level signaling verification.
Detected at runtime as \fBmp4box\fR or \fBMP4Box\fR.
.br
\fBtesseract\fR \(em OCR engine required by \fBpgsrip\fR for PGS bitmap
subtitle conversion.
.br
\fBpgsrip\fR or \fBsub2srt\fR \(em PGS bitmap subtitle OCR to SRT.
Configurable via \fB\-\-ocr\-tool\fR.
