  FORCE_CHROMA_420=1
  X264_PARAMS_BASE='profile=high:rc-lookahead=60:aq-mode=2:aq-strength=1.0'
  # HDR: preserve pixel format, no DV, no tone-map (let YouTube handle it)
  TONEMAP_HDR_TO_SDR=0
  HDR_TARGET_PIXFMT="yuv420p10le"
  # Audio: AAC stereo only (YouTube ingestion requirement)
  AUDIO_FORCE_CODEC="aac"
  MAX_AUDIO_CHANNELS=2
  STEREO_BITRATE="256k"
  AUDIO_LOSSLESS_PASSTHROUGH=0
  ADD_STEREO_IF_MULTICH=0
  # Subs: burn forced, export full as external SRT
  SUB_INCLUDE_FORCED=1
  SUB_INCLUDE_FULL=1
  SUB_INCLUDE_SDH=0
  SUB_BURN_FORCED=1
  SUB_EXPORT_EXTERNAL=1
  # Chapters/metadata: strip fluff, keep chapters
  STRIP_METADATA=1
  KEEP_CHAPTERS=1
}

# _profile_comment — return the profile tagline for container comment metadata.
# Returns empty string for unrecognised/absent profiles (no comment written).
_profile_comment() {
  case "${PROFILE_NAME:-}" in
