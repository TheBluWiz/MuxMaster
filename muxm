  SUB_INCLUDE_FORCED=1
  SUB_INCLUDE_FULL=1
  SUB_INCLUDE_SDH=0
  SUB_BURN_FORCED=1
  SUB_EXPORT_EXTERNAL=1
  # Chapters/metadata: strip
  KEEP_CHAPTERS=0
  STRIP_METADATA=1
}

