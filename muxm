# Dispatcher
apply_profile() {
  [[ -z "${PROFILE_NAME:-}" ]] && return 0
  case "$PROFILE_NAME" in
    archive)                     apply_profile_archive ;;
    dv-archival)
      # Deprecated alias: normalise PROFILE_NAME so all downstream code sees 'archive'.
      warn "Profile 'dv-archival' is deprecated. Use '--profile archive' instead."
      PROFILE_NAME="archive"
      apply_profile_archive ;;
    hdr10-hq)                    apply_profile_hdr10_hq ;;
    atv-directplay-hq)           apply_profile_atv_directplay_hq ;;
    atv-directplay-animation)    apply_profile_atv_directplay_animation ;;
    streaming-hevc)              apply_profile_streaming_hevc ;;
    streaming)
      # Deprecated alias: normalise PROFILE_NAME so all downstream code sees 'streaming-hevc'.
      warn "Profile 'streaming' is deprecated. Use '--profile streaming-hevc' instead."
      PROFILE_NAME="streaming-hevc"
      apply_profile_streaming_hevc ;;
    av1-hq)                      apply_profile_av1_hq ;;
    streaming-av1)               apply_profile_streaming_av1 ;;
    animation)                   apply_profile_animation ;;
    universal)                   apply_profile_universal ;;
    youtube-upload)              apply_profile_youtube_upload ;;
    *)
      printf "❌ ERROR: Unknown profile: %s\n" "$PROFILE_NAME" >&2
      printf "   Valid profiles: %s\n" "$(_valid_profiles_display)" >&2
      exit 11
      ;;
  esac
  note "Applied profile: $PROFILE_NAME (source: ${_PROFILE_SOURCE:-unknown})"
}

# _create_config_prescan — Pre-scan CLI args for --create-config/--force-create-config before full parsing.
#
# Scans "$@" for the config-generation flags, then calls _create_config and
# exits. Must run after profile apply functions are defined so the config
# generator can invoke them. Halts all other operations if the flag is found.
#
# Args: "$@" — the raw CLI arguments passed to main.
# Returns: exits 0 after writing config; returns normally (no-op) if flag absent.
# Globals: PROFILE_NAME (read)
_create_config_prescan() {
  local _cc_force=0 _cc_scope="" _cc_profile="" _cc_found=0 _cc_i=0
  local -a _cc_args=("$@")
  while (( _cc_i < ${#_cc_args[@]} )); do
    case "${_cc_args[$_cc_i]}" in
      --create-config|--force-create-config)
        _cc_found=1
        [[ "${_cc_args[$_cc_i]}" == "--force-create-config" ]] && _cc_force=1
        # Next arg must be scope
        if (( _cc_i + 1 >= ${#_cc_args[@]} )); then
          printf '❌ ERROR: %s requires a scope: system, user, or project\n' "${_cc_args[$_cc_i]}" >&2
          printf '   Usage: muxm %s <system|user|project> [profile]\n' "${_cc_args[$_cc_i]}" >&2
          exit 11
        fi
        _cc_scope="${_cc_args[$((_cc_i + 1))]}"
        # Optional: profile as third arg (only if it doesn't start with -)
        if (( _cc_i + 2 < ${#_cc_args[@]} )) && [[ "${_cc_args[$((_cc_i + 2))]}" != -* ]]; then
          _cc_profile="${_cc_args[$((_cc_i + 2))]}"
        fi
        break
        ;;
    esac
    _cc_i=$((_cc_i + 1))
  done
  if (( _cc_found )); then
    # Collect any remaining args after scope+profile as config override flags
    local _cc_override_start
    if [[ -n "$_cc_profile" ]]; then
      _cc_override_start=$(( _cc_i + 3 ))
    else
      _cc_override_start=$(( _cc_i + 2 ))
    fi
    local -a _cc_override_args=()
    local _cc_oi=$(( _cc_override_start ))
    while (( _cc_oi < ${#_cc_args[@]} )); do
      _cc_override_args+=("${_cc_args[$_cc_oi]}")
      _cc_oi=$(( _cc_oi + 1 ))
    done
    _create_config "$_cc_scope" "$_cc_profile" "$_cc_force" "${_cc_override_args[@]}"
    # _create_config always exits; this line is unreachable
  fi
}
_create_config_prescan "$@"

apply_profile

# _probe_profile_ext PROFILE — return the OUTPUT_EXT that apply_profile_PROFILE sets.
# Runs in an isolated local scope so the caller's OUTPUT_EXT is never mutated.
_probe_profile_ext() {
  local OUTPUT_EXT="mp4"
  "apply_profile_${1//-/_}" 2>/dev/null
  echo "${OUTPUT_EXT}"
}

# _run_multi_profiles — multi-profile dispatch.
# Called when _MULTI_PROFILE_MODE=1 (--profile a,b,c detected in prescan).
# Re-invokes the script once per profile as a subprocess, deriving a per-profile
# output path automatically. Each subprocess gets its own fresh variable state.
#
# Args: none (reads _MULTI_PROFILES, _ORIG_FILTERED_ARGS, SRC_ABS, POSITIONALS)
# Exits: 0 if all profiles succeed; 1 if any failed.
_run_multi_profiles() {
  local -i _total=${#_MULTI_PROFILES[@]}
  local -a _results=()
  local -i _fail_count=0
  local _src_stem="${SRC_ABS%.*}"
  local _src_ext="${SRC_ABS##*.}"

  # Determine output stem base (full path prefix used for per-profile file names).
  # If the user supplied an explicit output filename as the second positional arg,
  # extract its stem and directory; otherwise fall back to the source stem.
  local _out_stem_full
  local -i _user_provided=0
  if [[ ${#POSITIONALS[@]} -ge 2 && -n "${POSITIONALS[1]}" ]]; then
    local _user_out="${POSITIONALS[1]}"
    local _user_dir _user_base _user_stem
    _user_dir="$(dirname "$_user_out")"
    _user_base="$(basename "$_user_out")"
    _user_stem="${_user_base%.*}"
    local _user_ext="${_user_base##*.}"
    # Normalise and keep only recognised container extensions
    _user_ext="${_user_ext,,}"
    [[ "$_user_ext" =~ ^(mp4|m4v|mov|mkv)$ ]] || _user_ext=""
    _out_stem_full="${_user_dir}/${_user_stem}"
    _user_provided=1
  else
    _out_stem_full="$_src_stem"
  fi

  # Build child flag args: _ORIG_FILTERED_ARGS with source/output positionals stripped.
  # Positionals are always collected at the end by the CLI parser; strip the last
  # ${#POSITIONALS[@]} elements (1 = source only, 2 = source + explicit output).
  # _nflags = total arg count minus positionals = count of flag-only args to pass through.
  local -a _child_flags=()
  local -i _nargs=${#_ORIG_FILTERED_ARGS[@]}
  local -i _npos=${#POSITIONALS[@]}
  local -i _nflags=$(( _nargs - _npos ))
  (( _nflags < 0 )) && _nflags=0
  _child_flags=("${_ORIG_FILTERED_ARGS[@]:0:$_nflags}")

  # Pre-compute per-profile extensions and output paths (needed for warning + invocation).
  local -a _prof_exts=()
  local -a _child_outs=()
  local _mp _prof_ext
  for _mp in "${_MULTI_PROFILES[@]}"; do
    _prof_ext="$(_probe_profile_ext "$_mp")"
    # Passthrough profiles set OUTPUT_EXT="" — fall back to user extension (if
    # the user specified an explicit output filename with a recognised container
    # extension) or the source extension.
    if [[ -z "$_prof_ext" ]]; then
      if (( _user_provided )) && [[ -n "${_user_ext:-}" ]]; then
        _prof_ext="$_user_ext"
      else
        _prof_ext="$_src_ext"
      fi
    fi
    _prof_ext="${_prof_ext,,}"
    _prof_exts+=("$_prof_ext")
    _child_outs+=("${_out_stem_full}.${_mp}.${_prof_ext}")
  done

  # If the user supplied an explicit output filename, warn that it will be split
  # into per-profile files before the first encode starts.
  if (( _user_provided )); then
    warn "Multi-profile mode: output will be split into per-profile files:"
    local _co
    for _co in "${_child_outs[@]}"; do
      printf "     %s\n" "$_co" >&2
    done
  fi

  local -i _idx=0
  for _mp in "${_MULTI_PROFILES[@]}"; do
    _idx=$((_idx + 1))

    # Header per profile pass
    printf "━━━ Profile %d/%d: %s ━━━\n" "$_idx" "$_total" "$_mp" >&2

    _prof_ext="${_prof_exts[$((_idx-1))]}"
    local _child_out="${_child_outs[$((_idx-1))]}"

    # Re-invoke muxm for this profile
    local -i _child_rc=0
    "$0" --profile "$_mp" --output-ext "$_prof_ext" \
      "${_child_flags[@]}" "$SRC_ABS" "$_child_out" || _child_rc=$?

    if (( _child_rc == 0 )); then
      _results+=("${_mp}:PASS")
    else
      _results+=("${_mp}:FAIL:${_child_rc}")
      _fail_count=$((_fail_count + 1))
      warn "Profile '${_mp}' failed (exit ${_child_rc}) — continuing with remaining profiles."
    fi
  done

  # Per-profile summary
  printf "\n" >&2
  say "Multi-profile summary:"
  for _r in "${_results[@]}"; do
    local _rp="${_r%%:*}" _rs="${_r#*:}"
    if [[ "$_rs" == "PASS" ]]; then
      say "  ✅ ${_rp}: PASS"
    else
      say "  ❌ ${_rp}: FAIL (exit ${_rs#*:})"
    fi
  done

  return $(( _fail_count > 0 ? 1 : 0 ))
}

# ===== Section 12: CLI parsing =================================================================
if [[ -n "$OUTPUT_EXT" ]]; then
  USAGE_SHORT="Usage: ${CLI_NAME} [options] <source> [target.${OUTPUT_EXT}]"
else
  USAGE_SHORT="Usage: ${CLI_NAME} [options] <source> [target.{src-ext}]"
fi
print_usage(){
  cat <<EOF
${APP_NAME} v${VERSION} — ${CLI_NAME}

$USAGE_SHORT

Profiles (--profile NAME):
  archive                    Remux-first archival. DV + HDR10, multi-track. Passthrough container.
  hdr10-hq                   Strip DV, keep HDR10. CRF 17, lossless audio. MKV.
  atv-directplay-hq          Apple TV Direct Play. DV-aware, E-AC-3. Passthrough container.
  atv-directplay-animation   ATV Direct Play, animation quality. CRF 16, E-AC-3, ASS subs. Passthrough container.
  streaming-hevc             HEVC CRF 20 for Plex/Jellyfin. HDR10, E-AC-3. MP4.
  av1-hq                     AV1 CRF 20, lossless audio. HDR10, MKV.
  streaming-av1              AV1 CRF 30, Opus audio. Optimized for AV1-capable platforms. MP4.
  animation                  Anime/cartoon. CRF 16, lossless audio, ASS subs. MKV.
