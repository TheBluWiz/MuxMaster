  printf '#TAG_LANGUAGE_DEFAULT=und\n'
  printf '\n'
  echo "# Generate descriptive titles for audio streams (e.g., \"5.1 Surround (E-AC-3)\")"
  _V INCLUDE_AUDIO_TITLES
  printf '\n'

  printf '\n'
  echo "# ========================="
  echo "# Operational controls"
  echo "# ========================="
  printf '\n'
  echo "# Write a checksum next to final output (algorithm set by CHECKSUM_ALGO)"
  _V CHECKSUM
  printf '\n'
  echo "# Checksum algorithm: sha256 | blake2b | auto (auto prefers b2sum, falls back to sha256)"
  _V CHECKSUM_ALGO
  printf '\n'
  echo "# Dry-run: plan the steps without generating real outputs"
  printf '#DRY_RUN=0\n'
  printf '\n'
  echo "# Skip processing if source already matches profile requirements"
  _V SKIP_IF_IDEAL
  printf '\n'
  echo "# Generate a JSON report alongside output"
  _V REPORT_JSON
  printf '\n'
  echo "# Warn when free disk space drops below this many GB during encode"
  printf '#DISK_FREE_WARN_GB=5\n'
  printf '\n'
  echo "# Enable smart disk space preflight estimation (1 = enabled, 0 = disable with --no-disk-check)"
  printf '#DISK_CHECK=1\n'
  printf '\n'
  echo "# Keep temporary workdir on failure (for debugging)"
  printf '#KEEP_TEMP=0\n'
  printf '\n'
  echo "# Keep temporary workdir even on success"
  printf '#KEEP_TEMP_ALWAYS=0\n'
  printf '\n'
  echo "# Replace the original source file with the output (requires interactive TTY)"
  printf '#REPLACE_SOURCE=0\n'
  printf '\n'
  echo "# Replace the original source file without confirmation (scripting-friendly)"
  printf '#FORCE_REPLACE_SOURCE=0\n'
  printf '\n'

  printf '\n'
  echo "# ========================="
  echo "# ffmpeg / ffprobe UX"
  echo "# ========================="
  printf '\n'
  echo "# Hide ffmpeg banner: 1 = hide  |  0 = show"
  printf '#FFMPEG_HIDE_BANNER=1\n'
  printf '\n'
  echo "# ffmpeg log level: quiet|panic|fatal|error|warning|info|verbose|debug|trace"
  _V FFMPEG_LOGLEVEL "quoted"
  printf '\n'
  echo "# Overwrite outputs without prompting"
  printf '#FFMPEG_OVERWRITE=1\n'
  printf '\n'
  echo "# ffprobe log level"
  printf '#FFPROBE_LOGLEVEL=error\n'

  unset -f _V
}
