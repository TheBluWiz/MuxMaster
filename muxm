  _V SUB_PRESERVE_BITMAP
  printf '\n'

  printf '\n'
  echo "# ========================="
  echo "# Multi-track subtitles (archival)"
  echo "# ========================="
  printf '\n'
  echo "# Keep ALL matching subtitle tracks instead of selecting one per type."
  echo "# All tracks are stream-copied from source (no OCR, no format conversion)."
